# Secrets
config/.env
config/.env.marketing

# Python
__pycache__/
*.pyc
venv/
venv_office/
.DS_Store

# Old files
*_old*

# Orchestrator subprocess logs
logs/

# Completed briefs archive
config/.mdcompletati/

# Office scripts (CEO docx formatting tools)
scripts/office/

# Local machine instructions
.instructions.md

# Claude Code config (user-specific: skill flags, transcript prefs, hooks)
.claude/

# X stats scan reports (local-only, synced manually on demand)
post_x/

# Marketing data connectors output (Dev.to/Umami/Bing/GSC/Reddit), local-only
marketing_data/

# 47d backtest: OHLCV cache (~13 MB, rigenerabile) e raw trades (~4 MB)
# I 3 file di summary (CSV piccoli) restano nel repo per leggibilità.
scripts/output/.ohlcv_cache/
scripts/output/backtest_trades.csv

# Web prototypes (local-only, not deployed to Vercel)
web_proto/

# Blog inbox: CEO drafts + briefs passati a CC, locali al MBP.
# Una volta processati, il .md va in web_astro/src/content/blog/ e il
# brief in briefresolved.md/. Vedi blog/README.md per il flow.
# Anchored a root: NON deve ignorare web_astro/src/content/blog/.
/blog/

# Old pre-Astro site (replaced by web_astro/, kept locally as backup)
web/

# Analysis scratch (CSV dumps + scripts ad-hoc, local-only)
analysis/

# Audit reports (privati, solo locale)
audits/*
!audits/.gitkeep
# State archive snapshots: tracked so the readable history survives
# compaction passes (git log alone works but is harder to grep/skim).
!audits/PROJECT_STATE_archive*.md
!audits/BUSINESS_STATE_archive*.md
# Evergreen audit-request TEMPLATES are tracked (versioned rules, multi-machine).
# Dated request/report files (YYYYMMDD_audit[AX].md) stay local/gitignored.
!audits/requests/
audits/requests/*
!audits/requests/audit_request_A1.md
!audits/requests/audit_request_A2.md
!audits/requests/audit_request_A3.md
