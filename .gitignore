# Secrets
config/.env

# Python
__pycache__/
*.pyc
venv/
venv_office/
.DS_Store

# Old files
*_old*

# Orchestrator subprocess logs
logs/

# Completed briefs archive
config/.mdcompletati/

# Office scripts (CEO docx formatting tools)
scripts/office/

# Local machine instructions
.instructions.md

# Claude Code config (user-specific: skill flags, transcript prefs, hooks)
.claude/

# X stats scan reports (local-only, synced manually on demand)
post_x/

# 47d backtest: OHLCV cache (~13 MB, rigenerabile) e raw trades (~4 MB)
# I 3 file di summary (CSV piccoli) restano nel repo per leggibilità.
scripts/output/.ohlcv_cache/
scripts/output/backtest_trades.csv

# Web prototypes (local-only, not deployed to Vercel)
web_proto/

# Old pre-Astro site (replaced by web_astro/, kept locally as backup)
web/

# Audit reports (privati, solo locale)
audits/*
!audits/.gitkeep
# PROJECT_STATE archive snapshots: tracked so the readable history survives
# compaction passes (git log alone works but is harder to grep/skim).
!audits/PROJECT_STATE_archive_*.md
