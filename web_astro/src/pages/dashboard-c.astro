---
import Layout from "../layouts/Layout.astro";
import {
  mockSnapshot, mockGrid, mockTF, mockCumulative, mockDaily,
  mockTrades, mockCEOLog, fmtUsd, fmtSigned, fmtPct, fmtPrice, fmtTime, fmtDate,
} from "../data/dashboard-mock.ts";

const totalNW   = mockGrid.netWorth + mockTF.netWorth;
const totalInit = mockGrid.initial + mockTF.initial;
const totalPnl  = totalNW - totalInit;
const totalPct  = (totalPnl / totalInit) * 100;
---

<Layout title="Dashboard — Operativo editoriale (proto C)" current="dashboard">

  {/* ============ Variant switcher ============ */}
  <div class="border-b border-border-soft bg-surface/40">
    <div class="mx-auto max-w-6xl px-4 py-2 sm:px-6 flex items-center justify-between gap-4 text-[11px] font-mono">
      <span class="text-text-muted uppercase tracking-[0.18em]">Prototype</span>
      <div class="flex items-center gap-3">
        <a href="/dashboard-a" class="px-2.5 py-1 rounded border border-border text-text-dim hover:text-text">A · Lab notebook</a>
        <a href="/dashboard-b" class="px-2.5 py-1 rounded border border-border text-text-dim hover:text-text">B · Stato del fondo</a>
        <a href="/dashboard-c" class="px-2.5 py-1 rounded border border-primary text-primary">C · Operativo editoriale</a>
      </div>
    </div>
  </div>

  <main class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">

    {/* ============ EDITORIAL META ============ */}
    <section class="reveal">
      <div class="flex items-center gap-3 font-mono text-[11px] uppercase tracking-[0.22em] text-text-muted">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-pos shadow-[0_0_8px_rgba(134,239,172,0.7)]"></span>
        Daily report
        <span class="text-border">·</span>
        <span>{mockSnapshot.asOfLabel}</span>
        <span class="text-border">·</span>
        <span>day {mockSnapshot.dayNumber}</span>
      </div>
    </section>

    {/* ============ CEO LOG come articolo featured ============ */}
    <article class="mt-6 reveal">
      <h1 class="font-sans text-3xl sm:text-4xl text-text leading-tight font-medium">
        From the CEO's log
      </h1>
      <p class="mt-6 text-text leading-relaxed text-[18px] sm:text-[19px] font-light">
        "{mockCEOLog.today.text}"
      </p>
      <div class="mt-5 font-mono text-[11px] text-text-muted">
        — {mockCEOLog.today.model} · {fmtDate(mockCEOLog.today.date + "T00:00:00Z")}, day {mockCEOLog.today.dayNumber}
      </div>
    </article>

    {/* ============ SYNTHETIC SUMMARY ROW ============ */}
    <section class="mt-12 reveal">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="rounded-lg border border-border bg-surface p-4">
          <div class="font-mono text-[10px] uppercase tracking-[0.15em] text-text-muted">net worth</div>
          <div class="font-mono text-[20px] text-text mt-1.5" data-count={fmtUsd(totalNW)}>{fmtUsd(totalNW)}</div>
          <div class="font-mono text-[10px] text-text-muted mt-0.5">of {fmtUsd(totalInit, 0)}</div>
        </div>
        <div class="rounded-lg border border-border bg-surface p-4">
          <div class="font-mono text-[10px] uppercase tracking-[0.15em] text-text-muted">overall p&amp;l</div>
          <div class={`font-mono text-[20px] mt-1.5 ${totalPnl >= 0 ? "text-pos" : "text-neg"}`}>
            {fmtSigned(totalPnl)}
          </div>
          <div class={`font-mono text-[10px] mt-0.5 ${totalPnl >= 0 ? "text-pos/70" : "text-neg/70"}`}>
            {fmtPct(totalPct)}
          </div>
        </div>
        <div class="rounded-lg border border-border bg-surface p-4">
          <div class="font-mono text-[10px] uppercase tracking-[0.15em] text-text-muted">today</div>
          <div class={`font-mono text-[20px] mt-1.5 ${(mockGrid.todayPnl + mockTF.todayPnl) >= 0 ? "text-pos" : "text-neg"}`}>
            {fmtSigned(mockGrid.todayPnl + mockTF.todayPnl)}
          </div>
          <div class="font-mono text-[10px] text-text-muted mt-0.5">
            {mockGrid.todayTrades + mockTF.todayTrades} trades
          </div>
        </div>
        <div class="rounded-lg border border-border bg-surface p-4">
          <div class="font-mono text-[10px] uppercase tracking-[0.15em] text-text-muted">total trades</div>
          <div class="font-mono text-[20px] text-text mt-1.5">{mockGrid.trades + mockTF.trades}</div>
          <div class="font-mono text-[10px] text-text-muted mt-0.5">
            {mockGrid.buys + mockTF.buys}b · {mockGrid.sells + mockTF.sells}s
          </div>
        </div>
      </div>
    </section>

    {/* ============ TWO BOTS — magazine spread ============ */}
    <section class="mt-16">
      <div class="reveal mb-7">
        <h2 class="font-sans text-2xl text-text font-medium">The two operators</h2>
        <p class="text-text-dim text-[15px] mt-1">
          Both running today. Different jobs, different rhythms, different bags.
        </p>
      </div>

      <div class="reveal-stagger space-y-5">

        {/* GRID magazine card */}
        <article class="rounded-xl border border-border bg-surface overflow-hidden">
          <div class="grid grid-cols-1 md:grid-cols-[1fr_2fr]">
            <div class="p-6 border-b md:border-b-0 md:border-r border-border-soft" style="background:linear-gradient(180deg,rgba(34,197,94,0.05),transparent)">
              <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-pos">grid bot · live</div>
              <h3 class="font-sans text-2xl text-text font-medium mt-2">The cash machine</h3>
              <p class="text-text-dim text-[14px] mt-2 leading-relaxed">
                Buy low, sell high, mechanically. Three coins. Boring on purpose.
              </p>
              <div class="mt-5 flex items-baseline gap-3">
                <span class="font-mono text-3xl text-text">{fmtUsd(mockGrid.netWorth)}</span>
                <span class={`font-mono text-[15px] ${mockGrid.pnlAbs >= 0 ? "text-pos" : "text-neg"}`}>
                  {fmtSigned(mockGrid.pnlAbs)}
                </span>
              </div>
              <div class="font-mono text-[11px] text-text-muted mt-1">
                from ${mockGrid.initial} · {fmtPct(mockGrid.pnlPct)}
              </div>
            </div>
            <div class="p-6">
              <div class="font-mono text-[10px] uppercase tracking-[0.15em] text-text-muted mb-3">per asset</div>
              <div class="space-y-3">
                {mockGrid.assets.map((a) => {
                  const totalPnl = a.realized + a.unrealized;
                  return (
                    <div class="flex items-center gap-3">
                      <span class="inline-block w-2 h-2 rounded-full flex-shrink-0" style={`background:${a.color}`}></span>
                      <span class="font-mono text-[13px] text-text w-12">{a.short}</span>
                      <div class="flex-1 grid grid-cols-3 gap-3 font-mono text-[11px]">
                        <div>
                          <span class="text-text-muted">mtm </span>
                          <span class="text-text">{fmtUsd(a.mtmValue)}</span>
                        </div>
                        <div>
                          <span class="text-text-muted">live </span>
                          <span class="text-text-dim">{fmtPrice(a.livePrice)}</span>
                        </div>
                        <div class="text-right">
                          <span class={totalPnl >= 0 ? "text-pos" : "text-neg"}>{fmtSigned(totalPnl)}</span>
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        </article>

        {/* TF magazine card */}
        <article class="rounded-xl border border-border bg-surface overflow-hidden">
          <div class="grid grid-cols-1 md:grid-cols-[1fr_2fr]">
            <div class="p-6 border-b md:border-b-0 md:border-r border-border-soft" style="background:linear-gradient(180deg,rgba(245,158,11,0.05),transparent)">
              <div class="font-mono text-[10px] uppercase tracking-[0.18em]" style="color:#f59e0b">trend follower · beta</div>
              <h3 class="font-sans text-2xl text-text font-medium mt-2">The breakout hunter</h3>
              <p class="text-text-dim text-[14px] mt-2 leading-relaxed">
                Scans dozens of coins for momentum. Tier slots, conviction-weighted entries.
              </p>
              <div class="mt-5 flex items-baseline gap-3">
                <span class="font-mono text-3xl text-text">{fmtUsd(mockTF.netWorth)}</span>
                <span class={`font-mono text-[15px] ${mockTF.pnlAbs >= 0 ? "text-pos" : "text-neg"}`}>
                  {fmtSigned(mockTF.pnlAbs)}
                </span>
              </div>
              <div class="font-mono text-[11px] text-text-muted mt-1">
                from ${mockTF.initial} · {fmtPct(mockTF.pnlPct)}
              </div>
            </div>
            <div class="p-6">
              <div class="font-mono text-[10px] uppercase tracking-[0.15em] text-text-muted mb-3">tier slots</div>
              <div class="space-y-3">
                {mockTF.assets.map((a) => {
                  const totalPnl = a.realized + a.unrealized;
                  return (
                    <div class="flex items-center gap-3">
                      <span class="inline-block w-2 h-2 rounded-full flex-shrink-0" style={`background:${a.color}`}></span>
                      <span class="font-mono text-[13px] text-text w-12">{a.short}</span>
                      <div class="flex-1 grid grid-cols-3 gap-3 font-mono text-[11px]">
                        <div>
                          <span class="text-text-muted">mtm </span>
                          <span class="text-text">{a.mtmValue > 0 ? fmtUsd(a.mtmValue) : "—"}</span>
                        </div>
                        <div>
                          <span class="text-text-muted">live </span>
                          <span class="text-text-dim">{fmtPrice(a.livePrice)}</span>
                        </div>
                        <div class="text-right">
                          <span class={totalPnl >= 0 ? "text-pos" : "text-neg"}>{fmtSigned(totalPnl)}</span>
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        </article>

      </div>
    </section>

    {/* ============ CHARTS — TOGGLE TAB ============ */}
    <section class="mt-16 reveal">
      <div class="rounded-xl border border-border bg-surface p-6">
        <div class="flex items-baseline justify-between flex-wrap gap-3 mb-5">
          <h2 class="font-sans text-xl text-text font-medium">Performance</h2>
          <div class="flex gap-1 font-mono text-[11px]" id="chart-tabs-c">
            <button data-tab="cumul" class="tab-btn px-3 py-1.5 rounded border border-primary text-primary uppercase tracking-[0.12em]">cumul</button>
            <button data-tab="daily" class="tab-btn px-3 py-1.5 rounded border border-border text-text-dim uppercase tracking-[0.12em]">daily</button>
          </div>
        </div>

        <div class="h-[280px] relative" id="chart-pane-cumul">
          <canvas id="chart-cumul-c"></canvas>
        </div>
        <div class="h-[280px] relative hidden" id="chart-pane-daily">
          <canvas id="chart-daily-c"></canvas>
        </div>

        <div class="mt-3 font-mono text-[10px] text-text-muted" id="chart-legend-c">
          <span><span class="inline-block w-3 h-px bg-pos mr-1 align-middle"></span> realized</span>
          &nbsp;&nbsp;
          <span><span class="inline-block w-3 h-px border-t border-dashed border-pos/60 mr-1 align-middle"></span> mark-to-market</span>
        </div>
      </div>
    </section>

    {/* ============ FEED-STYLE TRADES ============ */}
    <section class="mt-16 reveal">
      <div class="flex items-baseline justify-between flex-wrap gap-3 mb-5">
        <h2 class="font-sans text-xl text-text font-medium">Recent activity</h2>
        <span class="font-mono text-[11px] text-text-muted">last 12 events</span>
      </div>

      <div class="space-y-px bg-border rounded-lg overflow-hidden border border-border">
        {mockTrades.map((t) => (
          <div class="bg-surface flex items-center gap-4 px-4 py-3 hover:bg-surface-hover transition-colors">
            <div class="font-mono text-[10px] text-text-muted w-24 flex-shrink-0">
              {fmtDate(t.ts)} {fmtTime(t.ts)}
            </div>
            <div class={`font-mono text-[10px] uppercase tracking-[0.15em] w-12 flex-shrink-0 ${t.bot === "grid" ? "text-pos" : "text-amber-400"}`}>
              {t.bot}
            </div>
            <div class={`font-mono text-[12px] w-12 flex-shrink-0 ${t.side === "buy" ? "text-text-dim" : "text-text"}`}>
              {t.side}
            </div>
            <div class="font-mono text-[13px] text-text w-16 flex-shrink-0">
              {t.symbol.replace("/USDT", "")}
            </div>
            <div class="font-mono text-[11px] text-text-muted hidden sm:block">
              @ {fmtPrice(t.price)} · {fmtUsd(t.cost)}
            </div>
            <div class={`font-mono text-[12px] ml-auto ${t.pnl == null ? "text-text-muted" : t.pnl >= 0 ? "text-pos" : "text-neg"}`}>
              {t.pnl == null ? "—" : fmtSigned(t.pnl)}
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* ============ EARLIER CEO ENTRIES ============ */}
    <section class="mt-20 reveal">
      <h2 class="font-sans text-xl text-text font-medium mb-6">Earlier from the log</h2>
      <div class="space-y-6">
        {mockCEOLog.archive.map((e) => (
          <article class="border-l border-border-soft pl-5">
            <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted mb-1.5">
              Day {e.dayNumber} · {fmtDate(e.date + "T00:00:00Z")}
            </div>
            <p class="text-text-dim text-[15px] leading-relaxed italic">"{e.text}"</p>
          </article>
        ))}
      </div>
    </section>

  </main>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js" is:inline></script>
  <script>
    const chartData = JSON.parse(document.getElementById("chart-data-c")!.textContent!);
    const Chart = (window as any).Chart;
    Chart.defaults.font.family = "'JetBrains Mono', monospace";
    Chart.defaults.color = "#9aa3b8";

    new Chart((document.getElementById("chart-cumul-c") as HTMLCanvasElement).getContext("2d")!, {
      type: "line",
      data: {
        labels: chartData.cumul.map((p: any) => p.date),
        datasets: [
          { label: "Realized", data: chartData.cumul.map((p: any) => p.realized),
            borderColor: "#86efac", backgroundColor: "rgba(134,239,172,0.07)",
            borderWidth: 2, fill: true, tension: 0.3, pointRadius: 0 },
          { label: "MTM", data: chartData.cumul.map((p: any) => p.mtm),
            borderColor: "rgba(134,239,172,0.55)", borderWidth: 1.5, borderDash: [4, 4],
            fill: false, tension: 0.3, pointRadius: 0 },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: "index", intersect: false },
        plugins: { legend: { display: false } },
        scales: {
          x: { grid: { display: false }, ticks: { font: { size: 9 }, maxTicksLimit: 7 } },
          y: { grid: { color: "rgba(255,255,255,0.04)" }, ticks: { font: { size: 9 },
               callback: function(v: any) { return "$" + v; } } },
        },
      },
    });

    new Chart((document.getElementById("chart-daily-c") as HTMLCanvasElement).getContext("2d")!, {
      type: "bar",
      data: {
        labels: chartData.daily.map((p: any) => p.date),
        datasets: [
          { label: "Grid", data: chartData.daily.map((p: any) => p.grid),
            backgroundColor: "rgba(34,197,94,0.7)", stack: "x" },
          { label: "TF", data: chartData.daily.map((p: any) => p.tf),
            backgroundColor: "rgba(251,146,60,0.7)", stack: "x" },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { stacked: true, grid: { display: false }, ticks: { display: false } },
          y: { stacked: true, grid: { color: "rgba(255,255,255,0.04)" }, ticks: { font: { size: 9 } } },
        },
      },
    });

    /* Tab switcher cumul/daily */
    const tabs = document.querySelectorAll<HTMLButtonElement>("#chart-tabs-c .tab-btn");
    const paneCumul  = document.getElementById("chart-pane-cumul")!;
    const paneDaily  = document.getElementById("chart-pane-daily")!;
    const legend     = document.getElementById("chart-legend-c")!;
    const legendCumul = legend.innerHTML;
    const legendDaily = `
      <span><span class="inline-block w-2 h-2 mr-1 align-middle" style="background:#22c55e"></span> grid</span>
      &nbsp;&nbsp;
      <span><span class="inline-block w-2 h-2 mr-1 align-middle" style="background:#f59e0b"></span> tf</span>`;

    tabs.forEach((btn) => {
      btn.addEventListener("click", () => {
        tabs.forEach((b) => {
          b.classList.remove("border-primary", "text-primary");
          b.classList.add("border-border", "text-text-dim");
        });
        btn.classList.remove("border-border", "text-text-dim");
        btn.classList.add("border-primary", "text-primary");
        const tab = btn.dataset.tab;
        if (tab === "cumul") {
          paneCumul.classList.remove("hidden");
          paneDaily.classList.add("hidden");
          legend.innerHTML = legendCumul;
        } else {
          paneCumul.classList.add("hidden");
          paneDaily.classList.remove("hidden");
          legend.innerHTML = legendDaily;
        }
      });
    });
  </script>

  <script id="chart-data-c" type="application/json" set:html={JSON.stringify({
    cumul: mockCumulative, daily: mockDaily,
  })}></script>

</Layout>
