---
import Layout from "../layouts/Layout.astro";
import {
  mockSnapshot, mockGrid, mockTF, mockCumulative, mockDaily,
  mockTrades, mockCEOLog, fmtUsd, fmtSigned, fmtPct, fmtPrice, fmtTime, fmtDate,
} from "../data/dashboard-mock.ts";

const totalNW   = mockGrid.netWorth + mockTF.netWorth;
const totalInit = mockGrid.initial + mockTF.initial;
const totalPnl  = totalNW - totalInit;
const totalPct  = (totalPnl / totalInit) * 100;
const todayTotal = mockGrid.todayPnl + mockTF.todayPnl;
---

<Layout title="Dashboard — Stato del fondo (proto B)" current="dashboard">

  {/* ============ Variant switcher ============ */}
  <div class="border-b border-border-soft bg-surface/40">
    <div class="mx-auto max-w-6xl px-4 py-2 sm:px-6 flex items-center justify-between gap-4 text-[11px] font-mono">
      <span class="text-text-muted uppercase tracking-[0.18em]">Prototype</span>
      <div class="flex items-center gap-3">
        <a href="/dashboard-a" class="px-2.5 py-1 rounded border border-border text-text-dim hover:text-text">A · Lab notebook</a>
        <a href="/dashboard-b" class="px-2.5 py-1 rounded border border-primary text-primary">B · Stato del fondo</a>
        <a href="/dashboard-c" class="px-2.5 py-1 rounded border border-border text-text-dim hover:text-text">C · Operativo editoriale</a>
      </div>
    </div>
  </div>

  <main class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-20">

    {/* ============ HERO — net worth gigantesco ============ */}
    <section class="reveal text-center sm:text-left">
      <div class="font-mono text-[11px] uppercase tracking-[0.22em] text-text-muted mb-4">
        State of the fund · {mockSnapshot.asOfLabel}
      </div>

      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6">
        <div>
          <div class="font-mono text-[11px] uppercase tracking-[0.18em] text-text-dim mb-2">
            Net worth
          </div>
          <div class="flex items-baseline gap-4 flex-wrap justify-center sm:justify-start">
            <span class="font-mono text-5xl sm:text-7xl text-text tracking-tight" data-count={fmtUsd(totalNW)}>
              {fmtUsd(totalNW)}
            </span>
            <span class={`font-mono text-2xl sm:text-3xl ${totalPnl >= 0 ? "text-pos" : "text-neg"}`}>
              {fmtSigned(totalPnl)}
            </span>
            <span class={`font-mono text-base sm:text-lg ${totalPnl >= 0 ? "text-pos/70" : "text-neg/70"}`}>
              ({fmtPct(totalPct)})
            </span>
          </div>
          <div class="font-mono text-[12px] text-text-muted mt-3">
            from <span class="text-text-dim">{fmtUsd(totalInit, 0)}</span> initial paper-trading capital
            · day <span class="text-text-dim">{mockSnapshot.dayNumber}</span>
          </div>
        </div>

        <div class="text-center sm:text-right">
          <div class="font-mono text-[11px] uppercase tracking-[0.18em] text-text-dim mb-2">
            Today
          </div>
          <div class={`font-mono text-3xl ${todayTotal >= 0 ? "text-pos" : "text-neg"}`}>
            {fmtSigned(todayTotal)}
          </div>
          <div class="font-mono text-[12px] text-text-muted mt-1">
            {mockGrid.todayTrades + mockTF.todayTrades} trades today
          </div>
        </div>
      </div>
    </section>

    {/* ============ GROSSO CUMULATIVE CHART ============ */}
    <section class="mt-16 reveal">
      <div class="rounded-xl border border-border bg-surface p-6 sm:p-8">
        <div class="flex items-baseline justify-between flex-wrap gap-3 mb-5">
          <h2 class="font-mono text-[13px] uppercase tracking-[0.22em] text-text">
            Performance — every day, every trade
          </h2>
          <div class="font-mono text-[11px] text-text-muted">
            v3 · launched 2026-03-30
          </div>
        </div>
        <div class="h-[320px] sm:h-[400px] relative">
          <canvas id="chart-cumul-b"></canvas>
        </div>
        <div class="mt-4 flex items-center gap-5 font-mono text-[11px] text-text-muted">
          <span class="flex items-center gap-2">
            <span class="inline-block w-3 h-px bg-pos"></span> realized — what's banked
          </span>
          <span class="flex items-center gap-2">
            <span class="inline-block w-3 h-px border-t border-dashed border-pos/60"></span> mark-to-market — current value
          </span>
        </div>
      </div>
    </section>

    {/* ============ DUE BOT AFFIANCATI ============ */}
    <section class="mt-20">
      <div class="reveal mb-8">
        <h2 class="font-mono text-sm uppercase tracking-[0.22em] text-text-dim mb-2">
          Two bots at work
        </h2>
        <p class="text-text-dim text-[15px] max-w-2xl">
          Each bot has its own budget, its own job, its own P&amp;L. They don't share capital.
        </p>
      </div>

      <div class="reveal-stagger grid grid-cols-1 md:grid-cols-2 gap-5">

        {/* GRID CARD */}
        <article class="rounded-xl border border-border bg-surface p-6 relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-px" style="background:#22c55e"></div>
          <div class="flex items-baseline justify-between mb-1">
            <h3 class="font-mono text-[15px] text-pos tracking-wide">Grid Bot</h3>
            <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted">
              ${mockGrid.initial} · BTC SOL BONK
            </span>
          </div>
          <div class="flex items-baseline gap-3 mt-3">
            <span class="font-mono text-3xl text-text">{fmtUsd(mockGrid.netWorth)}</span>
            <span class={`font-mono text-base ${mockGrid.pnlAbs >= 0 ? "text-pos" : "text-neg"}`}>
              {fmtSigned(mockGrid.pnlAbs)} ({fmtPct(mockGrid.pnlPct)})
            </span>
          </div>

          <div class="mt-5 grid grid-cols-3 gap-3 font-mono text-[11px]">
            <div>
              <div class="text-text-muted uppercase tracking-[0.12em] text-[9px]">realized</div>
              <div class={`mt-1 ${mockGrid.realized >= 0 ? "text-pos" : "text-neg"}`}>{fmtSigned(mockGrid.realized)}</div>
            </div>
            <div>
              <div class="text-text-muted uppercase tracking-[0.12em] text-[9px]">unrealized</div>
              <div class={`mt-1 ${mockGrid.unrealized >= 0 ? "text-pos" : "text-neg"}`}>{fmtSigned(mockGrid.unrealized)}</div>
            </div>
            <div>
              <div class="text-text-muted uppercase tracking-[0.12em] text-[9px]">trades</div>
              <div class="mt-1 text-text">{mockGrid.trades}</div>
            </div>
          </div>

          {/* Cash bar */}
          <div class="mt-5">
            <div class="flex justify-between font-mono text-[10px] text-text-muted mb-1.5">
              <span>cash · {mockGrid.cashPct.toFixed(0)}%</span>
              <span>{fmtUsd(mockGrid.cashAvail)} / {fmtUsd(mockGrid.initial, 0)}</span>
            </div>
            <div class="h-1.5 bg-border rounded-full overflow-hidden flex gap-px">
              {mockGrid.assets.map((a) => {
                const usedPct = ((a.alloc - a.cashLeft) / mockGrid.initial) * 100;
                return (
                  <div style={`width:${usedPct}%;background:${a.color};opacity:0.7`}></div>
                );
              })}
            </div>
            <div class="mt-2 flex flex-wrap gap-3 font-mono text-[10px] text-text-muted">
              {mockGrid.assets.map((a) => (
                <span class="flex items-center gap-1">
                  <span class="inline-block w-1.5 h-1.5 rounded-full" style={`background:${a.color}`}></span>
                  {a.short} {fmtUsd(a.mtmValue)}
                </span>
              ))}
            </div>
          </div>
        </article>

        {/* TF CARD */}
        <article class="rounded-xl border border-border bg-surface p-6 relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-px" style="background:#f59e0b"></div>
          <div class="flex items-baseline justify-between mb-1">
            <h3 class="font-mono text-[15px] tracking-wide" style="color:#f59e0b">Trend Follower</h3>
            <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted">
              ${mockTF.initial} · 3 tier slots · beta
            </span>
          </div>
          <div class="flex items-baseline gap-3 mt-3">
            <span class="font-mono text-3xl text-text">{fmtUsd(mockTF.netWorth)}</span>
            <span class={`font-mono text-base ${mockTF.pnlAbs >= 0 ? "text-pos" : "text-neg"}`}>
              {fmtSigned(mockTF.pnlAbs)} ({fmtPct(mockTF.pnlPct)})
            </span>
          </div>

          <div class="mt-5 grid grid-cols-3 gap-3 font-mono text-[11px]">
            <div>
              <div class="text-text-muted uppercase tracking-[0.12em] text-[9px]">realized</div>
              <div class={`mt-1 ${mockTF.realized >= 0 ? "text-pos" : "text-neg"}`}>{fmtSigned(mockTF.realized)}</div>
            </div>
            <div>
              <div class="text-text-muted uppercase tracking-[0.12em] text-[9px]">unrealized</div>
              <div class={`mt-1 ${mockTF.unrealized >= 0 ? "text-pos" : "text-neg"}`}>{fmtSigned(mockTF.unrealized)}</div>
            </div>
            <div>
              <div class="text-text-muted uppercase tracking-[0.12em] text-[9px]">trades</div>
              <div class="mt-1 text-text">{mockTF.trades}</div>
            </div>
          </div>

          <div class="mt-5">
            <div class="flex justify-between font-mono text-[10px] text-text-muted mb-1.5">
              <span>cash · {mockTF.cashPct.toFixed(0)}%</span>
              <span>{fmtUsd(mockTF.cashAvail)} / {fmtUsd(mockTF.initial, 0)}</span>
            </div>
            <div class="h-1.5 bg-border rounded-full overflow-hidden flex gap-px">
              {mockTF.assets.map((a) => {
                const usedPct = ((a.alloc - (a.alloc - a.mtmValue)) / mockTF.initial) * 100;
                return (
                  <div style={`width:${usedPct}%;background:${a.color};opacity:0.7`}></div>
                );
              })}
            </div>
            <div class="mt-2 flex flex-wrap gap-3 font-mono text-[10px] text-text-muted">
              {mockTF.assets.map((a) => (
                <span class="flex items-center gap-1">
                  <span class="inline-block w-1.5 h-1.5 rounded-full" style={`background:${a.color}`}></span>
                  {a.short} {a.mtmValue > 0 ? fmtUsd(a.mtmValue) : "—"}
                </span>
              ))}
            </div>
          </div>
        </article>

      </div>
    </section>

    {/* ============ DAILY P&L SECONDARY CHART ============ */}
    <section class="mt-16 reveal">
      <div class="rounded-xl border border-border bg-surface p-6">
        <div class="flex items-baseline justify-between mb-4">
          <h2 class="font-mono text-[13px] uppercase tracking-[0.22em] text-text">
            Daily realized — Grid + TF
          </h2>
          <span class="font-mono text-[11px] text-text-muted">UTC days</span>
        </div>
        <div class="h-[160px] relative">
          <canvas id="chart-daily-b"></canvas>
        </div>
      </div>
    </section>

    {/* ============ CEO LOG come quote elegante ============ */}
    <section class="mt-20 reveal">
      <div class="border-l-2 border-primary pl-6 sm:pl-8">
        <div class="font-mono text-[11px] uppercase tracking-[0.22em] text-text-muted mb-3">
          CEO's log · day {mockCEOLog.today.dayNumber}
        </div>
        <p class="text-text leading-relaxed text-[18px] sm:text-[20px] font-light italic">
          "{mockCEOLog.today.text}"
        </p>
        <div class="mt-4 font-mono text-[11px] text-text-muted">
          — written by {mockCEOLog.today.model} · {fmtDate(mockCEOLog.today.date + "T00:00:00Z")}
        </div>
      </div>

      <details class="mt-6 group">
        <summary class="cursor-pointer font-mono text-[11px] uppercase tracking-[0.18em] text-text-dim hover:text-text inline-flex items-center gap-2">
          <span class="group-open:rotate-90 transition-transform inline-block">▸</span>
          Earlier entries ({mockCEOLog.archive.length})
        </summary>
        <div class="mt-4 space-y-5">
          {mockCEOLog.archive.map((e) => (
            <div class="border-l border-border-soft pl-5">
              <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted mb-1">
                Day {e.dayNumber} · {fmtDate(e.date + "T00:00:00Z")}
              </div>
              <p class="text-text-dim text-[15px] italic">"{e.text}"</p>
            </div>
          ))}
        </div>
      </details>
    </section>

    {/* ============ FULL TRANSPARENCY ============ */}
    <section class="mt-20 reveal">
      <div class="flex items-baseline justify-between flex-wrap gap-3 mb-5">
        <h2 class="font-mono text-sm uppercase tracking-[0.22em] text-text-dim">
          Full transparency
        </h2>
        <span class="font-mono text-[11px] text-text-muted">
          Every trade, public — last 12 below
        </span>
      </div>

      <div class="overflow-x-auto rounded-lg border border-border bg-surface">
        <table class="w-full font-mono text-[12px]">
          <thead class="border-b border-border-soft">
            <tr class="text-text-muted uppercase tracking-[0.12em] text-[10px]">
              <th class="px-4 py-3 text-left">when</th>
              <th class="px-4 py-3 text-left">bot</th>
              <th class="px-4 py-3 text-left">action</th>
              <th class="px-4 py-3 text-left">coin</th>
              <th class="px-4 py-3 text-right">price</th>
              <th class="px-4 py-3 text-right">cost</th>
              <th class="px-4 py-3 text-right">p&amp;l</th>
            </tr>
          </thead>
          <tbody>
            {mockTrades.map((t) => (
              <tr class="border-t border-border-soft">
                <td class="px-4 py-3 text-text-muted">{fmtDate(t.ts)} · {fmtTime(t.ts)}</td>
                <td class="px-4 py-3">
                  <span class={`font-medium ${t.bot === "grid" ? "text-pos" : "text-amber-400"}`}>
                    {t.bot === "grid" ? "Grid" : "TF"}
                  </span>
                </td>
                <td class={`px-4 py-3 ${t.side === "buy" ? "text-text-dim" : "text-text"}`}>{t.side}</td>
                <td class="px-4 py-3 text-text">{t.symbol.replace("/USDT", "")}</td>
                <td class="px-4 py-3 text-right text-text-dim">{fmtPrice(t.price)}</td>
                <td class="px-4 py-3 text-right text-text-dim">{fmtUsd(t.cost)}</td>
                <td class={`px-4 py-3 text-right ${t.pnl == null ? "text-text-muted" : t.pnl >= 0 ? "text-pos" : "text-neg"}`}>
                  {t.pnl == null ? "—" : fmtSigned(t.pnl)}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

  </main>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js" is:inline></script>
  <script>
    const chartData = JSON.parse(document.getElementById("chart-data-b")!.textContent!);
    const Chart = (window as any).Chart;
    Chart.defaults.font.family = "'JetBrains Mono', monospace";
    Chart.defaults.color = "#9aa3b8";

    new Chart((document.getElementById("chart-cumul-b") as HTMLCanvasElement).getContext("2d")!, {
      type: "line",
      data: {
        labels: chartData.cumul.map((p: any) => p.date),
        datasets: [
          { label: "Realized", data: chartData.cumul.map((p: any) => p.realized),
            borderColor: "#86efac", backgroundColor: "rgba(134,239,172,0.08)",
            borderWidth: 2, fill: true, tension: 0.3, pointRadius: 0, pointHoverRadius: 4 },
          { label: "MTM", data: chartData.cumul.map((p: any) => p.mtm),
            borderColor: "rgba(134,239,172,0.55)", borderWidth: 1.5, borderDash: [4, 4],
            fill: false, tension: 0.3, pointRadius: 0 },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: "index", intersect: false },
        plugins: {
          legend: { display: false },
          tooltip: { backgroundColor: "#0f1626", borderColor: "#2a3556", borderWidth: 1,
                     padding: 10, titleFont: { size: 11 }, bodyFont: { size: 11 } },
        },
        scales: {
          x: { grid: { display: false }, ticks: { font: { size: 9 }, maxTicksLimit: 8 } },
          y: { grid: { color: "rgba(255,255,255,0.04)" }, ticks: { font: { size: 9 },
               callback: function(v: any) { return "$" + v; } } },
        },
      },
    });

    new Chart((document.getElementById("chart-daily-b") as HTMLCanvasElement).getContext("2d")!, {
      type: "bar",
      data: {
        labels: chartData.daily.map((p: any) => p.date),
        datasets: [
          { label: "Grid", data: chartData.daily.map((p: any) => p.grid),
            backgroundColor: "rgba(34,197,94,0.7)", stack: "x" },
          { label: "TF", data: chartData.daily.map((p: any) => p.tf),
            backgroundColor: "rgba(251,146,60,0.7)", stack: "x" },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { stacked: true, grid: { display: false }, ticks: { display: false } },
          y: { stacked: true, grid: { color: "rgba(255,255,255,0.04)" }, ticks: { font: { size: 9 } } },
        },
      },
    });
  </script>

  <script id="chart-data-b" type="application/json" set:html={JSON.stringify({
    cumul: mockCumulative, daily: mockDaily,
  })}></script>

</Layout>
