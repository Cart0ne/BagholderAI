---
import Layout from "../layouts/Layout.astro";
import {
  ROADMAP, phaseProgress, totalProgress, groupBySection,
  type Task, type PhaseStatus, type TaskStatus, type Who,
} from "../data/roadmap.ts";

/* /roadmap — porting from /web/roadmap.html. The data lives in
   src/data/roadmap.ts (single source of truth, edit there each session).
   Layout follows the same hero + section pattern as /diary, /dashboard,
   /blueprint:
     - Hero: max-w-4xl, h1 28→40px responsive, mono meta-strip
     - Main: max-w-4xl, sections separated by <hr>
     - Phase cards: collapsible <details> per phase (active phase open by
       default), <summary> shows title + status badge + progress
     - Phase 8 backlog: grouped by section markers (Phase 1 sub, Phase 2
       sub, etc.) using the same <details> pattern.
   Pure Astro static markup + native <details> for expand/collapse — no JS. */

const stats = totalProgress(ROADMAP.phases);
const remaining = stats.total - stats.done;
const lastUpdatedLabel = (() => {
  const d = new Date(ROADMAP.lastUpdated);
  return d.toLocaleDateString("en-US", {
    year: "numeric", month: "long", day: "numeric",
  });
})();

/* Map phase status → visual badge. Reuses tokens from blueprint and
   diary so the language stays consistent across pages. */
function phaseBadge(s: PhaseStatus) {
  if (s === "done") {
    return {
      label: "complete",
      cls: "border-pos/30 text-pos bg-pos/10",
    };
  }
  if (s === "active") {
    return {
      label: "● active",
      cls: "border-neu/40 text-neu bg-neu/10",
    };
  }
  return {
    label: "planned",
    cls: "border-border-soft text-text-muted bg-bg",
  };
}

/* Map task status → a little "sticker chip" icon: glyph inside a rounded
   badge. done = solid sage + white ✓; active = pulsing teal ring; todo =
   empty dashed sand ring; killed = muted ✕. Keeps the page playful (S95b). */
function taskIcon(s: TaskStatus): { ch: string; badge: string } {
  if (s === "done")   return { ch: "✓", badge: "border-transparent bg-pos text-white" };
  if (s === "active") return { ch: "◐", badge: "border-transparent bg-neu text-white animate-pulse" };
  if (s === "killed") return { ch: "✕", badge: "border-border-soft bg-bg text-text-muted" };
  return                       { ch: "", badge: "border-dashed border-sand bg-sand-soft text-sand" };  /* todo */
}

/* Color the WHO chip differently per actor — keeps quick scan possible.
   Same family as the dashboard managed_by chips. */
function whoChip(w: Who): string {
  if (w === "AI")   return "border-neu/40 text-neu bg-neu/10";
  if (w === "MAX")  return "border-warn/40 text-warn bg-warn/10";
  return "border-pos/30 text-pos bg-pos/10";  /* BOTH */
}
---

<Layout
  title="Roadmap — From One Bot to Five AI Brains | BagHolderAI"
  description="400+ tasks tracked live: from one trading bot to five autonomous AI modules — every feature shipped, every bug found, built by a non-coder with Claude Code."
  current="roadmap"
>

  {/* ============================================================ HERO */}
  <section class="mx-auto max-w-4xl px-4 pt-10 pb-6 sm:px-6 sm:pt-14 sm:pb-8">
    <h1 class="font-display text-[34px] font-extrabold leading-[1.04] tracking-[-0.02em]
               text-text sm:text-[42px]">
      What we're <span class="text-primary">building</span>.
    </h1>

    <p class="mt-3 max-w-2xl text-[14.5px] leading-[1.55] text-text-dim sm:text-[15px]">
      Every task by phase. What's done, what's active, what's planned —
      with the messy backlog included. Updated each session.
      The transparency is the product.
      Built by a non-coder directing Claude Code, session by session.
    </p>

    <div class="mt-5 flex flex-wrap items-center gap-3 font-mono text-[10.5px]
                uppercase tracking-[0.16em] text-text-muted">
      <span class="inline-flex items-center gap-1.5">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary"></span>
        {ROADMAP.version.toLowerCase()}
      </span>
      <span class="text-border">·</span>
      <span>last updated {lastUpdatedLabel}</span>
    </div>
  </section>

  {/* ============================================================ MAIN */}
  <main class="roadmap-page mx-auto max-w-4xl px-4 pb-24 sm:px-6">

    {/* ============ STATS BAR ============ */}
    <section class="reveal">
      <dl class="grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="rounded-2xl border border-border bg-surface px-4 py-4
                    shadow-sticker-sm">
          <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
            completed
          </dt>
          <dd class="mt-1 font-display text-[28px] sm:text-[32px] font-extrabold
                     leading-none text-pos tabular-nums">
            {stats.done}
          </dd>
        </div>
        <div class="rounded-2xl border border-border bg-surface px-4 py-4
                    shadow-sticker-sm">
          <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
            remaining
          </dt>
          <dd class="mt-1 font-display text-[28px] sm:text-[32px] font-extrabold
                     leading-none text-sand tabular-nums">
            {remaining}
          </dd>
        </div>
        <div class="rounded-2xl border border-border bg-surface px-4 py-4
                    shadow-sticker-sm">
          <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
            total tasks
          </dt>
          <dd class="mt-1 font-display text-[28px] sm:text-[32px] font-extrabold
                     leading-none text-text tabular-nums">
            {stats.total}
          </dd>
        </div>
        <div class="rounded-2xl border border-border bg-surface px-4 py-4
                    shadow-sticker-sm">
          <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
            progress
          </dt>
          <dd class="mt-1 font-display text-[28px] sm:text-[32px] font-extrabold
                     leading-none text-primary tabular-nums">
            {stats.percent}%
          </dd>
        </div>
      </dl>
    </section>

    {/* ============ PHASES ============
         All collapsed by default — chosen during Session 54 to avoid the
         207-task Phase 8 dominating the viewport at first paint. Tighter
         vertical rhythm (border-b separators, no <hr> + mt-12) modeled on
         /diary entry list. Phase 8 subsections show indent so the
         hierarchy is readable. */}
    <section class="mt-10 space-y-3">
    {ROADMAP.phases.map((phase) => {
      const { done, total } = phaseProgress(phase);
      const badge = phaseBadge(phase.status);
      const sections = groupBySection(phase.tasks);
      const hasSections = sections.length > 0;

      /* Phase 9 (Validation) opens by default — it's the living
         milestone the visitor should see first. Phase 8 (Backlog)
         stays collapsed but is the second-most-likely click. All
         other phases stay collapsed so the page is scannable at
         first paint. */
      const phaseOpen = phase.id === 9;

      return (
        <details class="group rounded-2xl border border-border bg-surface
                        shadow-sticker-sm transition hover:shadow-sticker overflow-hidden"
                 open={phaseOpen}>
          <summary class="cursor-pointer list-none
                          flex items-baseline justify-between gap-3
                          flex-wrap px-4 py-4
                          hover:bg-surface-hover transition-colors">
            <div class="flex items-baseline gap-3 flex-wrap">
              <span class="font-mono text-[10px] uppercase tracking-[0.18em]
                           text-text-muted">
                Phase {phase.id}
              </span>
              <h2 class="font-display text-[15px] font-extrabold tracking-[-0.01em]
                         text-text">
                {phase.title}
              </h2>
              <span class="font-mono text-[11px] text-text-muted tabular-nums">
                {done}/{total}
              </span>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              {phase.id === 9 && (
                <span class="rounded-full border border-sand/40
                             bg-sand-soft px-2.5 py-0.5
                             font-mono text-[9px] uppercase tracking-[0.16em]
                             text-sand">
                  ● Living milestone
                </span>
              )}
              <span class={`rounded-full border px-2.5 py-0.5
                            font-mono text-[9px] uppercase tracking-[0.16em]
                            ${badge.cls}`}>
                {badge.label}
              </span>
            </div>
          </summary>

          <div class="px-3 pb-4">
            <p class="mt-1 mb-4 text-[13.5px] leading-[1.65] text-text-dim">
              {phase.description}
              <span class="ml-2 font-mono text-[11px] text-text-muted">
                · {phase.timeframe}
              </span>
            </p>

            {hasSections ? (
                <div class="space-y-3 pl-4 sm:pl-6
                            border-l-2 border-border-soft">
                  {sections.map((g) => {
                    const subDone  = g.tasks.filter(t => t.status === "done").length;
                    const subTotal = g.tasks.length;
                    return (
                      <details class="rounded-xl border border-border-soft
                                      bg-bg/50 overflow-hidden group/sub">
                        <summary class="cursor-pointer list-none px-4 py-2.5
                                        flex items-baseline justify-between gap-3
                                        hover:bg-bg transition-colors">
                          <span class="font-mono text-[11px] uppercase
                                       tracking-[0.14em] text-text-dim">
                            {g.title}
                          </span>
                          <span class="font-mono text-[10px] text-text-muted
                                       tabular-nums shrink-0">
                            {subDone}/{subTotal}
                          </span>
                        </summary>
                        {subTotal === 0 ? (
                          <div class="px-4 py-3 font-mono text-[11px] text-text-muted italic">
                            No extras yet.
                          </div>
                        ) : (
                          <ul class="divide-y divide-border-soft">
                            {g.tasks.map((t) => {
                              const ic = taskIcon(t.status);
                              return (
                                <li class="px-4 py-2.5 flex items-baseline gap-3">
                                  <span class={`inline-flex h-[18px] w-[18px] shrink-0 mt-0.5
                                                items-center justify-center rounded-full border
                                                font-mono text-[10px] font-bold leading-none ${ic.badge}`}>
                                    {ic.ch}
                                  </span>
                                  <div class="flex-1 min-w-0">
                                    <div class={`text-[13.5px] leading-[1.55]
                                                 ${t.status === "done" ? "text-text-dim" : "text-text"}`}>
                                      {t.text}
                                    </div>
                                    {t.comment && (
                                      <div class="mt-1 text-[12.5px] leading-[1.6] text-text-muted italic">
                                        {t.comment}
                                      </div>
                                    )}
                                  </div>
                                  <span class={`shrink-0 rounded-full border px-2 py-0.5
                                                font-mono text-[9px] uppercase tracking-[0.14em]
                                                ${whoChip(t.who)}`}>
                                    {t.who.toLowerCase()}
                                  </span>
                                </li>
                              );
                            })}
                          </ul>
                        )}
                      </details>
                    );
                  })}
                </div>
              ) : (
                <ul class="divide-y divide-border-soft rounded-xl
                           border border-border-soft bg-bg/40 overflow-hidden">
                  {phase.tasks.filter((t): t is Task => "text" in t).map((t) => {
                    const ic = taskIcon(t.status);
                    return (
                      <li class="px-4 py-2.5 flex items-baseline gap-3">
                        <span class={`inline-flex h-[18px] w-[18px] shrink-0 mt-0.5
                                      items-center justify-center rounded-full border
                                      font-mono text-[10px] font-bold leading-none ${ic.badge}`}>
                          {ic.ch}
                        </span>
                        <div class="flex-1 min-w-0">
                          <div class={`text-[13.5px] leading-[1.55]
                                       ${t.status === "done" ? "text-text-dim" : "text-text"}`}>
                            {t.text}
                          </div>
                          {t.comment && (
                            <div class="mt-1 text-[12.5px] leading-[1.6] text-text-muted italic">
                              {t.comment}
                            </div>
                          )}
                        </div>
                        <span class={`shrink-0 rounded-full border px-2 py-0.5
                                      font-mono text-[9px] uppercase tracking-[0.14em]
                                      ${whoChip(t.who)}`}>
                          {t.who.toLowerCase()}
                        </span>
                      </li>
                    );
                  })}
                </ul>
              )}
          </div>
        </details>
      );
    })}
    </section>

    {/* ============ VERSION TAG ============ */}
    <div class="mt-16 border-t border-border-soft pt-4
                font-mono text-[11px] text-text-muted">
      {ROADMAP.version} · last updated {lastUpdatedLabel}
    </div>

  </main>

  {/* Style for native <summary> arrow — replace the default disclosure
      triangle with our own caret that rotates on open. Scoped to the
      roadmap section so it doesn't bleed into the SiteHeader mobile menu
      (which is also a <details>). */}
  <style is:inline>
    .roadmap-page details > summary::-webkit-details-marker { display: none; }
    .roadmap-page details > summary { position: relative; padding-left: 22px; }
    .roadmap-page details > summary::before {
      content: "▸";
      position: absolute;
      left: 6px;
      top: 50%;
      font-size: 10px;
      line-height: 1;
      color: rgba(40,48,38,0.4);
      transition: transform 0.15s ease;
      transform-origin: 50% 50%;
      transform: translateY(-50%);
    }
    .roadmap-page details[open] > summary::before {
      transform: translateY(-50%) rotate(90deg);
    }
  </style>
</Layout>
