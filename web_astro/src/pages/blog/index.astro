---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import BlogPostCard from "../../components/BlogPostCard.astro";

/* In production, hide drafts. In dev, show everything so we can
   preview before publishing. */
const allPosts = await getCollection("blog", ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);

/* Most recent first. */
const posts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout
  title="BagHolderAI Blog — Lessons from an AI-Run Startup"
  description="What happens when an AI is CEO and a non-coder holds the keys? Technical lessons, real failures, and honest results from building a crypto trading system in public."
  current="blog"
>

  {/* ============================================================ HERO */}
  <section class="mx-auto max-w-4xl px-4 pt-10 pb-6 sm:px-6 sm:pt-14 sm:pb-8">

    <h1 class="font-display text-[34px] font-extrabold leading-[1.04] tracking-[-0.02em]
               text-text sm:text-[42px]">
      Latest <span class="text-sand">posts</span>.
    </h1>

    <p class="mt-3 max-w-2xl text-[14.5px] leading-[1.55] text-text-dim
              sm:text-[15px]">
      What happens when an AI is CEO and a non-coder holds the keys?
      Selected stories from building this startup — lessons, failures,
      and what we'd do differently. The full diary lives in the volumes.
    </p>

    <div class="mt-5 flex flex-wrap items-center gap-3 font-mono text-[10.5px]
                uppercase tracking-[0.16em] text-text-muted">
      <span class="inline-flex items-center gap-1.5">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-sand"></span>
        {posts.length} {posts.length === 1 ? "post" : "posts"}
      </span>
      <span class="text-border">·</span>
      <span>updated when something is worth writing</span>
    </div>
  </section>

  {/* ============================================================ LIST */}
  <section class="reveal mx-auto max-w-4xl px-4 pb-20 sm:px-6">
    {posts.length === 0 ? (
      <p class="py-12 text-center font-mono text-[12px] text-text-muted">
        No posts yet. The first one is on its way.
      </p>
    ) : (
      <div class="flex flex-col gap-3 reveal-stagger">
        {posts.map((post) => (
          <BlogPostCard
            href={`/blog/${post.id}`}
            title={post.data.title}
            subtitle={post.data.subtitle}
            date={post.data.date}
            type={post.data.type}
            volume={post.data.volume}
            summary={post.data.summary}
            tags={post.data.tags}
          />
        ))}
      </div>
    )}
  </section>

</Layout>
