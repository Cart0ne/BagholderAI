---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import BlogCTA from "../../components/BlogCTA.astro";

/* Static paths: one route per non-draft post in production, all
   posts in dev. The `slug` rest param maps to the entry id (which
   for `glob` loader is the file path without extension). */
export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  );
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.date.toLocaleDateString("en-GB", {
  day: "2-digit",
  month: "long",
  year: "numeric",
});

const typePill =
  post.data.type === "highlight"
    ? post.data.volume
      ? `from Volume ${post.data.volume}`
      : "highlight"
    : "lesson";

/* Byline — convenzione a 2 voci (vedi content.config.ts → author).
   Mostrato in cima alla riga meta. Assente se il frontmatter non
   specifica `author`, così i post non ancora migrati restano invariati.
   L'attribuzione estesa (es. "scritto in italiano, tradotto") vive nella
   firma in fondo al post, non qui. */
const bylineMap = {
  ceo: "By Claude, AI CEO",
  max: "By Max, co-founder",
  both: "By Max & Claude",
};
const byline = post.data.author ? bylineMap[post.data.author] : null;

/* Article schema for rich snippets in search results. ISO date is
   required by schema.org/Article — `post.data.date` is a Date from
   the content collection (z.coerce.date), .toISOString() gives the
   canonical "YYYY-MM-DDTHH:mm:ss.sssZ" form. */
const articleUrl = new URL(`/blog/${post.id}/`, "https://bagholderai.lol").toString();
const articleEntity = {
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.summary,
  "datePublished": post.data.date.toISOString(),
  "url": articleUrl,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": articleUrl,
  },
  "author": {
    "@type": "Organization",
    "name": "BagHolderAI",
    "url": "https://bagholderai.lol",
  },
  "publisher": {
    "@type": "Organization",
    "name": "BagHolderAI",
    "url": "https://bagholderai.lol",
    "logo": {
      "@type": "ImageObject",
      "url": "https://bagholderai.lol/og-image.jpg",
    },
  },
  "image": "https://bagholderai.lol/og-image.jpg",
  ...(post.data.tags.length > 0 && { "keywords": post.data.tags.join(", ") }),
};

/* FAQPage schema (GEO + rich result). Generato solo se il frontmatter
   espone `faq`. Si affianca all'Article in un @graph: un solo
   <script type="application/ld+json">, due entità. Senza FAQ l'output
   resta identico al fix S84 (Article flat con @context). Aggiunto S95a. */
const faqEntity =
  post.data.faq && post.data.faq.length > 0
    ? {
        "@type": "FAQPage",
        "mainEntity": post.data.faq.map((item) => ({
          "@type": "Question",
          "name": item.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": item.answer,
          },
        })),
      }
    : null;

const jsonLd = faqEntity
  ? { "@context": "https://schema.org", "@graph": [articleEntity, faqEntity] }
  : { "@context": "https://schema.org", ...articleEntity };
---

<Layout
  title={`${post.data.title} — BagHolderAI`}
  description={post.data.summary}
  current="blog"
  jsonLd={jsonLd}
>

  {/* ========================================================== HEADER */}
  <section class="mx-auto max-w-4xl px-4 pt-10 pb-6 sm:px-6 sm:pt-14 sm:pb-8">

    <a
      href="/blog"
      class="inline-flex items-center gap-1 font-mono text-[11px] uppercase
             tracking-[0.16em] text-text-muted hover:text-text transition-colors"
    >
      ← Back to blog
    </a>

    <h1 class="mt-4 font-display text-[30px] font-extrabold leading-[1.06] tracking-[-0.02em]
               text-text sm:text-[38px] md:text-[44px]">
      {post.data.title}
    </h1>

    {post.data.subtitle && (
      <p class="mt-3 max-w-2xl text-[16px] leading-[1.55] text-text-dim italic
                sm:text-[17px]">
        {post.data.subtitle}
      </p>
    )}

    <div class="mt-5 flex flex-wrap items-center gap-2.5 font-mono text-[10.5px]
                uppercase tracking-[0.16em] text-text-muted">
      {byline && (
        <>
          <span class="normal-case tracking-normal text-[11px] text-text-dim">
            {byline}
          </span>
          <span class="text-border">·</span>
        </>
      )}
      <span>{formattedDate}</span>
      <span class="text-border">·</span>
      <span
        class:list={[
          "rounded-full border px-2 py-0.5 text-[9px]",
          post.data.type === "highlight"
            ? "border-pos/30 text-pos bg-pos/10"
            : "border-sand/30 text-sand bg-sand-soft",
        ]}
      >
        {typePill}
      </span>
      {post.data.tags.length > 0 && post.data.tags.map((t) => (
        <span class="rounded-md border border-border-soft bg-bg
                     px-1.5 py-0.5 text-[9px] normal-case tracking-normal
                     text-text-muted">
          #{t}
        </span>
      ))}
    </div>
  </section>

  {/* ========================================================== BODY */}
  {/* The article body is a white "reading sheet" so the long-form prose
      never floats on the page sage (REDESIGN_PATTERNS §15). */}
  <div class="mx-auto max-w-4xl px-4 pb-6 sm:px-6">
    <article class="prose-blog rounded-2xl border border-border bg-surface
                    px-5 py-7 shadow-sticker-sm sm:px-9 sm:py-9">
      <Content />
    </article>
  </div>

  {/* ========================================================== CTA */}
  <section class="mx-auto max-w-4xl px-4 pb-20 sm:px-6">
    <BlogCTA volume={post.data.volume} />
  </section>

</Layout>

<style is:global>
  /* Blog body typography — scoped under .prose-blog wrapper.
     We don't pull @tailwindcss/typography (no new deps); instead we
     style markdown elements here to match the rest of the site. */
  .prose-blog {
    color: var(--color-text-dim);
    font-size: 15px;
    line-height: 1.75;
  }
  .prose-blog h2 {
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-display);
    font-size: 23px;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.015em;
  }
  .prose-blog h3 {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    font-size: 18px;
    font-weight: 600;
    color: var(--color-text);
  }
  .prose-blog p {
    margin-bottom: 1rem;
    text-align: justify;
    -webkit-hyphens: auto;
    hyphens: auto;
  }
  .prose-blog blockquote {
    border-left: 3px solid var(--color-pos);
    padding-left: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-text-dim);
  }
  .prose-blog ul,
  .prose-blog ol {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .prose-blog ul li {
    list-style-type: disc;
    margin-bottom: 0.25rem;
  }
  .prose-blog ol li {
    list-style-type: decimal;
    margin-bottom: 0.25rem;
  }
  .prose-blog a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-blog a:hover {
    color: var(--color-text);
  }
  .prose-blog img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5rem 0;
  }
  .prose-blog code {
    background: var(--color-panel);
    border: 1px solid var(--color-border-soft);
    border-radius: 4px;
    padding: 0.1rem 0.35rem;
    font-size: 0.85em;
    color: var(--color-text);
    font-family: var(--font-mono);
  }
  .prose-blog pre {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 13px;
    line-height: 1.55;
  }
  .prose-blog pre code {
    background: transparent;
    border: none;
    padding: 0;
  }
  .prose-blog hr {
    border-color: var(--color-border-soft);
    margin: 2rem 0;
  }
  .prose-blog strong {
    color: var(--color-text);
    font-weight: 600;
  }
</style>
