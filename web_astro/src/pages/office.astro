---
import Layout from "../layouts/Layout.astro";
import LabRoom from "../components/office/LabRoom.jsx";

/* The AI Lab — /office (the "company HQ" animated scene).
   BUILT, NOT LINKED YET: noindex + excluded from nav/sitemap (same private
   pattern as /income). Reachable only by direct URL while we figure out how
   to structure the rest of the page (Max). To publish: drop noindex, add it
   to the sitemap filter + nav, and decide the surrounding sections.

   The scene is a React island (LabRoom), ported from the design handoff
   (config/bagholderAI dashboard.zip). Its data slots — board net worth /
   per-coin P&L% / sparkline, Sentinel risk, Grid realized — are wired to the
   same canonical live data as /home and /dashboard. Fixed 1040×630 canvas,
   scaled to fit the container by the ResizeObserver script below. */
---

<Layout
  title="While I Sleep, My AI Company Works — BagHolderAI"
  description="The BagHolderAI company HQ, alive: five AI agents at their desks around Bag the CEO, briefing each other, reading the news, watching risk — while the portfolio runs itself."
  current=""
  noindex={true}
>
  {/* ============================================================ HERO */}
  <section class="relative mx-auto max-w-4xl px-4 pt-10 pb-2 sm:px-6 sm:pt-12">
    {/* Work-in-progress sticker — /office is a private scaffold, not launched
        yet (no nav link, noindex). Retire when the page goes live. */}
    <div class="absolute right-3 top-7 z-10 rotate-[8deg] select-none rounded-full
                border border-warn/50 bg-warn-soft px-3.5 py-1.5 shadow-sticker
                sm:right-6 sm:top-9">
      <span class="whitespace-nowrap font-mono text-[10px] font-bold uppercase
                   tracking-[0.12em] text-warn">🚧 Work in progress</span>
    </div>

    <div class="inline-flex items-center gap-2 rounded-full border border-border
                bg-surface px-3 py-1 font-mono text-[10.5px] font-bold uppercase
                tracking-[0.16em] text-text-muted shadow-sticker-sm">
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary"></span>
      <span>The office</span>
      <span class="text-border">·</span>
      <span>5 agents · 1 CEO</span>
    </div>

    <h1 class="mt-4 font-display text-[32px] font-extrabold leading-[1.05]
               tracking-[-0.02em] text-text sm:text-[44px]">
      While I sleep, my AI <span class="text-primary">company</span> works.
    </h1>
  </section>

  {/* ===================================================== THE SCENE
      Fixed 1040×630 illustration, scaled to the container width by the
      script below (never upscaled past native). Sits on the page sage,
      its faded edges melt into it. */}
  <section class="mx-auto max-w-[1080px] px-4 pb-16 sm:px-6">
    <div id="office-stage" class="office-stage">
      <LabRoom client:visible />
    </div>

    <p class="mt-6 text-center text-[15px] leading-[1.6] text-text-dim">
      Five specialized AI agents. One mission: grow the capital. This is the
      company HQ — Grid, TrendFollower, NewsKeeper, Sentinel and Sherpa at
      their desks around <strong class="font-semibold text-text">Bag</strong>,
      the CEO. The board, the risk monitor and the realized P&amp;L are
      <strong class="font-semibold text-text">live</strong>; everything else is
      the team doing its thing.
    </p>

    <p class="mt-4 text-center font-mono text-[10.5px] uppercase tracking-[0.14em]
              text-text-muted">
      Click the board → dashboard · click Bag → how we work · agents are placeholders
    </p>
  </section>
</Layout>

<style>
  /* The scene is a fixed-size canvas; we scale it to fit the column. */
  .office-stage {
    width: 100%;
    overflow: hidden;
  }
  .office-stage :global(.office-scene) {
    transform-origin: top left;
  }
</style>

<script>
  /* Scale the fixed 1040×630 scene to the container width (cap at 1× so it
     never blurs past native), and keep the wrapper height in sync. Re-fits on
     resize and once the React island hydrates (its DOM can swap in late). */
  const NATIVE_W = 1040, NATIVE_H = 630;
  const stage = document.getElementById("office-stage");

  function fit() {
    if (!stage) return;
    const inner = stage.querySelector(".office-scene");
    if (!inner) return;
    const s = Math.min(1, stage.clientWidth / NATIVE_W);
    inner.style.transform = `scale(${s})`;
    stage.style.height = NATIVE_H * s + "px";
  }

  if (stage) {
    fit();
    new ResizeObserver(fit).observe(stage);
    /* The island is server-rendered then hydrated on visibility — re-fit when
       its child DOM appears/changes. childList only, so our own style writes
       don't re-trigger it. */
    new MutationObserver(fit).observe(stage, { childList: true, subtree: true });
  }
</script>
