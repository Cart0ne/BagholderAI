---
import Layout from "../layouts/Layout.astro";
import TestnetBanner from "../components/TestnetBanner.astro";
import CleanSlateSticker from "../components/CleanSlateSticker.astro";
import BotMascot from "../components/BotMascot.astro";
import SentinelMascot   from "../components/SentinelMascot.astro";
import NewsKeeperMascot from "../components/NewsKeeperMascot.astro";
import SherpaMascotV2   from "../components/SherpaMascotV2.astro";
import MixerSVG         from "../components/MixerSVG.astro";
import RadarSVG         from "../components/RadarSVG.astro";
import {
  mockSnapshot, mockGrid, mockTF,
  mockTrades, mockCEOLog, fmtUsd, fmtSigned, fmtPct, fmtPrice, fmtTime, fmtDate,
} from "../data/dashboard-mock.ts";

const totalNW    = mockGrid.netWorth + mockTF.netWorth;
const totalInit  = mockGrid.initial + mockTF.initial;
const totalPnl   = totalNW - totalInit;
const totalPct   = (totalPnl / totalInit) * 100;

/* Hero NET WORTH card — $600 basis = Grid $500 + TF $100, aggregate of both
   funds (S97b, supersedes the S72 Grid-only $500 hero). TF is idle in the
   current testnet cycle (0 trades) so it adds $100 cash and $0 P&L: the $
   P&L is identical to Grid-only, only the % denominator becomes 600. Numbers
   stay self-consistent (netWorth − P&L = started). The live JS hero in
   dashboard-live.ts mirrors this same 600 basis. */
const heroInit = totalInit;
const heroNW   = totalNW;
const heroPnl  = totalPnl;
const heroPct  = totalPct;

/* ====== "Today" snapshot — fotografia del giorno ====== */
const todayPnl       = mockGrid.todayPnl + mockTF.todayPnl;
const todayTrades    = mockGrid.todayTrades + mockTF.todayTrades;
const todayBuys      = mockGrid.todayBuys + mockTF.todayBuys;
const todaySells     = mockGrid.todaySells + mockTF.todaySells;
const todayAllocated = mockGrid.todayAllocated + mockTF.todayAllocated;

/* Sottotitoli statici per ora — in futuro popolati da Haiku ogni sera. */
const gridSubtitle = "The cash machine";
const tfSubtitle   = "The breakout hunter";

---

<Layout
  title="Live Dashboard — AI-Managed Crypto Trading | BagHolderAI"
  description="Five AI modules manage crypto trades on Binance Testnet — monitored by one human. Live P&L, positions, regime detection, and parameter tuning. No black box."
  current="dashboard"
>

  <TestnetBanner />

  {/* ============================================================ HERO (pattern /diary) */}
  <section class="mx-auto max-w-4xl px-4 pt-10 pb-6 sm:px-6 sm:pt-14 sm:pb-8">

    <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">

      {/* left — title + lede + meta */}
      <div class="min-w-0">
        <h1 class="font-display text-[34px] font-extrabold leading-[1.04] tracking-[-0.02em]
                   text-text sm:text-[42px]">
          Lab <span class="text-primary">notebook</span>.
        </h1>

        <p class="mt-3 font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-text-muted">
          Five AI modules. One human supervisor. Everything visible.
        </p>

        <p class="mt-3 max-w-2xl text-[14.5px] leading-[1.55] text-text-dim sm:text-[15px]">
          Two trade, two advise. Capital at risk:
          <span class="font-mono text-text">$500 Grid + $100 TF (Tier 1-2)</span>
          <span class="font-mono text-text-muted">(Sentinel/Sherpa advise live, no capital of their own)</span>.
          <span class="text-pos">Fresh start · Jun 5, 2026</span> — testnet was reset, counters start fresh (Day 1 = first trade).
        </p>

        <div class="mt-5 flex flex-wrap items-center gap-3 font-mono text-[10.5px]
                    uppercase tracking-[0.16em] text-text-muted">
          <span class="inline-flex items-center gap-1.5">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary"></span>
            live
          </span>
          <span class="text-border">·</span>
          <span>v3 · launched 2026-03-30</span>
        </div>
      </div>

      {/* right — NET WORTH card ($600 basis = Grid+TF; top border = P&L sign) */}
      <div id="hero-nw-card"
           class={`relative shrink-0 self-start rounded-2xl border border-border border-t-4 bg-surface
                   px-5 py-4 shadow-sticker sm:min-w-[208px] sm:text-right
                   ${heroPnl >= 0 ? "border-t-pos" : "border-t-neg"}`}>
        <CleanSlateSticker class="absolute -top-5 -left-3 z-20" />
        <div class="font-mono text-[10px] font-bold uppercase tracking-[0.18em] text-text-muted">
          Net worth
        </div>
        <div id="hero-nw"
             class="mt-1 font-display text-[36px] font-extrabold leading-none tabular-nums text-text">
          {fmtUsd(heroNW)}
        </div>
        <div id="hero-pnl"
             class={`mt-1.5 font-mono text-[12px] font-semibold tabular-nums
                     ${heroPnl >= 0 ? "text-pos" : "text-neg"}`}>
          {fmtSigned(heroPnl)} · {fmtPct(heroPct)}
        </div>
        <div class="mt-2.5 font-mono text-[9px] uppercase tracking-[0.14em] text-text-muted">
          started {fmtUsd(heroInit)} · day <span id="hero-day">{mockSnapshot.dayNumber}</span>
        </div>
      </div>
    </div>
  </section>

  {/* ============================================================ MAIN */}
  <main class="mx-auto max-w-4xl px-4 pb-24 sm:px-6">

    {/* ============ TODAY SNAPSHOT — fotografia del giorno ============ */}
    <section class="reveal">
      <div class="mb-3 flex items-baseline gap-3">
        <h2 class="font-display text-[20px] sm:text-[22px] font-extrabold tracking-[-0.01em] text-text">
          Today
        </h2>
        <span id="today-date"
              class="font-mono text-[12px] uppercase tracking-[0.16em] text-text-muted">
          {fmtDate(mockSnapshot.asOfIso)}
        </span>
      </div>

      {/* Brief 88d Task 2 — "why no trades" transparency banner. Server-
          rendered hidden; regime-banner.ts unhides it only when there are
          0 trades today AND the slow-loop regime is fear/extreme_fear, then
          fills in last-trade date + regime label. Disappears on its own
          once the bot trades again or the regime shifts. No sensitive
          figures — only last trade and current regime. */}
      <div id="regime-watch-banner"
           class="hidden mb-3 flex flex-wrap items-center gap-x-2 gap-y-1
                  rounded-xl border border-border bg-panel
                  px-3.5 py-2 font-mono text-[11.5px] text-text-dim">
        <span aria-hidden="true">🔍</span>
        <span class="text-text">Watching market</span>
        <span class="text-border">·</span>
        <span>Last trade <span id="regime-watch-lasttrade">—</span></span>
        <span class="text-border">·</span>
        <span id="regime-watch-regime" class="text-neu">Fear regime active</span>
      </div>

      {/* Same font hierarchy as the home live-snapshot panel:
          label 10px uppercase + value 20px semibold. */}
      <dl class="rounded-2xl border border-border bg-surface shadow-sticker-sm
                 grid grid-cols-2 sm:grid-cols-5 divide-x divide-border-soft">
        <div class="px-4 py-3.5">
          <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
            P&amp;L
          </dt>
          <dd id="today-pnl"
              class={`font-display text-[24px] font-extrabold tabular-nums mt-0.5
                      ${todayPnl >= 0 ? "text-pos" : "text-neg"}`}>
            {fmtSigned(todayPnl)}
          </dd>
        </div>
        <div class="px-4 py-3.5">
          <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
            trades
          </dt>
          <dd id="today-trades"
              class="font-display text-[24px] font-extrabold text-text tabular-nums mt-0.5">
            {todayTrades}
          </dd>
        </div>
        <div class="px-4 py-3.5">
          <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
            buys
          </dt>
          <dd id="today-buys"
              class="font-display text-[24px] font-extrabold text-text-dim tabular-nums mt-0.5">
            {todayBuys}
          </dd>
        </div>
        <div class="px-4 py-3.5">
          <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
            sells
          </dt>
          <dd id="today-sells"
              class="font-display text-[24px] font-extrabold text-text-dim tabular-nums mt-0.5">
            {todaySells}
          </dd>
        </div>
        <div class="px-4 py-3.5">
          <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
            allocated
          </dt>
          <dd id="today-allocated"
              class="font-display text-[24px] font-extrabold text-text tabular-nums mt-0.5">
            {fmtUsd(todayAllocated)}
          </dd>
        </div>
      </dl>
    </section>

    {/* ============ 1 — INSTRUMENTS ============ */}
    <hr class="mt-12 border-t border-border-soft" />
    <section class="mt-8">
      <h2 class="reveal font-display text-[20px] font-extrabold tracking-[-0.01em] text-text mb-7">
        1 · Instruments
      </h2>

      {/* ============ THE BRAINS — NewsKeeper → Sentinel → Sherpa (Brief S103b)
           Shown first (S106a): the real pipeline is NEWS → RISK → PARAMETERS
           → EXECUTION, so the brain comes before the execution. All three
           LIVE. Right-rail widgets wired in dashboard-live.ts from
           newskeeper_signals / newskeeper_regime / sentinel_scores /
           sherpa_proposals. JS-rebuilt nodes (headlines, coin rows, gauge,
           bars) styled via the <style is:global> block below. ============ */}
      <div class="reveal db-sec-h"><span>1.1 · Instruments — the brains</span><span class="aside">news → risk → parameters</span></div>

      {/* === NEWSKEEPER === */}
      <article id="newskeeper" class="reveal db-brain scroll-mt-24" style="--ac: var(--color-bot-news); --ac-soft: var(--color-bot-news-soft)">
        <div class="db-plate db-plate-ctx">
          <div class="db-plate-bg db-plate-bg--fill db-plate-q">?</div>
          <NewsKeeperMascot size={96} />
        </div>
        <div class="db-ident">
          <div class="nm"><span class="bar"></span><span class="name">NewsKeeper</span><span class="db-pill"><span class="dot"></span>live</span></div>
          <div class="role">News watcher</div>
          <p class="desc">Classifies crypto headlines by severity and signal — the macro early-warning.</p>
          <div class="foot"><span class="dot"></span>Classifying hourly</div>
        </div>
        <div class="db-rail">
          <div class="db-label">Latest classified headlines</div>
          <div class="db-headlines" id="nk-headlines">
            <div class="db-headline"><span class="sev" style="background:var(--color-neg)"></span><span>SEC delays spot ETH ETF decision to Q3</span></div>
            <div class="db-headline"><span class="sev" style="background:var(--color-pos)"></span><span>BlackRock Bitcoin fund sees $274M inflows</span></div>
            <div class="db-headline"><span class="sev" style="background:var(--color-text-muted)"></span><span>Solana DEX volume holds steady at $2.1B</span></div>
            <div class="db-headline"><span class="sev" style="background:var(--color-neg)"></span><span>Binance faces new regulatory probe in EU</span></div>
          </div>
          <div class="db-baro"><span class="db-label">24h barometer</span><span class="v" id="nk-barometer" style="color:var(--color-text-muted)">Neutral</span></div>
        </div>
      </article>

      <div class="reveal db-flow">
        <svg width="14" height="34" viewBox="0 0 14 34"><line x1="7" y1="0" x2="7" y2="26" stroke="var(--color-border)" stroke-width="2"></line><path d="M2 25 L7 33 L12 25 Z" fill="var(--color-border)"></path></svg>
        <span class="t">barometer</span><span class="shadow-pill">shadow</span>
      </div>

      {/* === SENTINEL === */}
      <article id="sentinel" class="reveal db-brain scroll-mt-24" style="--ac: var(--color-bot-sentinel); --ac-soft: var(--color-bot-sentinel-soft)">
        <div class="db-plate db-plate-ctx">
          <div class="db-plate-bg db-plate-bg--fill">
            <svg viewBox="0 0 200 150" preserveAspectRatio="xMidYMid meet">
              <g fill="none" stroke="var(--ac)" stroke-width="1.2">
                <circle cx="100" cy="75" r="18"><animate attributeName="r" values="18;72" dur="3.2s" repeatCount="indefinite"/><animate attributeName="opacity" values="0.5;0" dur="3.2s" repeatCount="indefinite"/></circle>
                <circle cx="100" cy="75" r="18"><animate attributeName="r" values="18;72" dur="3.2s" begin="1.05s" repeatCount="indefinite"/><animate attributeName="opacity" values="0.5;0" dur="3.2s" begin="1.05s" repeatCount="indefinite"/></circle>
                <circle cx="100" cy="75" r="18"><animate attributeName="r" values="18;72" dur="3.2s" begin="2.1s" repeatCount="indefinite"/><animate attributeName="opacity" values="0.5;0" dur="3.2s" begin="2.1s" repeatCount="indefinite"/></circle>
              </g>
            </svg>
          </div>
          <SentinelMascot size={96} />
        </div>
        <div class="db-ident">
          <div class="nm"><span class="bar"></span><span class="name">Sentinel</span><span class="db-pill"><span class="dot"></span>live</span></div>
          <div class="role">Risk officer</div>
          <p class="desc">Reads risk + the macro regime from price, funding, and Fear &amp; Greed.</p>
          <div class="foot"><span class="dot"></span>Scoring every 60s (fast) · 4h (slow)</div>
        </div>
        <div class="db-rail">
          <div class="db-gauge" id="sent-gauge">
            <span class="on" style="background:var(--color-primary)">extreme fear</span>
            <span style="background:var(--color-neu-soft)">fear</span>
            <span style="background:var(--color-border-soft)">neutral</span>
            <span style="background:var(--color-warn-soft)">greed</span>
            <span style="background:var(--color-neg-soft)">extreme greed</span>
          </div>
          <div class="db-scores">
            <div class="db-score"><div class="db-label">Risk</div><div class="track"><div class="fill" id="sent-risk-bar" style="width:20%;background:var(--color-neg)"></div></div><div class="v" id="sent-risk">20</div></div>
            <div class="db-score"><div class="db-label">Opportunity</div><div class="track"><div class="fill" id="sent-opp-bar" style="width:80%;background:var(--color-pos)"></div></div><div class="v" id="sent-opp">80</div></div>
          </div>
          <div class="db-strip" id="sent-strip">₿ BTC — · Funding —</div>
        </div>
      </article>

      <div class="reveal db-flow">
        <svg width="14" height="34" viewBox="0 0 14 34"><line x1="7" y1="0" x2="7" y2="26" stroke="var(--color-border)" stroke-width="2"></line><path d="M2 25 L7 33 L12 25 Z" fill="var(--color-border)"></path></svg>
        <span class="t">regime</span>
      </div>

      {/* === SHERPA === */}
      <article id="sherpa" class="reveal db-brain scroll-mt-24" style="--ac: var(--color-bot-sherpa); --ac-soft: var(--color-bot-sherpa-soft)">
        <div class="db-plate db-plate-ctx">
          <div class="db-plate-bg db-plate-bg--fill">
            <svg viewBox="0 0 100 100" class="db-gear" style="opacity:0.34">
              <g class="db-gear-spin" fill="var(--ac)">
                {Array.from({ length: 8 }).map((_, i) => (
                  <rect x="45" y="3" width="10" height="16" rx="2" transform={`rotate(${i * 45} 50 50)`} />
                ))}
                <circle cx="50" cy="50" r="30" />
                <circle cx="50" cy="50" r="13" fill="var(--ac-soft)" />
              </g>
            </svg>
          </div>
          <SherpaMascotV2 size={96} />
        </div>
        <div class="db-ident">
          <div class="nm"><span class="bar"></span><span class="name">Sherpa</span><span class="db-pill"><span class="dot"></span>live</span></div>
          <div class="role">Parameter tuner</div>
          <p class="desc">Turns Sentinel's regime reads into per-coin Grid settings.</p>
          <div class="foot"><span class="dot"></span><span id="sherpa-last">Last adjustment: —</span></div>
        </div>
        <div class="db-rail">
          <div class="db-regime-row">
            <span class="db-regime" id="sherpa-regime" style="background:var(--color-primary-soft);border-color:color-mix(in srgb, var(--color-primary) 25%, transparent);color:var(--color-primary)">
              <svg width="11" height="13" viewBox="0 0 11 13" fill="none"><path d="M5.5 0.8 10 2.5v3.6c0 3-1.9 5-4.5 6.1C2.9 11.1 1 9.1 1 6.1V2.5L5.5 0.8Z" fill="currentColor"></path></svg>
              Defensive
            </span>
            <span class="db-label" style="font-size:9px">buy / sell / idle</span>
          </div>
          <div class="db-coinrows" id="sherpa-coins">
            <div class="db-coinrow"><span class="sym">BTC</span><span class="posture">buy tight, sell fast, wait long</span><span class="params">0.65 / 1.05 / 5.6h</span></div>
            <div class="db-coinrow"><span class="sym">SOL</span><span class="posture">buy tight, sell fast, wait long</span><span class="params">0.65 / 1.53 / 5.6h</span></div>
            <div class="db-coinrow"><span class="sym">BONK</span><span class="posture">buy tight, sell fast, wait long</span><span class="params">3.0 / 1.75 / 5.6h</span></div>
          </div>
        </div>
      </article>

      {/* ============ THE TRADERS — TF → Grid (Brief S103b) ============
           Live horizontal rows in data-flow order. Trader numbers reuse the
           existing computeCanonicalState wiring (ids tf-nw / grid-nw / …);
           only the presentation changed. Card grammar lives in the
           <style is:global> block at the end of this section. */}
      <div class="reveal db-sec-h mt-14"><span>1.2 · Instruments — the traders</span><span class="aside">tf picks → grid manages</span></div>

      {/* === TREND FOLLOWER === */}
      <article id="trendfollower" class="reveal db-trade scroll-mt-24" style="--ac: var(--color-bot-tf); --ac-soft: var(--color-bot-tf-soft)">
        <div class="db-plate db-plate-ctx">
          <div class="db-plate-bg db-plate-bg--fill"><RadarSVG color="#f59e0b" /></div>
          <BotMascot color="#f59e0b" accent="#f59e0b" build="lanky" expression="scanning" carrying="binoculars" size={86} uid="mascot-tf" />
        </div>
        <div class="db-ident">
          <div class="nm"><span class="bar"></span><span class="name">Trend Follower</span><span class="db-pill"><span class="dot"></span>live</span></div>
          <div class="meta">— <span id="tf-budget">$100</span> · live · Tier 1-2</div>
          <div class="role">{tfSubtitle}</div>
          <div class="foot">Day <span id="tf-day">…</span> · Cash to reinvest: <b id="tf-cash-reinvest">…</b></div>
        </div>
        <div class="db-core">
          <div>
            <div class="db-label">Net worth</div>
            <div class="db-nwrow"><span class="nw" id="tf-nw">—</span><span class="chg" id="tf-pnl-pct">—</span></div>
          </div>
          <div class="db-spark">
            <svg viewBox="0 0 100 30" preserveAspectRatio="none" id="tf-spark"><polyline points="2,15 98,15" fill="none" stroke="var(--color-bot-tf)" stroke-width="1.6" stroke-linecap="round"></polyline></svg>
            <div class="cap">7d net worth</div>
          </div>
          <div class="db-triple">
            <div><div class="db-label">Unrealized</div><div class="tv" id="tf-unrealized">—</div></div>
            <div><div class="db-label">Fees paid</div><div class="tv" id="tf-fees">—</div></div>
            <div><div class="db-label">Skim</div><div class="tv" id="tf-skim">—</div></div>
          </div>
          <div class="db-cashrow">
            <div class="top"><span>Cash</span><span id="tf-cash-pct">—</span></div>
            <div class="db-allocbar" id="tf-cash-bar"></div>
          </div>
        </div>
        <div class="db-coins">
          <div class="db-label">Open positions</div>
          <div id="tf-natives"><div class="db-empty"><span>None — 100% cash.<br/>Scanning Tier 1-2<br/>for breakouts.</span></div></div>
        </div>
      </article>

      <div class="reveal db-flow">
        <svg width="14" height="34" viewBox="0 0 14 34"><line x1="7" y1="0" x2="7" y2="26" stroke="var(--color-border)" stroke-width="2"></line><path d="M2 25 L7 33 L12 25 Z" fill="var(--color-border)"></path></svg>
        <span class="t">tf picks, grid manages</span>
      </div>

      {/* === GRID BOT === */}
      <article id="grid" class="reveal db-trade scroll-mt-24" style="--ac: var(--color-bot-grid); --ac-soft: var(--color-bot-grid-soft)">
        <div class="db-plate db-plate-ctx">
          <div class="db-plate-bg db-plate-bg--top"><MixerSVG color="#22c55e" /></div>
          <BotMascot color="#22c55e" accent="#22c55e" build="stocky" expression="focused" size={86} uid="mascot-grid" />
        </div>
        <div class="db-ident">
          <div class="nm"><span class="bar"></span><span class="name">Grid Bot</span><span class="db-pill"><span class="dot"></span>live</span></div>
          <div class="meta">— <span id="grid-budget">$500</span> · live</div>
          <div class="role">{gridSubtitle}</div>
          <div class="foot">Day <span id="grid-day">…</span> · Cash to reinvest: <b id="grid-cash-reinvest">…</b></div>
        </div>
        <div class="db-core">
          <div>
            <div class="db-label">Net worth</div>
            <div class="db-nwrow"><span class="nw" id="grid-nw">—</span><span class="chg" id="grid-pnl-pct">—</span></div>
          </div>
          <div class="db-spark">
            <svg viewBox="0 0 100 30" preserveAspectRatio="none" id="grid-spark"><polyline points="2,15 98,15" fill="none" stroke="var(--color-bot-grid)" stroke-width="1.6" stroke-linecap="round"></polyline></svg>
            <div class="cap">7d net worth</div>
          </div>
          <div class="db-triple">
            <div><div class="db-label">Unrealized</div><div class="tv" id="grid-unrealized">—</div></div>
            <div><div class="db-label">Fees paid</div><div class="tv" id="grid-fees">—</div></div>
            <div><div class="db-label">Skim</div><div class="tv" id="grid-skim">—</div></div>
          </div>
          <div class="db-cashrow">
            <div class="top"><span>Cash</span><span id="grid-cash-pct">—</span></div>
            <div class="db-allocbar" id="grid-cash-bar"></div>
          </div>
        </div>
        <div class="db-coins">
          <div class="db-label">Managed coins</div>
          <div id="grid-natives"></div>
        </div>
      </article>

      {/* ============ TEST METRIC — Net realized profit (post-fees) ============
          Single-row test between Grid/TF and Sentinel/Sherpa. Formula from
          brief 70c §4 (parked pending full Strada 2 fix). Kept visible so
          the gap with raw "Total P&L" stays auditable on the public page. */}
      <div class="reveal db-netbar">
        <span class="lbl">Realized profit from sells (post-fees)</span>
        <span id="net-realized-test" class="val tabular-nums">—</span>
      </div>

      <script>
        // Net realized (post-fees) for the Grid fund — avg-cost replay.
        // Single anon-key request; PostgREST max 1000 rows enough at testnet scale.
        //
        // Fix A (2026-06-29): compute realized from the avg-cost replay
        // (revenue − avg×qty per sell) instead of SUM(trades.realized_pnl).
        // The stored realized_pnl drifts ~$8 high because the bot zeroes
        // avg_buy_price on dust sell-out while keeping the dust coins
        // (sell_pipeline.py:696). This inline block was the LAST consumer still
        // reading the raw field — homepage/grid/tf/admin already use the
        // avg-cost replay (lib/pnl-canonical). Mirrors that logic exactly so
        // /dashboard agrees (~+$22.4, not the stale +$30.6).
        //
        // managed_by=eq.grid + cycle=eq.testnet_2 (S72/S97b): single source of
        // truth, current testnet cycle only.
        (async () => {
          const SB_URL = "https://pxdhtmqfwjwjhtcoacsn.supabase.co";
          const SB_KEY =
            "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9." +
            "eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InB4ZGh0bXFmd2p3amh0Y29hY3NuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM4NDI1OTIsImV4cCI6MjA4OTQxODU5Mn0." +
            "G76lvYWrqlM0z2RoSkU1uAglfMBKN_rXvBGOQhb4kdg";
          const url =
            SB_URL +
            "/rest/v1/trades?config_version=eq.v3&managed_by=eq.grid&cycle=eq.testnet_2" +
            "&select=symbol,side,amount,cost,fee,fee_asset,created_at&order=created_at.asc";
          const el = document.getElementById("net-realized-test");
          if (!el) return;
          try {
            const r = await fetch(url, {
              headers: { apikey: SB_KEY, Authorization: "Bearer " + SB_KEY },
            });
            if (!r.ok) throw new Error(String(r.status));
            const rows = (await r.json()) as Array<{
              symbol: string; side: string;
              amount: number | null; cost: number | null;
              fee: number | null; fee_asset: string | null;
              created_at: string;
            }>;
            const st: Record<string, { h: number; avg: number }> = {};
            let realized = 0;
            let fees = 0;
            for (const t of rows) {
              const sym = t.symbol;
              const s = (st[sym] ||= { h: 0, avg: 0 });
              const amt = Number(t.amount) || 0;
              const cost = Number(t.cost) || 0;
              const fee = Number(t.fee) || 0;
              fees += fee;
              if (t.side === "buy") {
                const base = (sym.split("/")[0] || "").toUpperCase();
                const fa = (t.fee_asset || "USDT").toUpperCase();
                const price = amt > 0 ? cost / amt : 0;
                const feeNative = fa === base && price > 0 ? fee / price : 0;
                const q = amt - feeNative;
                const nh = s.h + q;
                if (nh > 0) s.avg = (s.avg * s.h + cost) / nh;
                s.h = nh;
              } else {
                realized += cost - s.avg * amt;
                s.h -= amt;
                if (s.h <= 1e-9) { s.h = 0; s.avg = 0; }
              }
            }
            const net = realized - fees;
            const sign = net >= 0 ? "+" : "−";
            el.textContent = sign + "$" + Math.abs(net).toFixed(2);
            el.classList.remove("text-pos", "text-neg");
            el.classList.add(net >= 0 ? "text-pos" : "text-neg");
          } catch {
            el.textContent = "—";
          }
        })();
      </script>

