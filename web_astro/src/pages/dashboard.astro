---
import Layout from "../layouts/Layout.astro";
import TestnetBanner from "../components/TestnetBanner.astro";
import BotMascot from "../components/BotMascot.astro";
import SentinelMascot   from "../components/SentinelMascot.astro";
import NewsKeeperMascot from "../components/NewsKeeperMascot.astro";
import SherpaMascotV2   from "../components/SherpaMascotV2.astro";
import {
  mockSnapshot, mockGrid, mockTF, mockTools,
  mockTrades, mockCEOLog, fmtUsd, fmtSigned, fmtPct, fmtPrice, fmtTime, fmtDate,
} from "../data/dashboard-mock.ts";

const totalNW    = mockGrid.netWorth + mockTF.netWorth;
const totalInit  = mockGrid.initial + mockTF.initial;
const totalPnl   = totalNW - totalInit;
const totalPct   = (totalPnl / totalInit) * 100;

/* Hero NET WORTH card mirrors the LIVE hero: Grid-ONLY, $500 basis
   (Brief 72a / S72 — TF/Sentinel/Sherpa excluded from public P&L, so the
   numbers stay self-consistent: netWorth − P&L = started). */
const heroInit = mockGrid.initial;
const heroNW   = mockGrid.netWorth;
const heroPnl  = heroNW - heroInit;
const heroPct  = (heroPnl / heroInit) * 100;

/* ====== "Today" snapshot — fotografia del giorno ====== */
const todayPnl       = mockGrid.todayPnl + mockTF.todayPnl;
const todayTrades    = mockGrid.todayTrades + mockTF.todayTrades;
const todayBuys      = mockGrid.todayBuys + mockTF.todayBuys;
const todaySells     = mockGrid.todaySells + mockTF.todaySells;
const todayAllocated = mockGrid.todayAllocated + mockTF.todayAllocated;

/* Sottotitoli statici per ora — in futuro popolati da Haiku ogni sera. */
const gridSubtitle = "The cash machine";
const tfSubtitle   = "The breakout hunter";

---

<Layout
  title="Live Trading Dashboard — BagHolderAI"
  description="Real-time view of our crypto grid trading bots on Binance Testnet. BTC, SOL, BONK — live positions, P&L, and performance, updated every minute."
  current="dashboard"
>

  <TestnetBanner />

  {/* ============================================================ HERO (pattern /diary) */}
  <section class="mx-auto max-w-4xl px-4 pt-10 pb-6 sm:px-6 sm:pt-14 sm:pb-8">

    <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">

      {/* left — title + lede + meta */}
      <div class="min-w-0">
        <h1 class="font-display text-[34px] font-extrabold leading-[1.04] tracking-[-0.02em]
                   text-text sm:text-[42px]">
          Lab <span class="text-primary">notebook</span>.
        </h1>

        <p class="mt-3 max-w-2xl text-[14.5px] leading-[1.55] text-text-dim sm:text-[15px]">
          Two live, two shadowed. Capital at risk:
          <span class="font-mono text-text">$500 Grid + $100 TF (Tier 1-2)</span>
          <span class="font-mono text-text-muted">(Sentinel/Sherpa shadow-only)</span>.
          Snapshot recorded {mockSnapshot.asOfLabel}.
        </p>

        <div class="mt-5 flex flex-wrap items-center gap-3 font-mono text-[10.5px]
                    uppercase tracking-[0.16em] text-text-muted">
          <span class="inline-flex items-center gap-1.5">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary"></span>
            live
          </span>
          <span class="text-border">·</span>
          <span>v3 · launched 2026-03-30</span>
        </div>
      </div>

      {/* right — NET WORTH card (Grid-only $500 basis; top border = P&L sign) */}
      <div id="hero-nw-card"
           class={`shrink-0 self-start rounded-2xl border border-border border-t-4 bg-surface
                   px-5 py-4 shadow-sticker sm:min-w-[208px] sm:text-right
                   ${heroPnl >= 0 ? "border-t-pos" : "border-t-neg"}`}>
        <div class="font-mono text-[10px] font-bold uppercase tracking-[0.18em] text-text-muted">
          Net worth
        </div>
        <div id="hero-nw"
             class="mt-1 font-display text-[36px] font-extrabold leading-none tabular-nums text-text">
          {fmtUsd(heroNW)}
        </div>
        <div id="hero-pnl"
             class={`mt-1.5 font-mono text-[12px] font-semibold tabular-nums
                     ${heroPnl >= 0 ? "text-pos" : "text-neg"}`}>
          {fmtSigned(heroPnl)} · {fmtPct(heroPct)}
        </div>
        <div class="mt-2.5 font-mono text-[9px] uppercase tracking-[0.14em] text-text-muted">
          started {fmtUsd(heroInit)} · day <span id="hero-day">{mockSnapshot.dayNumber}</span>
        </div>
      </div>
    </div>
  </section>

  {/* ============================================================ MAIN */}
  <main class="mx-auto max-w-4xl px-4 pb-24 sm:px-6">

    {/* ============ TODAY SNAPSHOT — fotografia del giorno ============ */}
    <section class="reveal">
      <div class="mb-3 flex items-baseline gap-3">
        <h2 class="font-display text-[20px] sm:text-[22px] font-extrabold tracking-[-0.01em] text-text">
          Today
        </h2>
        <span id="today-date"
              class="font-mono text-[12px] uppercase tracking-[0.16em] text-text-muted">
          {fmtDate(mockSnapshot.asOfIso)}
        </span>
      </div>

      {/* Brief 88d Task 2 — "why no trades" transparency banner. Server-
          rendered hidden; regime-banner.ts unhides it only when there are
          0 trades today AND the slow-loop regime is fear/extreme_fear, then
          fills in last-trade date + regime label. Disappears on its own
          once the bot trades again or the regime shifts. No sensitive
          figures — only last trade and current regime. */}
      <div id="regime-watch-banner"
           class="hidden mb-3 flex flex-wrap items-center gap-x-2 gap-y-1
                  rounded-xl border border-border bg-panel
                  px-3.5 py-2 font-mono text-[11.5px] text-text-dim">
        <span aria-hidden="true">🔍</span>
        <span class="text-text">Watching market</span>
        <span class="text-border">·</span>
        <span>Last trade <span id="regime-watch-lasttrade">—</span></span>
        <span class="text-border">·</span>
        <span id="regime-watch-regime" class="text-neu">Fear regime active</span>
      </div>

      {/* Same font hierarchy as the home live-snapshot panel:
          label 10px uppercase + value 20px semibold. */}
      <dl class="rounded-2xl border border-border bg-surface shadow-sticker-sm
                 grid grid-cols-2 sm:grid-cols-5 divide-x divide-border-soft">
        <div class="px-4 py-3.5">
          <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
            P&amp;L
          </dt>
          <dd id="today-pnl"
              class={`font-display text-[24px] font-extrabold tabular-nums mt-0.5
                      ${todayPnl >= 0 ? "text-pos" : "text-neg"}`}>
            {fmtSigned(todayPnl)}
          </dd>
        </div>
        <div class="px-4 py-3.5">
          <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
            trades
          </dt>
          <dd id="today-trades"
              class="font-display text-[24px] font-extrabold text-text tabular-nums mt-0.5">
            {todayTrades}
          </dd>
        </div>
        <div class="px-4 py-3.5">
          <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
            buys
          </dt>
          <dd id="today-buys"
              class="font-display text-[24px] font-extrabold text-text-dim tabular-nums mt-0.5">
            {todayBuys}
          </dd>
        </div>
        <div class="px-4 py-3.5">
          <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
            sells
          </dt>
          <dd id="today-sells"
              class="font-display text-[24px] font-extrabold text-text-dim tabular-nums mt-0.5">
            {todaySells}
          </dd>
        </div>
        <div class="px-4 py-3.5">
          <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
            allocated
          </dt>
          <dd id="today-allocated"
              class="font-display text-[24px] font-extrabold text-text tabular-nums mt-0.5">
            {fmtUsd(todayAllocated)}
          </dd>
        </div>
      </dl>
    </section>

    {/* ============ 1 — CEO LOG di oggi ============ */}
    <hr class="mt-12 border-t border-border-soft" />
    <section class="mt-8 reveal">
      <h2 class="font-display text-[20px] font-extrabold tracking-[-0.01em] text-text mb-5">
        1 · CEO observation log
      </h2>
      <article id="ceo-today" class="grid grid-cols-[auto_1fr] items-center gap-6
               rounded-2xl border border-border border-l-4 border-l-pos
               bg-surface shadow-sticker-sm p-6">
        <div class="w-[60px] shrink-0 text-center leading-none">
          <span class="block font-mono text-[9px] font-bold uppercase tracking-[0.18em] text-text-muted">day</span>
          <span id="ceo-today-day" class="mt-1 block font-display text-[40px] font-extrabold leading-none text-pos">{mockCEOLog.today.dayNumber}</span>
          <span id="ceo-today-date" class="mt-1.5 block font-mono text-[9px] uppercase tracking-[0.12em] text-text-muted">{fmtDate(mockCEOLog.today.date + "T00:00:00Z")}</span>
        </div>
        <div>
          <div class="mb-2 flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.16em] text-text-muted">
            <span>latest</span>
            <span class="text-border">·</span>
            <span id="ceo-today-model" class="opacity-70">via {mockCEOLog.today.model}</span>
          </div>
          <p id="ceo-today-text" class="text-text leading-[1.7] text-[15px] italic">
            "{mockCEOLog.today.text}"
          </p>
        </div>
      </article>
    </section>

    {/* ============ 2 — INSTRUMENTS ============ */}
    <hr class="mt-12 border-t border-border-soft" />
    <section class="mt-8">
      <h2 class="reveal font-display text-[20px] font-extrabold tracking-[-0.01em] text-text mb-7">
        2 · Instruments
      </h2>

      {/* ============ HORIZONTAL PIPELINE LAYOUT ============
           TF card (left) + shared coins (center) + Grid card (right).
           Both bot cards mirror the same frame (rounded-lg, border-border,
           bg-surface, p-6). Shared-cards container in the center holds
           tf_grid coins (picked by TF, managed by Grid). */}
      <div class="relative grid grid-cols-1 lg:grid-cols-[1fr_140px_1fr]
                  gap-x-3 gap-y-4 items-stretch">

        {/* === TF CARD (left) — mirror of Grid card frame. */}
        <article class="relative h-full rounded-2xl border border-border border-l-4 border-l-[#B5862E] bg-surface shadow-sticker-sm p-6 overflow-hidden">
          {/* mascot peeking from the top-right corner */}
          <BotMascot color="#f59e0b" accent="#f59e0b" build="lanky" expression="scanning"
                     carrying="binoculars" size={58} uid="mascot-tf"
                     class="pointer-events-none absolute top-3 right-3 select-none" />
          <div class="flex items-center gap-3 mb-4 flex-wrap pr-16">
            <div class="w-[3px] h-[22px] rounded-sm" style="background:#B5862E"></div>
            <div class="font-mono text-[14px] text-text uppercase tracking-[0.05em] font-semibold">
              Trend Follower
            </div>
            <div class="font-mono text-[10px] text-text-muted">— <span id="tf-budget">…</span> · live · Tier 1-2</div>
          </div>
          <div class="font-sans text-[12px] text-text-muted italic mb-2">{tfSubtitle}</div>

          {/* Day + Cash to reinvest — populated by JS */}
          <div class="font-mono text-[10px] text-text-muted mb-3 flex flex-wrap gap-x-3 gap-y-1">
            <span>Day <span id="tf-day">…</span></span>
            <span class="text-border">·</span>
            <span>Cash to reinvest: <span id="tf-cash-reinvest" class="text-text">…</span></span>
          </div>

          <div class="font-mono text-[11px] text-text-muted">Net worth</div>
          <div class="flex items-baseline gap-2 flex-wrap mt-1">
            <span id="tf-nw"
                  class="text-[clamp(28px,5vw,38px)] font-bold tracking-tight text-text leading-none">
              —
            </span>
            <span id="tf-pnl-pct" class="font-mono text-[12px] text-text-muted">
              —
            </span>
          </div>

          <div class="my-4 border-t border-border-soft"></div>
          <div class="grid grid-cols-3 gap-y-3 gap-x-4 font-mono">
            <div>
              <div class="text-[10px] text-text-muted">Unrealized</div>
              <div id="tf-unrealized" class="text-[14px] font-medium text-text-muted">—</div>
            </div>
            <div>
              <div class="text-[10px] text-text-muted">Fees paid</div>
              <div id="tf-fees" class="text-[14px] font-medium text-text-muted">—</div>
            </div>
            <div>
              <div class="text-[10px] text-text-muted">Skim</div>
              <div id="tf-skim" class="text-[14px] font-medium text-text-muted">—</div>
            </div>
          </div>

          <div class="my-4 border-t border-border-soft"></div>
          <div class="flex justify-between font-mono mb-2">
            <span class="text-[10px] text-text-muted">Cash</span>
            <span id="tf-cash-pct" class="text-[10px] text-text">—</span>
          </div>
          <div id="tf-cash-bar" class="h-2 bg-border rounded-md overflow-hidden flex"></div>
        </article>

        {/* === SHARED COINS (center) === */}
        <div class="relative flex flex-col items-center justify-start
                    px-2 lg:px-4 self-start pt-4">

          {/* Horizontal arrow with sliding-gradient shimmer.
              Handoff: TF picks Tier 1-2 coins, Grid manages them. */}
          <div class="flex flex-col items-center mb-3 w-full">
            <span class="font-mono text-[9px] uppercase tracking-[0.22em] mb-1 text-center leading-[1.4]"
                  style="color:#3F7589">
              TF picks,<br/>Grid manages
            </span>
            <div class="pipeline-arrow w-full max-w-[200px] h-[14px] relative">
              <span class="pipeline-arrow-tip"></span>
            </div>
          </div>

          {/* Shared cards stacked vertically — populated by JS from
              bot_config WHERE managed_by='tf_grid' AND is_active=true. */}
          <div id="shared-cards" class="flex flex-col gap-2 w-full"></div>

          <div class="mt-4 font-mono text-[9px] uppercase tracking-[0.18em] text-text-muted text-center">
            picked by TF<br/>managed by Grid
          </div>
        </div>

        {/* === GRID BOT CARD (right) — ORIGINAL look (rounded-lg, bg-surface, p-6) === */}
        <article class="relative h-full rounded-2xl border border-border border-l-4 border-l-pos bg-surface shadow-sticker-sm p-6 overflow-hidden">
          {/* mascot peeking from the top-right corner */}
          <BotMascot color="#22c55e" accent="#22c55e" build="stocky" expression="focused"
                     size={58} uid="mascot-grid"
                     class="pointer-events-none absolute top-3 right-3 select-none" />
          <div class="flex items-center gap-3 mb-4 flex-wrap pr-16">
            <div class="w-[3px] h-[22px] rounded-sm" style="background:#4E8A57"></div>
            <div class="font-mono text-[14px] text-text uppercase tracking-[0.05em] font-semibold">
              Grid Bot
            </div>
            <div class="font-mono text-[10px] text-text-muted">— <span id="grid-budget">…</span> · live</div>
          </div>
          <div class="font-sans text-[12px] text-text-muted italic mb-2">{gridSubtitle}</div>

          {/* Day + Cash to reinvest — populated by JS */}
          <div class="font-mono text-[10px] text-text-muted mb-3 flex flex-wrap gap-x-3 gap-y-1">
            <span>Day <span id="grid-day">…</span></span>
            <span class="text-border">·</span>
            <span>Cash to reinvest: <span id="grid-cash-reinvest" class="text-text">…</span></span>
          </div>

          <div class="font-mono text-[11px] text-text-muted">Net worth</div>
          <div class="flex items-baseline gap-2 flex-wrap mt-1">
            <span id="grid-nw"
                  class="text-[clamp(28px,5vw,38px)] font-bold tracking-tight text-text leading-none">
              —
            </span>
            <span id="grid-pnl-pct" class="font-mono text-[12px] text-text-muted">
              —
            </span>
          </div>

          <div class="my-4 border-t border-border-soft"></div>
          <div class="grid grid-cols-3 gap-y-3 gap-x-4 font-mono">
            <div>
              <div class="text-[10px] text-text-muted">Unrealized</div>
              <div id="grid-unrealized" class="text-[14px] font-medium text-text-muted">—</div>
            </div>
            <div>
              <div class="text-[10px] text-text-muted">Fees paid</div>
              <div id="grid-fees" class="text-[14px] font-medium text-text-muted">—</div>
            </div>
            <div>
              <div class="text-[10px] text-text-muted">Skim</div>
              <div id="grid-skim" class="text-[14px] font-medium text-text-muted">—</div>
            </div>
          </div>

          <div class="my-4 border-t border-border-soft"></div>
          <div class="flex justify-between font-mono mb-2">
            <span class="text-[10px] text-text-muted">Cash</span>
            <span id="grid-cash-pct" class="text-[10px] text-text">—</span>
          </div>
          <div id="grid-cash-bar" class="h-2 bg-border rounded-md overflow-hidden flex"></div>
        </article>

        {/* === BOTTOM ROW (inside same grid):
            col 1 = tf-natives (TF-managed coins, populated by JS),
            col 2 = empty, col 3 = grid-natives. */}
        <div id="tf-natives" class="grid grid-cols-2 gap-2 h-full"></div>
        <div></div>
        <div id="grid-natives" class="grid grid-cols-3 gap-2 h-full"></div>
      </div>

      {/* ============ TEST METRIC — Net realized profit (post-fees) ============
          Single-row test between Grid/TF and Sentinel/Sherpa. Formula from
          brief 70c §4 (parked pending full Strada 2 fix). Kept visible so
          the gap with raw "Total P&L" stays auditable on the public page. */}
      <section class="reveal mt-10">
        <div class="rounded-2xl border border-border bg-surface shadow-sticker-sm px-5 py-4
                    flex flex-wrap items-baseline justify-between gap-3">
          <div class="flex flex-wrap items-baseline gap-3">
            <span class="font-mono text-[10px] uppercase tracking-[0.16em] text-text-muted">
              Net realized profit (post-fees)
            </span>
            <span class="font-mono text-[12px] text-text-dim">
              Total P&amp;L sell − Fees =
            </span>
          </div>
          <span id="net-realized-test"
                class="font-display text-[24px] font-extrabold text-pos tabular-nums">
            —
          </span>
        </div>
      </section>

      <script>
        // Fetch sell P&L and total fees from trades v3 — aggregate client-side.
        // Single anon-key request; PostgREST max 1000 rows enough at testnet scale.
        //
        // Brief 72a S72 fix (Max audit 2026-05-11): originally selected ALL
        // v3 trades without managed_by filter — pulled in 2 TF + 2 tf_grid
        // rows (+$0.041 realized, +$0.028 fees) → netto +$0.013 ≈ $0.01
        // overstatement vs canonical Grid-only number on /grid.html. Filter
        // realigned to managed_by=eq.grid (single source of truth, mirrors
        // dashboard-live.ts gridManagedBy + grid.html post-S72).
        (async () => {
          const SB_URL = "https://pxdhtmqfwjwjhtcoacsn.supabase.co";
          const SB_KEY =
            "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9." +
            "eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InB4ZGh0bXFmd2p3amh0Y29hY3NuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM4NDI1OTIsImV4cCI6MjA4OTQxODU5Mn0." +
            "G76lvYWrqlM0z2RoSkU1uAglfMBKN_rXvBGOQhb4kdg";
          const url =
            SB_URL +
            "/rest/v1/trades?config_version=eq.v3&managed_by=eq.grid&select=side,realized_pnl,fee";
          const el = document.getElementById("net-realized-test");
          if (!el) return;
          try {
            const r = await fetch(url, {
              headers: { apikey: SB_KEY, Authorization: "Bearer " + SB_KEY },
            });
            if (!r.ok) throw new Error(String(r.status));
            const rows = (await r.json()) as Array<{
              side: string;
              realized_pnl: number | null;
              fee: number | null;
            }>;
            let pnlSell = 0;
            let fees = 0;
            for (const t of rows) {
              if (t.side === "sell") pnlSell += Number(t.realized_pnl) || 0;
              fees += Number(t.fee) || 0;
            }
            const net = pnlSell - fees;
            const sign = net >= 0 ? "+" : "−";
            el.textContent = sign + "$" + Math.abs(net).toFixed(2);
            el.classList.remove("text-pos", "text-neg");
            el.classList.add(net >= 0 ? "text-pos" : "text-neg");
          } catch {
            el.textContent = "—";
          }
        })();
      </script>

      {/* ============ SENTINEL + SHERPA — live observational brains ============ */}
      <div class="reveal mt-14 grid grid-cols-1 gap-5 sm:grid-cols-3 items-stretch">
        {mockTools.filter((t) => t.status === "active" || t.status === "testing").map((tool) => {
          const live = tool.status === "active";
          const statusLine = tool.key === "sentinel"
            ? "Scoring risk + regime every 60s (fast) and 4h (slow)."
            : tool.key === "newskeeper"
            ? "Classifying crypto headlines by severity + signal, hourly."
            : "Proposing per-coin Grid parameters — logged, not applied.";
          return (
            <div class="flex flex-col h-full">
              <div class="flex items-center gap-3 mb-3.5">
                <div class="w-[3px] h-[22px] rounded-sm" style={`background:${tool.color}`}></div>
                <div class="font-mono text-[14px] text-text uppercase tracking-[0.05em] font-semibold">
                  {tool.name}
                </div>
                <div class={`font-mono text-[11px] ${live ? "text-pos" : "text-text-muted"}`}>
                  — {live ? "LIVE" : "DRY_RUN"}
                </div>
              </div>
              <div class="flex-1 flex flex-col rounded-2xl border border-border bg-surface shadow-sticker-sm p-5">
                <div class="flex items-start gap-3">
                  <div class="shrink-0 -mt-1 -ml-1 select-none pointer-events-none">
                    {tool.key === "sentinel"  && <SentinelMascot   size={70} />}
                    {tool.key === "newskeeper" && <NewsKeeperMascot size={70} />}
                    {tool.key === "sherpa"     && <SherpaMascotV2   size={70} />}
                  </div>
                  <p class="text-text-dim text-[14px] leading-relaxed">{tool.blurb}</p>
                </div>
                <div class="mt-auto pt-4 font-mono text-[11px] text-text-muted">
                  {live ? "🟢" : "🔬"} {statusLine}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    {/* ============ 3 — CHARTS (full-width, stacked) ============
         One range selector controls both charts: line cumulative P&L on
         top, stacked weekly/monthly bar chart below. Net labels for the
         bar chart are rendered as an HTML row absolutely positioned over
         the canvas (see dashboard-live.ts → syncNetRow). */}
    <hr class="mt-12 border-t border-border-soft" />
    <section class="mt-8 reveal">
      <div class="flex items-baseline justify-between flex-wrap gap-3 mb-5">
        <h2 class="font-display text-[20px] font-extrabold tracking-[-0.01em] text-text">
          3 · Performance · time series
