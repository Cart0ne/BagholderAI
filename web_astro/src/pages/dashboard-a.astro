---
import Layout from "../layouts/Layout.astro";
import {
  mockSnapshot, mockGrid, mockTF, mockTools, mockCumulative, mockDaily,
  mockTrades, mockCEOLog, fmtUsd, fmtSigned, fmtPct, fmtPrice, fmtTime, fmtDate,
} from "../data/dashboard-mock.ts";

const totalNW   = mockGrid.netWorth + mockTF.netWorth;
const totalInit = mockGrid.initial + mockTF.initial;
const totalPnl  = totalNW - totalInit;
const totalPct  = (totalPnl / totalInit) * 100;
---

<Layout title="Dashboard — Lab notebook (proto A)" current="dashboard">

  {/* ============ Variant switcher (visibile solo in proto) ============ */}
  <div class="border-b border-border-soft bg-surface/40">
    <div class="mx-auto max-w-6xl px-4 py-2 sm:px-6 flex items-center justify-between gap-4 text-[11px] font-mono">
      <span class="text-text-muted uppercase tracking-[0.18em]">Prototype</span>
      <div class="flex items-center gap-3">
        <a href="/dashboard-a" class="px-2.5 py-1 rounded border border-primary text-primary">A · Lab notebook</a>
        <a href="/dashboard-b" class="px-2.5 py-1 rounded border border-border text-text-dim hover:text-text">B · Stato del fondo</a>
        <a href="/dashboard-c" class="px-2.5 py-1 rounded border border-border text-text-dim hover:text-text">C · Operativo editoriale</a>
      </div>
    </div>
  </div>

  <main class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">

    {/* ============ HEADER LAB-STYLE ============ */}
    <section class="reveal">
      <div class="font-mono text-[11px] uppercase tracking-[0.22em] text-text-muted mb-3">
        Experiment log · v3
      </div>
      <h1 class="font-mono text-2xl sm:text-3xl text-text leading-tight">
        Lab notebook — <span class="text-primary">day {mockSnapshot.dayNumber}</span>
      </h1>
      <p class="mt-3 text-text-dim max-w-2xl text-[15px] leading-relaxed">
        Four instruments. Two live, two staged. Capital at risk: <span class="text-text font-mono">{fmtUsd(totalInit, 0)}</span>.
        Snapshot recorded {mockSnapshot.asOfLabel}.
      </p>

      {/* Meta strip — orizzontale, mono, da quaderno scientifico */}
      <div class="mt-8 grid grid-cols-2 sm:grid-cols-4 gap-px bg-border rounded-lg overflow-hidden border border-border">
        <div class="bg-surface p-4">
          <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted mb-1">net worth</div>
          <div class="font-mono text-xl text-text" data-count={fmtUsd(totalNW)}>{fmtUsd(totalNW)}</div>
        </div>
        <div class="bg-surface p-4">
          <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted mb-1">delta</div>
          <div class={`font-mono text-xl ${totalPnl >= 0 ? "text-pos" : "text-neg"}`}>
            {fmtSigned(totalPnl)} <span class="text-[12px] opacity-70">({fmtPct(totalPct)})</span>
          </div>
        </div>
        <div class="bg-surface p-4">
          <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted mb-1">trades</div>
          <div class="font-mono text-xl text-text">{mockGrid.trades + mockTF.trades}</div>
        </div>
        <div class="bg-surface p-4">
          <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted mb-1">days live</div>
          <div class="font-mono text-xl text-text">{mockSnapshot.dayNumber}</div>
        </div>
      </div>
    </section>

    {/* ============ 4 INSTRUMENTS ============ */}
    <section class="mt-20">
      <div class="reveal flex items-baseline justify-between gap-4 mb-6">
        <h2 class="font-mono text-sm uppercase tracking-[0.22em] text-text-dim">
          § 1 — Instruments
        </h2>
        <span class="font-mono text-[11px] text-text-muted">2 live · 2 staged</span>
      </div>

      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 gap-px bg-border rounded-lg overflow-hidden border border-border">
        {mockTools.map((tool) => (
          <article class={`bg-surface p-6 relative ${tool.status === "soon" ? "opacity-60" : ""}`}>
            {/* Stato indicator */}
            <div class="absolute top-4 right-4 flex items-center gap-1.5">
              <span class={`inline-block w-1.5 h-1.5 rounded-full ${tool.status === "live" ? "" : ""}`}
                    style={`background:${tool.color};${tool.status === "live" ? `box-shadow:0 0 8px ${tool.color}aa;` : "opacity:0.4;"}`}>
              </span>
              <span class="font-mono text-[9px] uppercase tracking-[0.18em] text-text-muted">
                {tool.status === "live" ? "live" : "staged"}
              </span>
            </div>

            <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted mb-1">
              instrument · {tool.rarity}
            </div>
            <h3 class="font-mono text-xl text-text" style={`color:${tool.color}`}>
              {tool.name}
            </h3>
            <p class="text-[14px] text-text-dim mt-2 leading-relaxed">{tool.blurb}</p>

            {tool.status === "live" ? (
              <div class="mt-5 grid grid-cols-3 gap-4 font-mono">
                <div>
                  <div class="text-[10px] uppercase tracking-[0.15em] text-text-muted">capital</div>
                  <div class="text-[15px] text-text mt-1">{fmtUsd(tool.capital!, 0)}</div>
                </div>
                <div>
                  <div class="text-[10px] uppercase tracking-[0.15em] text-text-muted">net worth</div>
                  <div class="text-[15px] text-text mt-1">{fmtUsd(tool.nw!)}</div>
                </div>
                <div>
                  <div class="text-[10px] uppercase tracking-[0.15em] text-text-muted">delta</div>
                  <div class={`text-[15px] mt-1 ${tool.pnlPct! >= 0 ? "text-pos" : "text-neg"}`}>
                    {fmtPct(tool.pnlPct!)}
                  </div>
                </div>
              </div>
            ) : (
              <div class="mt-5 font-mono text-[11px] text-text-muted">
                ⏳ in design — not yet deployed
              </div>
            )}
          </article>
        ))}
      </div>
    </section>

    {/* ============ § 2 — INSTRUMENT DETAILS (Grid) ============ */}
    <section class="mt-20 reveal">
      <h2 class="font-mono text-sm uppercase tracking-[0.22em] text-text-dim mb-6">
        § 2.1 — Grid Bot · per-asset
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-border rounded-lg overflow-hidden border border-border">
        {mockGrid.assets.map((a) => {
          const totalPnl = a.realized + a.unrealized;
          return (
            <div class="bg-surface p-5">
              <div class="flex items-center gap-2 mb-3">
                <span class="inline-block w-2 h-2 rounded-full" style={`background:${a.color}`}></span>
                <span class="font-mono text-[13px] text-text">{a.short}</span>
                <span class="font-mono text-[10px] text-text-muted ml-auto">${a.alloc} alloc</span>
              </div>
              <div class="font-mono text-[10px] uppercase tracking-[0.15em] text-text-muted">mtm value</div>
              <div class="font-mono text-lg text-text">{fmtUsd(a.mtmValue)}</div>
              <div class="mt-3 grid grid-cols-2 gap-2 font-mono text-[11px]">
                <div>
                  <div class="text-text-muted">realized</div>
                  <div class={a.realized >= 0 ? "text-pos" : "text-neg"}>{fmtSigned(a.realized)}</div>
                </div>
                <div>
                  <div class="text-text-muted">unrealized</div>
                  <div class={a.unrealized >= 0 ? "text-pos" : "text-neg"}>{fmtSigned(a.unrealized)}</div>
                </div>
              </div>
              <div class="mt-3 font-mono text-[10px] text-text-muted">
                live {fmtPrice(a.livePrice)} · avg {fmtPrice(a.avgBuy)}
              </div>
            </div>
          );
        })}
      </div>
    </section>

    {/* ============ § 2.2 — TF per-asset ============ */}
    <section class="mt-12 reveal">
      <h2 class="font-mono text-sm uppercase tracking-[0.22em] text-text-dim mb-6">
        § 2.2 — Trend Follower · per-asset
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-border rounded-lg overflow-hidden border border-border">
        {mockTF.assets.map((a) => (
          <div class="bg-surface p-5">
            <div class="flex items-center gap-2 mb-3">
              <span class="inline-block w-2 h-2 rounded-full" style={`background:${a.color}`}></span>
              <span class="font-mono text-[13px] text-text">{a.short}</span>
              <span class="font-mono text-[10px] text-text-muted ml-auto">${a.alloc.toFixed(2)} alloc</span>
            </div>
            <div class="font-mono text-[10px] uppercase tracking-[0.15em] text-text-muted">mtm value</div>
            <div class="font-mono text-lg text-text">{fmtUsd(a.mtmValue)}</div>
            <div class="mt-3 grid grid-cols-2 gap-2 font-mono text-[11px]">
              <div>
                <div class="text-text-muted">realized</div>
                <div class={a.realized >= 0 ? "text-pos" : "text-neg"}>{fmtSigned(a.realized)}</div>
              </div>
              <div>
                <div class="text-text-muted">unrealized</div>
                <div class={a.unrealized >= 0 ? "text-pos" : "text-neg"}>{fmtSigned(a.unrealized)}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* ============ § 3 — CHARTS as experiment output ============ */}
    <section class="mt-20 reveal">
      <h2 class="font-mono text-sm uppercase tracking-[0.22em] text-text-dim mb-6">
        § 3 — Experiment output · time series
      </h2>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="rounded-lg border border-border bg-surface p-5">
          <div class="flex items-baseline justify-between mb-3">
            <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-text-dim">
              Cumulative P&amp;L
            </span>
            <span class="font-mono text-[10px] text-text-muted">realized + mtm</span>
          </div>
          <div class="h-[180px] relative">
            <canvas id="chart-cumul-a"></canvas>
          </div>
          <div class="mt-3 flex gap-4 font-mono text-[10px] text-text-muted">
            <span><span class="inline-block w-3 h-px align-middle bg-pos mr-1"></span>realized</span>
            <span><span class="inline-block w-3 h-px align-middle border-t border-dashed border-pos/60 mr-1"></span>mark-to-market</span>
          </div>
        </div>

        <div class="rounded-lg border border-border bg-surface p-5">
          <div class="flex items-baseline justify-between mb-3">
            <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-text-dim">
              Daily realized
            </span>
            <span class="font-mono text-[10px] text-text-muted">grid + tf stacked</span>
          </div>
          <div class="h-[180px] relative">
            <canvas id="chart-daily-a"></canvas>
          </div>
          <div class="mt-3 flex gap-4 font-mono text-[10px] text-text-muted">
            <span><span class="inline-block w-2 h-2 align-middle mr-1" style="background:#22c55e"></span>grid</span>
            <span><span class="inline-block w-2 h-2 align-middle mr-1" style="background:#f59e0b"></span>tf</span>
          </div>
        </div>
      </div>
    </section>

    {/* ============ § 4 — CEO LOG ============ */}
    <section class="mt-20 reveal">
      <h2 class="font-mono text-sm uppercase tracking-[0.22em] text-text-dim mb-6">
        § 4 — CEO observation log
      </h2>
      <article class="rounded-lg border border-border bg-surface p-7">
        <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted mb-3">
          Day {mockCEOLog.today.dayNumber} · {fmtDate(mockCEOLog.today.date + "T00:00:00Z")} · via {mockCEOLog.today.model}
        </div>
        <p class="text-text leading-relaxed text-[16px] italic">
          "{mockCEOLog.today.text}"
        </p>
      </article>

      <details class="mt-4 rounded-lg border border-border bg-surface/60">
        <summary class="cursor-pointer px-5 py-3 font-mono text-[11px] uppercase tracking-[0.18em] text-text-dim hover:text-text">
          ▸ Earlier entries ({mockCEOLog.archive.length})
        </summary>
        <div class="px-5 pb-4 space-y-4">
          {mockCEOLog.archive.map((e) => (
            <div class="border-t border-border pt-3">
              <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted mb-1">
                Day {e.dayNumber} · {fmtDate(e.date + "T00:00:00Z")}
              </div>
              <p class="text-text-dim text-[14px] italic">"{e.text}"</p>
            </div>
          ))}
        </div>
      </details>
    </section>

    {/* ============ § 5 — TRADE REGISTRY ============ */}
    <section class="mt-20 reveal">
      <h2 class="font-mono text-sm uppercase tracking-[0.22em] text-text-dim mb-6">
        § 5 — Experiment registry · last 12 trades
      </h2>
      <div class="overflow-x-auto rounded-lg border border-border">
        <table class="w-full font-mono text-[12px]">
          <thead class="bg-surface/60">
            <tr class="text-text-muted uppercase tracking-[0.12em] text-[10px]">
              <th class="px-3 py-2.5 text-left">time</th>
              <th class="px-3 py-2.5 text-left">bot</th>
              <th class="px-3 py-2.5 text-left">side</th>
              <th class="px-3 py-2.5 text-left">coin</th>
              <th class="px-3 py-2.5 text-right">price</th>
              <th class="px-3 py-2.5 text-right">cost</th>
              <th class="px-3 py-2.5 text-right">p&amp;l</th>
            </tr>
          </thead>
          <tbody>
            {mockTrades.map((t) => (
              <tr class="border-t border-border-soft hover:bg-surface/40">
                <td class="px-3 py-2.5 text-text-muted">{fmtDate(t.ts)} {fmtTime(t.ts)}</td>
                <td class="px-3 py-2.5">
                  <span class={`inline-block px-1.5 py-0.5 rounded text-[10px] uppercase tracking-[0.1em] ${
                    t.bot === "grid" ? "border border-pos/40 text-pos" : "border border-amber-400/40 text-amber-400"
                  }`}>
                    {t.bot}
                  </span>
                </td>
                <td class={`px-3 py-2.5 ${t.side === "buy" ? "text-text-dim" : "text-text"}`}>{t.side}</td>
                <td class="px-3 py-2.5 text-text">{t.symbol.replace("/USDT", "")}</td>
                <td class="px-3 py-2.5 text-right text-text-dim">{fmtPrice(t.price)}</td>
                <td class="px-3 py-2.5 text-right text-text-dim">{fmtUsd(t.cost)}</td>
                <td class={`px-3 py-2.5 text-right ${t.pnl == null ? "text-text-muted" : t.pnl >= 0 ? "text-pos" : "text-neg"}`}>
                  {t.pnl == null ? "—" : fmtSigned(t.pnl)}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="mt-3 font-mono text-[11px] text-text-muted text-right">
        Full trade log on <a href="#" class="text-primary hover:underline">/trades</a> · public, every entry
      </div>
    </section>

  </main>

  {/* Chart.js loaded inline. The script is in a separate .ts file because
     inline TS in Astro <script> tags fails in browsers (memory: scroll-anim lesson). */}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js" is:inline></script>
  <script>
    /* Mini reimport del mock per il client.
       Non possiamo importare da .ts direttamente nel browser, quindi
       i dati per i grafici li passiamo via dataset su un elemento. */
    const chartData = JSON.parse(document.getElementById("chart-data-a")!.textContent!);
    const cumulCtx = (document.getElementById("chart-cumul-a") as HTMLCanvasElement).getContext("2d")!;
    const dailyCtx = (document.getElementById("chart-daily-a") as HTMLCanvasElement).getContext("2d")!;

    const Chart = (window as any).Chart;
    Chart.defaults.font.family = "'JetBrains Mono', monospace";
    Chart.defaults.color = "#9aa3b8";

    new Chart(cumulCtx, {
      type: "line",
      data: {
        labels: chartData.cumul.map((p: any) => p.date),
        datasets: [
          { label: "Realized", data: chartData.cumul.map((p: any) => p.realized),
            borderColor: "#86efac", backgroundColor: "rgba(134,239,172,0.06)",
            borderWidth: 1.5, fill: true, tension: 0.25, pointRadius: 0 },
          { label: "MTM", data: chartData.cumul.map((p: any) => p.mtm),
            borderColor: "rgba(134,239,172,0.6)", borderWidth: 1, borderDash: [3, 3],
            fill: false, tension: 0.25, pointRadius: 0 },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { display: false },
          y: { grid: { color: "rgba(255,255,255,0.04)" }, ticks: { font: { size: 9 } } },
        },
      },
    });

    new Chart(dailyCtx, {
      type: "bar",
      data: {
        labels: chartData.daily.map((p: any) => p.date),
        datasets: [
          { label: "Grid", data: chartData.daily.map((p: any) => p.grid),
            backgroundColor: "rgba(34,197,94,0.7)", stack: "x" },
          { label: "TF", data: chartData.daily.map((p: any) => p.tf),
            backgroundColor: "rgba(251,146,60,0.7)", stack: "x" },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { display: false, stacked: true },
          y: { stacked: true, grid: { color: "rgba(255,255,255,0.04)" }, ticks: { font: { size: 9 } } },
        },
      },
    });
  </script>

  {/* JSON payload per i grafici. */}
  <script id="chart-data-a" type="application/json" set:html={JSON.stringify({
    cumul: mockCumulative,
    daily: mockDaily,
  })}></script>

</Layout>
