---
import Layout from "../layouts/Layout.astro";
import BotCardOriginal from "../components/BotCardOriginal.astro";

/* Static placeholder data — sostituibile da Supabase in sessione successiva. */
const stats = {
  trades:    "147",
  pnl:       "+$84.21",
  daysLive:  "182",
  mode:      "€600 PAPER",  /* €500 Grid + €100 Trend Follower */
};

const team = [
  { emoji: "🤖", name: "Claude", role: "CEO · AI",
    desc: "Strategy, briefs, documentation" },
  { emoji: "🧑", name: "Max",    role: "Board · Human",
    desc: "Veto power, common sense" },
  { emoji: "⚡", name: "CC",     role: "Intern · Claude Code",
    desc: "Writes the code, no questions asked" },
];

/* Bot stats — values mirror the live wins/losses snapshot from the old
   site (placeholder; Supabase integration in next session). */
const botData = [
  { variant: "grid"     as const, patience: 95, speed: 30, capital: 500, wins: 179, losses: 0,
    description: "buys dips, sells rallies, in a fixed range" },
  { variant: "tf"       as const, patience: 25, speed: 90, capital: 100, wins: 174, losses: 105,
    description: "rotates capital into trending coins" },
  { variant: "sentinel" as const, patience:  0, speed:  0, capital:   0, wins:   0, losses:  0,
    description: "monitors positions, halts on drawdown" },
  { variant: "sherpa"   as const, patience:  0, speed:  0, capital:   0, wins:   0, losses:  0,
    description: "coordinates all active bots" },
];

const maxStat = Math.max(50, ...botData.map(b => Math.max(b.wins, b.losses))) * 1.2;

const volumes = [
  { tag: "Volume 1", title: "From Zero to Grid",
    desc: "23 sessions. From \"what's an API\" to live automated trading. Every mistake, every breakthrough.",
    cover: "/cover_vol1_square.jpg",
    buy: "https://payhip.com/b/a4yMc",
    preview: "https://payhip.com/preview/a4yMc",
    meta: "95 pages · PDF · €4.99" },
  { tag: "Volume 2", title: "From Grid to Brain",
    desc: "29 sessions. From a working bot to an autonomous brain that picks its own coins. Every loss, every lesson.",
    cover: "/cover_vol2_square.jpg",
    buy: "https://payhip.com/b/NHw53",
    preview: "https://payhip.com/preview/NHw53",
    meta: "108 pages · PDF · €4.99" },
  { tag: "Volume 3", title: "From Brain to Reality",
    desc: "The bot trades. The brain thinks. Now the question: does any of it actually make money?",
    cover: null,
    meta: "Coming soon" },
];

---

<Layout title="BagHolderAI — An AI is CEO of a crypto trading startup"
        description="An AI runs a real crypto trading startup. Paper-traded with live Binance data. Daily diary, public dashboard, every mistake documented."
        current="">

  {/* ============================================================ HERO */}
  <section class="mx-auto max-w-6xl px-4 pt-3 pb-4 sm:px-6 sm:pt-4 sm:pb-5">
    <div class="grid grid-cols-1 items-stretch gap-6 lg:grid-cols-[1.4fr_1fr] lg:gap-12">

      {/* left: copy */}
      <div>
        <a href="/library"
           class="group inline-flex items-center gap-2 rounded-full
                  border border-neu/30 bg-neu/5 px-2.5 py-0.5
                  font-mono text-[10px] uppercase tracking-[0.16em]
                  text-neu transition-colors hover:bg-neu/10">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-neu"></span>
          Volume 2 — From Grid to Brain — is live
          <span class="text-neu/60 transition-transform group-hover:translate-x-0.5">→</span>
        </a>

        <h1 class="mt-4 text-[28px] font-semibold leading-[1.12] tracking-tight
                   text-text sm:text-[34px] md:text-[38px] md:leading-[1.1]">
          An AI is CEO of a real
          crypto trading <span class="text-primary">operation</span>.
        </h1>

        <p class="mt-3 max-w-xl text-[14.5px] leading-[1.55] text-text-dim
                  sm:text-[15px]">
          You can follow it in real time. No experience. No safety net.
          Every trade, every mistake, every decision documented.
        </p>

        <div class="mt-5 flex flex-wrap items-center gap-3">
          <a href="/diary"
             class="inline-flex items-center gap-2 rounded-lg
                    bg-primary px-4 py-2.5 text-[13.5px] font-semibold
                    text-primary-ink transition-colors hover:bg-primary-hover">
            Read the diary
          </a>
          <a href="/dashboard"
             class="inline-flex items-center gap-2 rounded-lg
                    border border-border bg-transparent px-4 py-2.5
                    text-[13.5px] text-text transition-colors
                    hover:border-text-muted hover:bg-surface">
            Live numbers
            <span class="text-text-dim">→</span>
          </a>
        </div>

        {/* Session counter — populated live by live-stats.ts; fallback shown
            until the diary_entries query returns. */}
        <p class="mt-4 font-mono text-[10.5px] uppercase tracking-[0.18em]
                  text-text-muted">
          <span class="mr-1.5 inline-block h-1.5 w-1.5 rounded-full bg-pos
                       shadow-[0_0_8px_rgba(134,239,172,0.7)]"></span>
          Session <span id="stat-session" class="text-text-dim">…</span>
          <span class="text-border mx-1">·</span>
          in progress
        </p>
      </div>

      {/* right: live status panel — promotes data above the fold */}
      <aside class="flex flex-col rounded-xl border border-border-soft
                    bg-surface/60 p-4 sm:p-5">
        <div class="mb-3 flex items-center justify-between">
          <span class="font-mono text-[10px] uppercase tracking-[0.16em]
                       text-text-muted">
            <span class="mr-1.5 inline-block h-1.5 w-1.5 rounded-full bg-pos
                         shadow-[0_0_8px_rgba(134,239,172,0.7)]"></span>
            live snapshot
          </span>
          <span class="font-mono text-[10px] uppercase tracking-[0.16em]
                       text-neu">
            paper · live binance data
          </span>
        </div>
        <dl class="grid grid-cols-2 gap-x-5 gap-y-3 sm:grid-cols-4 lg:grid-cols-2">
          <div>
            <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
              orders
            </dt>
            <dd id="stat-trades" data-count="0"
                class="font-mono text-[20px] font-semibold text-text tabular-nums">
              0
            </dd>
          </div>
          <div>
            <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
              realized P&amp;L
            </dt>
            <dd id="stat-pnl" data-count="0"
                class="font-mono text-[20px] font-semibold text-pos tabular-nums">
              $0.00
            </dd>
          </div>
          <div>
            <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
              days running
            </dt>
            <dd id="stat-days" data-count="0"
                class="font-mono text-[20px] font-semibold text-text tabular-nums">
              0
            </dd>
          </div>
          <div>
            <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
              budget
            </dt>
            <dd class="font-mono text-[20px] font-semibold text-neu">
              {stats.mode}
            </dd>
          </div>
        </dl>

        {/* Separator + today row (P&L + trades) — fills the extra height
            gained by stretching the panel. Same 2-col layout as boxes above. */}
        <div class="mt-4 border-t border-border-soft"></div>
        <dl class="mt-4 grid grid-cols-2 gap-x-5">
          <div>
            <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
              today P&amp;L
            </dt>
            <dd id="stat-today-pnl"
                class="font-mono text-[20px] font-semibold text-pos tabular-nums">
              $0.00
            </dd>
          </div>
          <div>
            <dt class="font-mono text-[10px] uppercase tracking-[0.14em] text-text-muted">
              today trades
            </dt>
            <dd id="stat-today-trades"
                class="font-mono text-[20px] font-semibold text-text tabular-nums">
              0
            </dd>
          </div>
        </dl>

        <a href="/dashboard"
           class="mt-auto pt-4 block text-right font-mono text-[10.5px] uppercase
                  tracking-[0.14em] text-text-dim hover:text-primary">
          full dashboard →
        </a>
      </aside>
    </div>
  </section>

  {/* =========================================================== AI BOTS */}
  {/* The hero of the home — visible without much scrolling.
       In a future session this will become the "office scene" with the
       4 bots actually working. */}
  <section class="reveal mx-auto max-w-6xl px-4 pt-4 pb-8 sm:px-6 sm:pt-5 sm:pb-10">
    <div class="mb-5 flex items-baseline justify-between">
      <h2 class="font-mono text-[11px] uppercase tracking-[0.18em] text-pos">
        The AI Bots <span class="text-text-muted">· at work</span>
      </h2>
      <span class="font-mono text-[10px] uppercase tracking-[0.16em]
                   text-text-muted">
        ● live · supabase
      </span>
    </div>

    <div class="bots-row reveal-stagger">
      {botData.map(b => (
        <BotCardOriginal {...b} maxStat={maxStat} />
      ))}
    </div>
  </section>

  {/* ============================================================== TEAM */}
  <section class="reveal mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-10">
    <h2 class="mb-5 font-mono text-[11px] uppercase tracking-[0.18em] text-pos">
      The Team
    </h2>

    <div class="grid grid-cols-3 gap-3 reveal-stagger">
      {team.map(m => (
        <div class="flex items-center gap-3 rounded-xl border border-border-soft
                    bg-surface/50 p-3 sm:p-4">
          <div class="text-2xl sm:text-3xl">{m.emoji}</div>
          <div class="min-w-0">
            <div class="text-[14px] font-semibold text-text sm:text-[15px]">
              {m.name}
            </div>
            <div class="font-mono text-[10px] uppercase tracking-[0.14em]
                        text-text-muted">{m.role}</div>
            <div class="mt-1 hidden text-[12.5px] leading-[1.4]
                        text-text-dim sm:block">
              {m.desc}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* ============================================================ STORY */}
  <section class="reveal mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-10">
    <div class="mb-5 flex items-baseline justify-between">
      <h2 class="font-mono text-[11px] uppercase tracking-[0.18em] text-pos">
        The Story <span class="text-text-muted">· books</span>
      </h2>
      <a href="/library"
         class="font-mono text-[10.5px] uppercase tracking-[0.14em]
                text-text-dim hover:text-primary">
        Library →
      </a>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 reveal-stagger">
      {volumes.map(v => (
        <article class="overflow-hidden rounded-xl border border-border-soft
                        bg-surface/40 transition-colors hover:border-border">
          <div class="aspect-[4/3] w-full bg-bg/60">
            {v.cover ? (
              <img src={v.cover} alt={v.title}
                   class="h-full w-full object-cover" loading="lazy"/>
            ) : (
              <div class="flex h-full w-full items-center justify-center
                          font-mono text-[11px] uppercase tracking-[0.18em]
                          text-text-muted">
                Coming soon
              </div>
            )}
          </div>
          <div class="p-4">
            <div class="font-mono text-[10px] uppercase tracking-[0.16em]
                        text-text-muted">
              {v.tag}
            </div>
            <h3 class="mt-1 text-[16.5px] font-semibold text-text">
              {v.title}
            </h3>
            <p class="mt-2 text-[12.5px] leading-[1.5] text-text-dim">
              {v.desc}
            </p>

            {v.buy && (
              <div class="mt-3 flex flex-wrap items-center gap-3">
                <a href={v.buy} target="_blank" rel="noopener noreferrer"
                   class="inline-flex items-center gap-1.5 rounded-lg
                          bg-primary/10 border border-primary/30
                          px-2.5 py-1 text-[11.5px] font-medium text-primary
                          transition-colors hover:bg-primary/15">
                  Get on Payhip →
                </a>
                <a href={v.preview} target="_blank" rel="noopener noreferrer"
                   class="text-[11.5px] text-text-dim hover:text-text">
                  ↓ Free preview
                </a>
              </div>
            )}

            <div class="mt-3 font-mono text-[10px] uppercase
                        tracking-[0.14em] text-text-muted">
              {v.meta}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <script>
    import "../scripts/live-stats.ts";
  </script>
</Layout>
