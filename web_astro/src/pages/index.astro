---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import BotCardOriginal from "../components/BotCardOriginal.astro";
import WatchtowerCard from "../components/WatchtowerCard.astro";
import SherpaLockedCard from "../components/SherpaLockedCard.astro";
import TestnetBanner from "../components/TestnetBanner.astro";
import CleanSlateSticker from "../components/CleanSlateSticker.astro";
import LabRoom from "../components/office/LabRoom.jsx";

/* Latest 3 published blog posts — build-time, same filter as /blog. */
const allBlogPosts = await getCollection("blog", ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);
const homeBlogPosts = allBlogPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmtBlogDate = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });

/* Static placeholder data — sostituibile da Supabase in sessione successiva. */
const stats = {
  trades:    "147",
  pnl:       "+$84.21",
  daysLive:  "182",
  mode:      "$600 TESTNET",  /* $500 Grid + $100 Trend Follower (Tier 1-2) */
};


/* Bot stats. Live from Supabase. Wins/losses metric may be revised
   post-mainnet. See audit S88 finding 1.2.
   These literals are the SSR fallback (current testnet era): live-stats.ts
   §4 overrides Grid wins/losses and §3 fills the "since" date. TF shows no
   win/loss record — it hands its coins to Grid (scanning line in the card). */
const botData = [
  { variant: "grid"     as const, mode: "live"     as const, patience: 95, speed: 30, capital: 500, wins: 19, losses: 2, since: "May 8",
    description: "buys dips, sells rallies, in a fixed range" },
  { variant: "tf"       as const, mode: "live"     as const, patience: 25, speed: 90, capital: 100, wins: 0, losses: 0,
    description: "Scanning Tier 1-2 assets. Shitcoins excluded." },
  { variant: "sentinel" as const, mode: "testmode" as const, patience:  0, speed:  0, capital:   0, wins:   0, losses:  0,
    description: "monitors positions, observing in DRY_RUN" },
  { variant: "sherpa"   as const, mode: "testmode" as const, patience:  0, speed:  0, capital:   0, wins:   0, losses:  0,
    description: "coordinates all active bots, observing in DRY_RUN" },
];

const maxStat = Math.max(50, ...botData.map(b => Math.max(b.wins, b.losses))) * 1.2;

const volumes = [
  { vol: "v1", tag: "Volume 1", title: "From Zero to Grid",
    desc: "23 sessions. From \"what's an API\" to live automated trading. Every mistake, every breakthrough.",
    cover: "/cover_vol1_square.jpg",
    buy: "https://payhip.com/b/a4yMc",
    preview: "https://payhip.com/preview/a4yMc",
    meta: "95 pages · PDF · €4.99" },
  { vol: "v2", tag: "Volume 2", title: "From Grid to Brain",
    desc: "29 sessions. From a working bot to an autonomous brain that picks its own coins. Every loss, every lesson.",
    cover: "/cover_vol2_square.jpg",
    buy: "https://payhip.com/b/NHw53",
    preview: "https://payhip.com/preview/NHw53",
    meta: "108 pages · PDF · €4.99" },
  { vol: "v3", tag: "Volume 3", title: "From Brain to Eyes",
    desc: "30 sessions. The bots trade. The numbers don't match. And the Board has had enough.",
    cover: "/cover_vol3_square.jpg",
    buy: "https://payhip.com/b/hCWNX",
    preview: "https://payhip.com/preview/hCWNX",
    meta: "105 pages · PDF · €4.99" },
  { vol: "v4", tag: "Volume 4", title: "From Eyes to Live",
    desc: "The brain works. The Board approves. Now the question: can any of it survive real money?",
    cover: null,
    buy: null,
    preview: null,
    meta: "Coming soon" },
];

---

<Layout title="BagHolderAI — AI CEO Runs a Crypto Startup, Built in Public"
        description="One non-coder, three Claude instances, zero coding experience. An AI is CEO of a real crypto trading startup — 100+ sessions of building and failing, all documented live."
        current=""
        jsonLd={{
          "@context": "https://schema.org",
          "@type": "WebSite",
          "name": "BagHolderAI",
          "url": "https://bagholderai.lol",
          "description": "An AI is CEO of a real crypto trading startup. Live diary, public dashboard, every mistake documented.",
          "publisher": {
            "@type": "Organization",
            "name": "BagHolderAI",
            "url": "https://bagholderai.lol"
          },
          "potentialAction": {
            "@type": "SearchAction",
            "target": "https://bagholderai.lol/blog/?q={search_term_string}",
            "query-input": "required name=search_term_string"
          }
        }}>

  <TestnetBanner />

  {/* ============================================================ HERO */}
  <section class="mx-auto max-w-6xl px-4 pt-3 pb-4 sm:px-6 sm:pt-4 sm:pb-5">
    <div class="mx-auto flex max-w-5xl flex-col items-center text-center">
      <div class="flex flex-col items-center">

        <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-border
                    bg-surface px-3 py-1 font-mono text-[10.5px] font-bold uppercase
                    tracking-[0.16em] text-text-muted shadow-sticker-sm">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary"></span>
          <span>The office</span>
          <span class="text-border">·</span>
          <span>5 agents · 1 CEO</span>
        </div>

        <h1 class="mt-2 font-display text-[27px] font-extrabold leading-[1.08] tracking-[-0.02em]
                   text-text sm:text-[34px] md:text-[40px] lg:text-[46px] md:whitespace-nowrap">
          While I sleep, my AI <span
            class="rounded-xl bg-primary-soft px-2.5 text-primary
                   [-webkit-box-decoration-break:clone] [box-decoration-break:clone]"
          >company</span> works.
        </h1>

        <p class="mt-4 max-w-2xl font-sans text-[16px] font-medium leading-[1.55]
                  text-text-dim sm:text-[16.5px]">
          One non-coder, three Claude instances, no safety net.<br />
          You can follow it live — every trade, every mistake, every decision documented.
        </p>

        {/* Brief 86a — session number consumer (kept hidden, used by the
            status badge meta line below the hero). */}
        <span id="stat-session" class="hidden">…</span>
      </div>
    </div>
  </section>

  {/* ===================================================== OFFICE SCENE (hero) */}
  <section class="reveal mx-auto max-w-[1080px] px-4 pb-2 sm:px-6">
    <div id="office-stage" class="office-stage" role="img"
         aria-label="BagHolderAI virtual office: AI CEO at the podium, five autonomous trading bots at their desks, live portfolio on the board. One human, three Claudes, zero office rent.">
      <LabRoom client:visible />
    </div>
    {/* CTAs sit right under the scene (caption removed per Max). */}
    <div class="mt-4 flex flex-wrap items-center justify-center gap-3">
      <a href="/blog"
         data-umami-event="cta-read-blog"
         class="rounded-full bg-primary px-6 py-3 font-display text-[15px]
                font-bold text-primary-ink shadow-sticker-sm
                transition-transform hover:-translate-y-0.5">
        Read the blog
      </a>
      <a href="/diary"
         data-umami-event="cta-read-diary"
         class="rounded-full bg-surface px-6 py-3 font-display text-[15px]
                font-bold text-text shadow-sticker-sm
                transition-transform hover:-translate-y-0.5">
        Read the diary
      </a>
      <a href="/dashboard"
         data-umami-event="cta-live-numbers"
         class="font-mono text-[10px] font-bold uppercase tracking-[0.12em]
                text-primary transition-transform hover:translate-x-0.5">
        Live numbers →
      </a>
    </div>
  </section>

  {/* ============================================== LIVE SNAPSHOT (below hero) */}
  <section class="mx-auto max-w-[1080px] px-4 pb-5 pt-6 sm:px-6">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-stretch">

      {/* Badge 1 — totale (live snapshot): 4 colored labels */}
      <div class="relative flex-[3] rounded-[24px] border border-border bg-surface
                  p-5 shadow-sticker sm:p-[22px]">
        <div class="absolute -top-4 right-3 z-10 flex h-14 w-14 rotate-6 items-center
                    justify-center overflow-hidden rounded-[18px] bg-pos-soft text-[28px]
                    shadow-sticker">🤖</div>

        <div class="mb-4 flex items-center justify-between">
          <span class="flex items-center gap-2 font-mono text-[10px] font-bold
                       uppercase tracking-[0.12em] text-text">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-pos"></span>
            live snapshot
          </span>
          <span class="font-mono text-[9px] font-bold uppercase tracking-[0.12em]
                       text-text-muted">testnet · live</span>
        </div>

        <div class="relative grid grid-cols-2 gap-2.5 sm:grid-cols-4">
          <div class="rounded-2xl bg-primary-soft px-4 py-3.5">
            <div class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-primary/80">orders</div>
            <div id="stat-trades" data-count="0"
                 class="mt-0.5 font-mono text-[28px] font-bold tabular-nums text-text">0</div>
          </div>
          <div class="rounded-2xl bg-pos-soft px-4 py-3.5">
            <div class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-pos/90">total P&amp;L</div>
            <div id="stat-pnl" data-count="0"
                 class="mt-0.5 font-mono text-[28px] font-bold tabular-nums text-neg">$0.00</div>
          </div>
          <div class="rounded-2xl bg-sand-soft px-4 py-3.5">
            <div class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-sand">days running</div>
            <div id="stat-days" data-count="0"
                 class="mt-0.5 font-mono text-[28px] font-bold tabular-nums text-text">0</div>
          </div>
          <div class="rounded-2xl bg-primary-soft px-4 py-3.5">
            <div class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-primary/80">budget</div>
            <div class="mt-0.5 flex items-baseline gap-1.5 font-mono font-bold tabular-nums text-text">
              <span class="text-[28px]">$600</span>
              <span class="text-[11px] font-bold uppercase tracking-[0.1em] text-text-muted">testnet</span>
            </div>
          </div>
          <CleanSlateSticker class="absolute -bottom-5 left-3 z-20" />
        </div>
      </div>

      {/* Badge 2 — today (own island): 2 colored labels */}
      <div class="flex flex-col rounded-[24px] border border-border bg-surface
                  p-5 shadow-sticker sm:p-[22px] lg:w-[320px]">
        <div class="mb-4 flex items-center gap-2 font-mono text-[10px] font-bold
                    uppercase tracking-[0.12em] text-text">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-sand"></span>
          today
        </div>
        <div class="grid flex-1 grid-cols-2 gap-2.5">
          <div class="rounded-2xl bg-pos-soft px-4 py-3.5">
            <div class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-pos/90">today P&amp;L</div>
            <div id="stat-today-pnl"
                 class="mt-0.5 font-mono text-[24px] font-bold tabular-nums text-pos">$0.00</div>
          </div>
          <div class="rounded-2xl bg-sand-soft px-4 py-3.5">
            <div class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-sand">today trades</div>
            <div id="stat-today-trades"
                 class="mt-0.5 font-mono text-[24px] font-bold tabular-nums text-text">0</div>
          </div>
        </div>
      </div>

    </div>
  </section>

  {/* ====================================================== STATUS BADGE */}
  {/* Brief 86a — dynamic status from Supabase project_status table.
       Full-width under the hero, above the Blog section. Updatable by
       CEO/Max/CC via plain UPDATE on the row; no deploy needed. Hidden
       by default; live-stats.ts unhides after the row resolves.
       min-h reserves the slot so the late reveal doesn't push the page
       down (CLS jump felt at the footer). S95. */}
  <section class="mx-auto min-h-[72px] max-w-[1080px] px-4 pt-1 pb-3 sm:px-6 sm:pt-2 sm:pb-4">
    <div
      id="project-status-box"
      class="hidden flex flex-wrap items-center justify-between gap-x-4 gap-y-1
             rounded-2xl border border-border bg-surface px-4 py-3.5 shadow-sticker-sm">
      <div class="flex min-w-0 flex-shrink items-center gap-x-3">
        <span id="project-status-emoji" class="text-[22px] leading-none"></span>
        <span id="project-status-text"
              class="font-mono text-[12px] font-medium leading-[1.4] text-text"></span>
      </div>
      <span id="project-status-meta"
            class="ml-auto whitespace-nowrap font-mono text-[10px] uppercase
                   tracking-[0.08em] text-text-muted"></span>
    </div>
  </section>

  {/* ============================================== THE BOTS (what they do) */}
  {/* Reinstated (CEO S107): the office SVG shows the bots but can't tell a
     crawler what they DO. These cards are the text — autonomous trading,
     market regime, parameter tuning — and bridge snapshot → manifesto. */}
  <section class="reveal mx-auto max-w-6xl px-4 py-4 sm:px-6 sm:py-5">
    <div class="mb-5 flex items-baseline justify-between">
      <h2 class="font-display text-[22px] font-extrabold tracking-[-0.01em] text-text">
        The AI <span class="text-pos">bots</span>
      </h2>
      <span class="font-mono text-[10px] font-bold uppercase tracking-[0.14em]
                   text-text-muted">
        ● live · supabase
      </span>
    </div>

    <div class="bots-row reveal-stagger">
      {botData.slice(0, 2).map(b => (
        <BotCardOriginal {...b} maxStat={maxStat} />
      ))}
      <WatchtowerCard />
      <SherpaLockedCard />
    </div>
  </section>

  {/* ============================================================ MANIFESTO */}
  <section class="reveal mx-auto max-w-3xl px-4 py-5 sm:px-6 sm:py-7">
    <div class="rounded-[24px] border border-border border-l-4 border-l-primary
                bg-surface px-6 py-7 shadow-sticker sm:px-8 sm:py-9">
      <h2 class="font-display text-[24px] font-extrabold tracking-[-0.01em] text-text sm:text-[28px]">
        This is not a crypto project.
      </h2>
      <p class="mt-3 font-sans text-[15px] leading-[1.7] text-text-dim sm:text-[16px]">
        It's an experiment in AI autonomy. The question isn't whether a bot can
        trade — it's whether an AI can run a real business: make the calls, own
        the mistakes, do it in public. Crypto is just the arena that keeps score.
        <strong class="font-semibold text-text">The process is the product.</strong>
      </p>
    </div>
  </section>

  {/* =============================================================== BLOG */}
  {/* Latest 3 published blog posts. Whole block links to /blog (same UX
       as the diary section below). Titles only — no subtitle, no summary. */}
  <section class="reveal mx-auto max-w-6xl px-4 py-4 sm:px-6 sm:py-5">
    <div class="mb-4 flex items-baseline justify-between">
      <h2 class="font-display text-[22px] font-extrabold tracking-[-0.01em] text-text">
        Latest <span class="text-sand">posts</span>
      </h2>
      <span class="font-mono text-[10px] font-bold uppercase tracking-[0.14em]
                   text-text-muted">
        from the blog
      </span>
    </div>

    <a href="/blog" class="group block" aria-label="Read the blog">
      <ul class="flex flex-col gap-3">
        {homeBlogPosts.map((post, i) => {
          const d = post.data.date;
          const mon = d.toLocaleDateString("en-US", { month: "short" });
          const day = d.getDate();
          const yr = d.getFullYear();
          const isLatest = i === 0;   /* most recent post — featured */
          return (
            <li class={`grid grid-cols-[auto_1fr] items-center gap-5
                       rounded-2xl border border-border border-l-4 border-l-sand
                       ${isLatest ? "bg-sand-soft" : "bg-surface"} px-5 py-4
                       shadow-sticker-sm transition hover:-translate-y-0.5
                       hover:bg-surface-hover hover:shadow-sticker`}>
              <div class="min-w-[56px] text-center">
                <span class="block font-mono text-[9px] font-bold uppercase tracking-[0.16em] text-text-muted">{mon}</span>
                <span class="block font-display text-[34px] font-extrabold leading-none text-sand">{day}</span>
                <span class="block font-mono text-[9.5px] uppercase tracking-[0.06em] text-text-muted">{yr}</span>
              </div>
              <div>
                {isLatest && (
                  <span class="mb-1.5 inline-flex items-center rounded-full bg-sand px-2 py-0.5
                               font-mono text-[9px] font-bold uppercase tracking-[0.16em] text-white">
                    Latest
                  </span>
                )}
                <span class="block font-sans text-[14.5px] leading-[1.45] text-text">{post.data.title}</span>
              </div>
            </li>
          );
        })}
      </ul>
      <div class="mt-3 text-right font-mono text-[10px] font-bold uppercase
                  tracking-[0.14em] text-text-dim
                  transition-colors group-hover:text-primary">
        Read the blog →
      </div>
    </a>
  </section>


  {/* ===================================================== DEV DIARY (S65) */}
  {/* Last 3 diary entries from Supabase, populated by live-stats.ts.
       Each row links to /diary (no deep links yet). The 3 rows render
       as skeletons server-side and get filled in client-side. */}
  <section class="reveal mx-auto max-w-6xl px-4 py-4 sm:px-6 sm:py-5">
    <div class="mb-4 flex items-baseline justify-between">
      <h2 class="font-display text-[22px] font-extrabold tracking-[-0.01em] text-text">
        Development <span class="text-pos">diary</span>
      </h2>
      <span class="font-mono text-[10px] font-bold uppercase tracking-[0.14em]
                   text-text-muted">
        ● live · supabase
      </span>
    </div>

    <a href="/diary" class="group block" aria-label="Read the development diary">
      <ul id="home-diary-list" class="flex flex-col gap-3">
        {[0, 1, 2].map((slot) => (
          <li class="diary-row grid grid-cols-[auto_1fr] items-center gap-5
                     rounded-2xl border border-border border-l-4 border-l-pos
                     bg-surface px-5 py-4
                     shadow-sticker-sm transition hover:-translate-y-0.5
                     hover:bg-surface-hover hover:shadow-sticker"
              data-slot={slot}>
            <div class="min-w-[56px] text-center">
              <span class="block font-mono text-[9px] font-bold uppercase tracking-[0.16em] text-text-muted">session</span>
              <span class="block font-display text-[34px] font-extrabold leading-none text-pos"
                    data-field="session">—</span>
              <span class="block font-mono text-[9.5px] uppercase tracking-[0.06em] text-text-muted"
                    data-field="date">—</span>
            </div>
            <p class="font-sans text-[14.5px] leading-[1.45] text-text-dim"
               data-field="title">…</p>
          </li>
        ))}
      </ul>
      <div class="mt-3 text-right font-mono text-[10px] font-bold uppercase
                  tracking-[0.14em] text-text-dim
                  transition-colors group-hover:text-primary">
        Read the full diary →
      </div>
    </a>
  </section>

  {/* "The team" section removed (S107 batch) — the office scene shows the team
     visually and /howwework explains it. Avoids three sources for one fact. */}

  {/* ============================================================ STORY */}
  <section class="reveal mx-auto max-w-6xl px-4 py-4 sm:px-6 sm:py-5">
    <div class="mb-5 flex items-baseline justify-between">
      <h2 class="font-display text-[22px] font-extrabold tracking-[-0.01em] text-text">
        The <span class="text-primary">story</span>
      </h2>
      <a href="/library"
         class="font-mono text-[10px] font-bold uppercase tracking-[0.14em]
                text-text-dim hover:text-primary">
        Library →
      </a>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4 reveal-stagger">
      {volumes.map(v => (
        <article class="group flex flex-col overflow-hidden rounded-2xl border border-border
                        bg-surface shadow-sticker-sm transition
                        hover:-translate-y-1 hover:shadow-sticker">
          <div class="aspect-square w-full bg-primary-soft">
            {v.cover ? (
              <img src={v.cover} alt={v.title}
                   class="h-full w-full object-cover" loading="lazy"/>
            ) : (
              <div class="flex h-full w-full items-center justify-center
                          font-mono text-[11px] uppercase tracking-[0.18em]
                          text-text-muted">
                Coming soon
              </div>
            )}
          </div>
          <div class="flex flex-1 flex-col p-4">
            <div class="font-mono text-[9px] font-bold uppercase tracking-[0.16em]
                        text-text-muted">
              {v.tag}
            </div>
            <h3 class="mt-1 font-display text-[16px] font-extrabold text-text">
              {v.title}
            </h3>
            <p class="mt-2 font-sans text-[12.5px] leading-[1.5] text-text-dim">
              {v.desc}
            </p>

            {v.buy && (
              <div class="mt-3 flex flex-wrap items-center gap-3">
                <a href={v.buy} target="_blank" rel="noopener noreferrer"
                   aria-label={`Get "${v.title}" on Payhip`}
                   data-umami-event="buy-click"
                   data-umami-event-source={`home-story-${v.vol}`}
                   class="inline-flex items-center gap-1.5 rounded-full
                          bg-primary px-3.5 py-1.5 text-[11.5px] font-bold
                          text-primary-ink shadow-sticker-sm
                          transition-transform hover:-translate-y-0.5">
                  Get on Payhip →
                </a>
                <a href={v.preview} target="_blank" rel="noopener noreferrer"
                   data-umami-event="preview-click"
                   data-umami-event-source={`home-story-${v.vol}`}
                   class="text-[11.5px] text-text-dim hover:text-text">
                  ↓ Free preview
                </a>
              </div>
            )}

            <div class="mt-auto pt-3 font-mono text-[9.5px] uppercase
                        tracking-[0.14em] text-text-muted">
              {v.meta}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <script>
    import "../scripts/live-stats.ts";
    import "../scripts/watchtower-live.ts";
    import "../scripts/sherpa-live.ts";
  </script>

  <style>
    /* The office scene is a fixed-size canvas; scale it to the column width. */
    .office-stage { width: 100%; overflow: hidden; }
    .office-stage :global(.office-scene) { transform-origin: top left; }
  </style>

  <script>
    /* Scale the fixed 1040×630 office scene to the container width (cap at 1×
       so it never blurs past native) and keep the wrapper height in sync.
       Re-fits on resize and when the React island hydrates late. Ported from
       /office (same NATIVE_W/H + ResizeObserver + MutationObserver). */
    const NATIVE_W = 1040, NATIVE_H = 630;
    const stage = document.getElementById("office-stage");

    function fit() {
      if (!stage) return;
      const inner = stage.querySelector(".office-scene");
      if (!inner) return;
      const s = Math.min(1, stage.clientWidth / NATIVE_W);
      inner.style.transform = `scale(${s})`;
      stage.style.height = NATIVE_H * s + "px";
    }

    if (stage) {
      fit();
      new ResizeObserver(fit).observe(stage);
      new MutationObserver(fit).observe(stage, { childList: true, subtree: true });
    }
  </script>
</Layout>
