---
/* Brief 70c §2 — Testnet disclaimer banner shown on home + dashboard.
   Positioned below SiteHeader, above the main content.

   S96a (2026-06-04): copy extended to state that testnet balances are
   reset periodically by Binance without notice (a monthly reset wiped
   the grid wallets and triggered the clean slate). IS_TESTNET is the
   single flag to flip when we go to mainnet — set it false (or swap the
   copy) and the banner disappears everywhere it's used. */
const IS_TESTNET = true;
---

{IS_TESTNET && (
<div class="border-y border-pos/25 bg-pos/[0.06]">
  <div class="mx-auto flex max-w-6xl flex-col gap-1 px-4 py-2.5
              sm:flex-row sm:items-baseline sm:gap-2.5 sm:px-6">
    <span class="flex flex-shrink-0 items-center gap-2 font-mono text-[11px]
                 uppercase tracking-[0.16em] text-pos">
      <span class="inline-block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-pos
                   shadow-[0_0_8px_rgba(134,239,172,0.7)]"></span>
      Live on Binance Testnet
    </span>
    <p class="text-[12.5px] leading-[1.5] text-text-dim sm:text-[13px]">
      Real orders, simulated money. Every trade runs on Binance's test
      exchange, where prices are synthetic and balances are reset periodically
      without notice. The logic is real, the dollars aren't. Yet.
    </p>
  </div>
</div>
)}
