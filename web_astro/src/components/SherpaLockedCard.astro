---
/* SHERPA — locked single card (Parameter Tuner).
   Replaces the existing Sherpa `BotCardOriginal` on the homepage with a
   richer mascot + tuner-specific stats. Reuses the same CSS shell as
   Grid/TF so it aligns with the other 3 cards. */
import SherpaMascotV2 from "./SherpaMascotV2.astro";

const SHERPA = "#ef4444";
---

<article class="bot-card sherpa-active tilt-r">
  <span class="bot-pill testmode-sherpa">TEST</span>

  <div class="bot-head">
    <span class="bot-name sherpa">SHERPA</span>
    <span class="bot-rarity">ACTIVE</span>
  </div>
  <div class="bot-subtitle">Parameter Tuner</div>

  <div class="bot-frame sherpa sherpa-frame">
    <div class="bot-scanlines"></div>
    <div class="sherpa-glow"></div>

    <div class="sherpa-mascot-wrap">
      <SherpaMascotV2 size={120} />
    </div>
  </div>

  {/* 5 stat rows — same shell as Grid/TF, compacted to 1 line each.
       BOTS: dynamic — sherpa-live.ts fetches bot_config (managed_by=grid,
       is_active=true) and rewrites the pip count + value on load. */}
  <div class="bot-stat-row">
    <span class="bot-stat-label">BOTS</span>
    <div class="bot-stat-bar-track sherpa-pip-row" id="sherpa-bots-bar">
      <div class="sherpa-bot-pip" style={`background:${SHERPA}`}></div>
      <div class="sherpa-bot-pip" style={`background:${SHERPA}`}></div>
      <div class="sherpa-bot-pip" style={`background:${SHERPA}`}></div>
    </div>
    <span class="bot-stat-value" id="sherpa-bots-count" style={`color:${SHERPA}; opacity:0.85;`}>3</span>
  </div>

  {/* PARAMS: 7 pips. Sherpa now controls 3 tuning params (buy_pct ·
       sell_pct · idle_reentry_hours) PLUS the 4 protective "board" params
       it took over in S103a (2026-06-12): stop_buy_drawdown_pct ·
       stop_buy_unlock_hours · dead_zone_hours · profit_target_pct.
       Compact pip size so all 7 fit the track. */}
  <div class="bot-stat-row">
    <span class="bot-stat-label">PARAMS</span>
    <div class="bot-stat-bar-track sherpa-pip-row compact">
      <div class="sherpa-bot-pip" style={`background:${SHERPA}`}></div>
      <div class="sherpa-bot-pip" style={`background:${SHERPA}`}></div>
      <div class="sherpa-bot-pip" style={`background:${SHERPA}`}></div>
      <div class="sherpa-bot-pip" style={`background:${SHERPA}`}></div>
      <div class="sherpa-bot-pip" style={`background:${SHERPA}`}></div>
      <div class="sherpa-bot-pip" style={`background:${SHERPA}`}></div>
      <div class="sherpa-bot-pip" style={`background:${SHERPA}`}></div>
    </div>
    <span class="bot-stat-value" style={`color:${SHERPA}; opacity:0.85;`}>7</span>
  </div>

  {/* MODE: 2 pips toggle — dry_run (sx) · live (dx). Sherpa flipped to
       LIVE on testnet at the S102b restart (2026-06-11, SHERPA_MODE=live):
       at the first tick it wrote real params to bot_config (verified in
       config_changes_log, changed_by='sherpa'). Hardcoded — no DB flag for
       the env mode; flip back if a future restart returns it to dry_run. */}
  <div class="bot-stat-row">
    <span class="bot-stat-label">MODE</span>
    <div class="bot-stat-bar-track sherpa-pip-row">
      <div class="sherpa-mode-pip"        data-mode="dry_run" style={`background:${SHERPA}`}></div>
      <div class="sherpa-mode-pip active" data-mode="live"    style={`background:${SHERPA}`}></div>
    </div>
    <span class="bot-stat-value" style={`color:${SHERPA}; opacity:0.95; min-width:54px;`}>LIVE</span>
  </div>

  {/* ADJUST: live — parameter changes Sherpa wrote in the last 7 days
       (config_changes_log, changed_by='sherpa'). sherpa-live.ts fills the
       count, lights the bar red, and un-dims the row. Falls back to the
       dim —/7d placeholder if the fetch fails. */}
  <div class="bot-stat-row dim" id="sherpa-adjust-row">
    <span class="bot-stat-label">ADJUST</span>
    <div class="bot-stat-bar-track"><div class="bot-stat-bar-fill" id="sherpa-adjust-bar" style="width:0%;"></div></div>
    <span class="bot-stat-value" id="sherpa-adjust-value">—/7d</span>
  </div>

  {/* STOP BUY: live from sherpa_proposals.proposed_stop_buy_active.
       Sherpa proposes stop_buy=true only when regime=extreme_fear (S81
       Sprint 2 slow-loop gate). 3 rows per tick (1 per coin); we OR the
       last 3. Pip lights red when ON, dim grey when OFF. */}
  <div class="bot-stat-row">
    <span class="bot-stat-label">STOP BUY</span>
    <div class="bot-stat-bar-track sherpa-pip-row">
      <div class="sherpa-stop-pip" id="sherpa-stop-pip" style={`background:${SHERPA}`}></div>
    </div>
    <span class="bot-stat-value" id="sherpa-stop-value" style="color:rgba(255,255,255,0.4); min-width:40px;">OFF</span>
  </div>

  <div class="bot-footer"><span class="arrow sherpa">▸ </span>Reads the regime. Adjusts the grid. One parameter at a time.</div>
</article>

<style is:global>
  .sherpa-frame {
    position: relative;
    overflow: hidden;
  }
  .sherpa-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at center,
                                rgba(239, 68, 68, 0.14) 0%,
                                transparent 70%);
    pointer-events: none;
  }
  .sherpa-mascot-wrap {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    filter: drop-shadow(0 0 10px rgba(239, 68, 68, 0.4));
  }
  /* Discrete-pip row, shared by BOTS + PARAMS (and any future stat that
     wants "N units" instead of a filled bar). Fixed 26px wide each, 6px
     gap, left-aligned just after the label. */
  .sherpa-pip-row {
    display: flex;
    gap: 6px;
    justify-content: flex-start;
    background: transparent;
    overflow: visible;
  }
  .sherpa-bot-pip {
    flex: 0 0 26px;
    height: 100%;
    border-radius: 2px;
    opacity: 0.75;
  }
  /* Compact variant for rows with many pips (PARAMS = 7): shrink each
     pip + tighten the gap so they all fit the track on one line. */
  .sherpa-pip-row.compact { gap: 4px; }
  .sherpa-pip-row.compact .sherpa-bot-pip { flex: 0 0 15px; }
  /* MODE pips: same geometry as bot pips, but default dim and only the
     active one fully lit (same pattern as Watchtower's REGIME pips). */
  .sherpa-mode-pip {
    flex: 0 0 26px;
    height: 100%;
    border-radius: 2px;
    opacity: 0.25;
    transition: opacity 400ms ease-out;
  }
  .sherpa-mode-pip.active { opacity: 1; }
  /* STOP BUY pip: dim by default (OFF), opacity 1 when active=true (ON) */
  .sherpa-stop-pip {
    flex: 0 0 26px;
    height: 100%;
    border-radius: 2px;
    opacity: 0.25;
    transition: opacity 400ms ease-out;
  }
  .sherpa-stop-pip.active { opacity: 1; }
</style>
