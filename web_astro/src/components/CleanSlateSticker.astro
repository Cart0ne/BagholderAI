---
/* CleanSlateSticker.astro — S96b, self-updating since S117 (2026-07-11).
   Rotated pastel "sticker" marking a testnet fresh start (Binance resets
   the test exchange periodically without notice; the counters restart).
   Positive / transparent tone — the reset is a fresh start, not a problem.

   Fully data-driven, no dates in code: the client script reads the current
   cycle from bot_config and stamps the date of that cycle's FIRST TRADE
   (Day 1, same convention as "days running" — audit A2 L1, S108). Shown
   only while the restart is actually news — FRESH_DAYS days from Day 1 —
   then it hides itself until the next reset, when it reappears with the
   new date on its own. Hidden by default: no stale date ever reaches
   non-JS crawlers, and a fetch failure just keeps it hidden (better
   nothing than wrong).

   Place inside a `relative` parent and position via the `class` prop
   (e.g. "absolute -top-3 -left-3 z-20"). Used on the homepage snapshot
   and (scaled 0.8) on both /dashboard § 3 chart cards — Astro dedupes the
   component script, so the fetch runs once per page. */
const { class: cls = "" } = Astro.props;
---
{/* -5deg (was -7): with the ✨ weighing down the left end, a steeper tilt
    made the text read as slanted differently than the pill outline. */}
<div data-clean-slate class={`hidden -rotate-[5deg] select-none rounded-full border border-neg/40
             bg-neg-soft px-3 py-[5px] shadow-sticker ${cls}`}>
  <span class="flex items-center gap-1 whitespace-nowrap font-mono text-[9.5px]
               font-bold uppercase leading-none tracking-[0.1em] text-neg">
    <span class="text-[11px] leading-none">✨</span>
    <span>Fresh start · <span data-clean-slate-date></span></span>
  </span>
</div>

<script>
  /* One fetch per page (Astro dedupes component scripts); updates every
     sticker instance found in the DOM. */
  const FRESH_DAYS = 42; // ~6 weeks: after that a "fresh start" isn't news

  const SB_URL = "https://pxdhtmqfwjwjhtcoacsn.supabase.co";
  const SB_KEY =
    "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9." +
    "eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InB4ZGh0bXFmd2p3amh0Y29hY3NuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM4NDI1OTIsImV4cCI6MjA4OTQxODU5Mn0." +
    "G76lvYWrqlM0z2RoSkU1uAglfMBKN_rXvBGOQhb4kdg";
  const headers = { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` };

  const q = async <T,>(path: string): Promise<T> => {
    const r = await fetch(`${SB_URL}/rest/v1/${path}`, { headers });
    if (!r.ok) throw new Error(String(r.status));
    return r.json() as Promise<T>;
  };

  (async () => {
    /* Current cycle straight from bot_config — no hardcoded cycle name,
       so a reset (cycle bump on the bot side) re-arms the sticker alone.
       S118: filtered to the most recently updated ACTIVE grid row — the old
       unfiltered limit=1 became NON-DETERMINISTIC the moment a second venue
       row (Kraken) exists with a different cycle. */
    const cfg = await q<{ cycle: string }[]>(
      // S119 (Fase 2a): pin the public view to venue=binance. During the Kraken
      // test/collaudo (Board decision S119) binance is the canonical public venue
      // — without the filter, activating a Kraken row would make this jump onto
      // its near-empty cycle and flash "Fresh start". All current rows are
      // venue='binance' (migration default NOT NULL), so this is a no-op today.
      "bot_config?select=cycle&managed_by=eq.grid&is_active=eq.true&venue=eq.binance&order=updated_at.desc&limit=1",
    );
    const cycle = cfg?.[0]?.cycle;
    if (!cycle) return;

    const first = await q<{ created_at: string }[]>(
      `trades?select=created_at&config_version=eq.v3&cycle=eq.${cycle}` +
        "&order=created_at.asc&limit=1",
    );
    const day1 = first?.[0]?.created_at;
    if (!day1) return;

    const ageDays = (Date.now() - new Date(day1).getTime()) / 86_400_000;
    if (ageDays < 0 || ageDays > FRESH_DAYS) return; // old news — stay hidden

    const label = new Date(day1).toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
      timeZone: "UTC",
    });
    document.querySelectorAll("[data-clean-slate]").forEach((el) => {
      const d = el.querySelector("[data-clean-slate-date]");
      if (d) d.textContent = label;
      el.classList.remove("hidden");
    });
  })().catch(() => {}); /* fetch failure → sticker simply stays hidden */
</script>
