---
import Logo from "./Logo.astro";

interface Props {
  current?: string;
}

const { current = "" } = Astro.props;

type NavLink = { href: string; label: string; key: string; umami?: string };

const links: NavLink[] = [
  { href: "/dashboard", label: "Dashboard", key: "dashboard" },
  { href: "/diary",     label: "Diary",     key: "diary"     },
  { href: "/blog",      label: "Blog",      key: "blog"      },
  { href: "/blueprint", label: "Blueprint", key: "blueprint" },
  { href: "/howwework", label: "How we work", key: "howwework" },
  { href: "/roadmap",   label: "Roadmap",   key: "roadmap"   },
  { href: "/library",   label: "Library",   key: "library", umami: "nav-library" },
];
---

<header class="sticky top-0 z-40 border-b border-border-soft/70
               bg-bg/80 backdrop-blur-md backdrop-saturate-150">

  {/* live status strip — white sticker chip on sage */}
  <div class="mx-auto flex max-w-6xl items-center justify-between
              px-4 py-2 sm:px-6">
    <span class="inline-flex items-center gap-2 rounded-full bg-surface
                 px-3 py-1.5 font-mono text-[10px] font-bold uppercase
                 tracking-[0.14em] text-text shadow-sticker-sm">
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-pos"></span>
      live · bagholderai.lol
    </span>
    <span class="hidden font-mono text-[10px] font-bold uppercase tracking-[0.14em]
                 text-text-muted sm:inline">
      binance testnet · live data
    </span>
  </div>

  {/* main bar — logo + playful pill nav */}
  <div class="mx-auto flex max-w-6xl items-center justify-between
              px-4 pb-3 pt-0.5 sm:px-6">
    <Logo size={40} />

    {/* desktop nav — pill links, active = powder-soft sticker */}
    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {links.map(l => (
        <a href={l.href}
           data-umami-event={l.umami}
           class={`rounded-full px-3 py-1.5 text-[13px] transition
                   ${l.key === current
                     ? "bg-surface text-text font-semibold shadow-sticker-sm"
                     : "font-medium text-text-dim hover:bg-surface hover:text-text"}`}>
          {l.label}
        </a>
      ))}
    </nav>

    {/* mobile: compact menu trigger (link list collapses) */}
    <details class="relative md:hidden">
      <summary class="list-none cursor-pointer rounded-full border border-border
                      bg-surface px-4 py-1.5 text-[12px] font-medium text-text
                      shadow-sticker-sm [&::-webkit-details-marker]:hidden">
        Menu
      </summary>
      <div class="absolute right-0 mt-2 min-w-[190px] rounded-2xl
                  border border-border bg-surface shadow-sticker
                  py-2">
        {links.map(l => (
          <a href={l.href}
             data-umami-event={l.umami}
             class={`block px-4 py-2 text-[14px]
                     ${l.key === current
                       ? "bg-surface-hover font-semibold text-text"
                       : "text-text hover:bg-surface-hover"}`}>
            {l.label}
          </a>
        ))}
      </div>
    </details>
  </div>
</header>
