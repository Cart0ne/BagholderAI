---
import Logo from "./Logo.astro";

interface Props {
  current?: string;
}

const { current = "" } = Astro.props;

type NavLink = { href: string; label: string; key: string; umami?: string };

/* Nav structure (S106a): product pages stay top-level; the four "meta"
   pages that explain the project collapse into the "Under the hood ▾"
   dropdown. News is intentionally NOT here yet — /news ships after the
   barometer verdict (~23 Jun); adding it now would be a dead link. */
const primary: NavLink[] = [
  { href: "/dashboard", label: "Dashboard", key: "dashboard" },
  { href: "/diary",     label: "Diary",     key: "diary"     },
  { href: "/blog",      label: "Blog",      key: "blog"      },
];

const underTheHood: NavLink[] = [
  { href: "/howwework", label: "How we work",    key: "howwework" },
  { href: "/blueprint", label: "Blueprint",      key: "blueprint" },
  { href: "/roadmap",   label: "Roadmap",        key: "roadmap"   },
  { href: "/income",    label: "The experiment", key: "income"    },
];

const trailing: NavLink[] = [
  { href: "/library", label: "Library", key: "library", umami: "nav-library" },
];

/* Highlight the dropdown trigger when we're on one of its child pages. */
const hoodActive = underTheHood.some((l) => l.key === current);
---

<header class="sticky top-0 z-40 border-b border-border-soft/70
               bg-bg/80 backdrop-blur-md backdrop-saturate-150">

  {/* live status strip — white sticker chip on sage */}
  <div class="mx-auto flex max-w-6xl items-center justify-between
              px-4 py-2 sm:px-6">
    <span class="inline-flex items-center gap-2 rounded-full bg-surface
                 px-3 py-1.5 font-mono text-[10px] font-bold uppercase
                 tracking-[0.14em] text-text shadow-sticker-sm">
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-pos"></span>
      live · bagholderai.lol
    </span>
    <span class="hidden font-mono text-[10px] font-bold uppercase tracking-[0.14em]
                 text-text-muted sm:inline">
      binance testnet · live data
    </span>
  </div>

  {/* main bar — logo + playful pill nav */}
  <div class="mx-auto flex max-w-6xl items-center justify-between
              px-4 pb-3 pt-0.5 sm:px-6">
    <Logo size={40} />

    {/* desktop nav — pill links, active = powder-soft sticker */}
    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {primary.map(l => (
        <a href={l.href}
           data-umami-event={l.umami}
           class={`rounded-full px-3 py-1.5 text-[13px] transition
                   ${l.key === current
                     ? "bg-surface text-text font-semibold shadow-sticker-sm"
                     : "font-medium text-text-dim hover:bg-surface hover:text-text"}`}>
          {l.label}
        </a>
      ))}

      {/* "Under the hood" dropdown — opens on click (native <details>),
          closes on click-outside / Esc (nav-dropdown.ts). */}
      <details class="nav-dropdown relative">
        <summary class={`list-none cursor-pointer inline-flex items-center gap-1.5
                         rounded-full px-3 py-1.5 text-[13px] transition
                         [&::-webkit-details-marker]:hidden
                         ${hoodActive
                           ? "bg-surface text-text font-semibold shadow-sticker-sm"
                           : "font-medium text-text-dim hover:bg-surface hover:text-text"}`}>
          Under the hood
          <svg class="nav-caret h-2.5 w-2.5 transition-transform" viewBox="0 0 10 6"
               fill="none" aria-hidden="true">
            <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5"
                  stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </summary>
        <div class="absolute left-0 z-50 mt-2 min-w-[180px] rounded-2xl
                    border border-border bg-surface shadow-sticker py-2">
          {underTheHood.map(l => (
            <a href={l.href}
               class={`block px-4 py-2 text-[14px]
                       ${l.key === current
                         ? "bg-surface-hover font-semibold text-text"
                         : "text-text hover:bg-surface-hover"}`}>
              {l.label}
            </a>
          ))}
        </div>
      </details>

      {trailing.map(l => (
        <a href={l.href}
           data-umami-event={l.umami}
           class={`rounded-full px-3 py-1.5 text-[13px] transition
                   ${l.key === current
                     ? "bg-surface text-text font-semibold shadow-sticker-sm"
                     : "font-medium text-text-dim hover:bg-surface hover:text-text"}`}>
          {l.label}
        </a>
      ))}
    </nav>

    {/* mobile: compact menu trigger (link list collapses) */}
    <details class="nav-dropdown relative md:hidden">
      <summary class="list-none cursor-pointer rounded-full border border-border
                      bg-surface px-4 py-1.5 text-[12px] font-medium text-text
                      shadow-sticker-sm [&::-webkit-details-marker]:hidden">
        Menu
      </summary>
      <div class="absolute right-0 z-50 mt-2 min-w-[210px] rounded-2xl
                  border border-border bg-surface shadow-sticker py-2">
        {primary.map(l => (
          <a href={l.href}
             data-umami-event={l.umami}
             class={`block px-4 py-2 text-[14px]
                     ${l.key === current
                       ? "bg-surface-hover font-semibold text-text"
                       : "text-text hover:bg-surface-hover"}`}>
            {l.label}
          </a>
        ))}

        {/* Under the hood — grouped, indented sub-links (no nested details) */}
        <div class="mt-1 border-t border-border-soft pt-1.5">
          <span class="block px-4 pb-1 font-mono text-[10px] font-bold uppercase
                       tracking-[0.14em] text-text-muted">Under the hood</span>
          {underTheHood.map(l => (
            <a href={l.href}
               class={`block px-4 py-2 pl-6 text-[14px]
                       ${l.key === current
                         ? "bg-surface-hover font-semibold text-text"
                         : "text-text hover:bg-surface-hover"}`}>
              {l.label}
            </a>
          ))}
        </div>

        <div class="mt-1 border-t border-border-soft pt-1.5">
          {trailing.map(l => (
            <a href={l.href}
               data-umami-event={l.umami}
               class={`block px-4 py-2 text-[14px]
                       ${l.key === current
                         ? "bg-surface-hover font-semibold text-text"
                         : "text-text hover:bg-surface-hover"}`}>
              {l.label}
            </a>
          ))}
        </div>
      </div>
    </details>
  </div>

  {/* Caret flips when the dropdown is open. Plain CSS (not the Tailwind
      `open:` variant) so it works regardless of Tailwind version. */}
  <style>
    .nav-dropdown[open] .nav-caret { transform: rotate(180deg); }
  </style>

  {/* Close any open <details.nav-dropdown> on outside-click or Esc.
      <details> opens natively on summary click; clicking the summary
      bubbles here but is contained, so it stays open. */}
  <script>
    const closeAll = (except?: EventTarget | null) => {
      document.querySelectorAll("details.nav-dropdown[open]").forEach((d) => {
        if (!except || !(d as HTMLElement).contains(except as Node)) {
          d.removeAttribute("open");
        }
      });
    };
    document.addEventListener("click", (e) => closeAll(e.target));
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeAll();
    });
  </script>
</header>
