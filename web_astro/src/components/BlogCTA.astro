---
/* ============================================================
   BlogCTA — appears at the bottom of every blog post.

   - If `volume` is provided and known (1, 2 or 3), shows a
     volume-specific CTA pointing to the matching Payhip page.
   - Otherwise (`type: lesson` cross-volume, or no volume set),
     shows a generic CTA listing all three volumes side-by-side.
   ============================================================ */

interface Props {
  volume?: number;
}

const VOLUMES = {
  1: {
    title: "From Zero to Grid",
    sessions: "23 sessions",
    url: "https://payhip.com/b/a4yMc",
  },
  2: {
    title: "From Grid to Brain",
    sessions: "29 sessions",
    url: "https://payhip.com/b/NHw53",
  },
  3: {
    title: "From Brain to Eyes",
    sessions: "30 sessions",
    url: "https://payhip.com/b/hCWNX",
  },
} as const;

const { volume } = Astro.props;
const v = volume === 1 || volume === 2 || volume === 3 ? VOLUMES[volume] : null;

/* Per-volume accent, matching the /library spines: V1 sage, V2 teal,
   V3 lilla. Full literal class strings so Tailwind keeps them at build. */
const VOL_ACCENT = {
  1: { eyebrow: "text-pos", card: "border-pos/30 bg-pos/10", btn: "bg-pos" },
  2: { eyebrow: "text-neu", card: "border-neu/30 bg-neu/10", btn: "bg-neu" },
  3: { eyebrow: "text-cc",  card: "border-cc/30 bg-cc/10",   btn: "bg-cc"  },
} as const;
const accent = v ? VOL_ACCENT[volume as 1 | 2 | 3] : null;
---

{v ? (
  <div class:list={["mt-10 rounded-2xl border px-5 py-5 shadow-sticker-sm sm:px-6", accent.card]}>
    <div class:list={["font-mono text-[10px] uppercase tracking-[0.18em] mb-2", accent.eyebrow]}>
      From the diary
    </div>
    <div class="font-display text-[16px] font-extrabold text-text">
      This story is from Volume {volume} — {v.title}.
    </div>
    <p class="mt-2 text-[14px] leading-[1.6] text-text-dim">
      The full diary with all {v.sessions} is available on Payhip for €4.99.
    </p>
    <a href={v.url}
       data-umami-event="buy-click"
       data-umami-event-source={`blog-cta-v${volume}`}
       class:list={["mt-4 inline-flex items-center gap-2 rounded-full px-5 py-2.5",
                    "font-mono text-[12px] font-semibold text-white shadow-sticker-sm",
                    "transition hover:-translate-y-0.5 hover:shadow-sticker", accent.btn]}>
      → Read Volume {volume} on Payhip
    </a>
  </div>
) : (
  <div class="mt-10 rounded-2xl border border-border bg-surface px-5 py-5 shadow-sticker-sm sm:px-6">
    <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted mb-2">
      If this resonated
    </div>
    <div class="font-display text-[16px] font-extrabold text-text">
      The full diary lives in three volumes on Payhip.
    </div>
    <div class="mt-3 flex flex-col gap-2 sm:flex-row sm:gap-3 sm:flex-wrap">
      <a href="https://payhip.com/b/a4yMc"
         data-umami-event="buy-click"
         data-umami-event-source="blog-cta-fallback-v1"
         class="inline-flex items-center gap-2 rounded-full bg-pos
                px-4 py-2 font-mono text-[12px] font-semibold text-white shadow-sticker-sm
                transition hover:-translate-y-0.5 hover:shadow-sticker">
        V1 · From Zero to Grid · €4.99
      </a>
      <a href="https://payhip.com/b/NHw53"
         data-umami-event="buy-click"
         data-umami-event-source="blog-cta-fallback-v2"
         class="inline-flex items-center gap-2 rounded-full bg-neu
                px-4 py-2 font-mono text-[12px] font-semibold text-white shadow-sticker-sm
                transition hover:-translate-y-0.5 hover:shadow-sticker">
        V2 · From Grid to Brain · €4.99
      </a>
      <a href="https://payhip.com/b/hCWNX"
         data-umami-event="buy-click"
         data-umami-event-source="blog-cta-fallback-v3"
         class="inline-flex items-center gap-2 rounded-full bg-cc
                px-4 py-2 font-mono text-[12px] font-semibold text-white shadow-sticker-sm
                transition hover:-translate-y-0.5 hover:shadow-sticker">
        V3 · From Brain to Eyes · €4.99
      </a>
    </div>
  </div>
)}
