---
/* ============================================================
   BlogCTA — appears at the bottom of every blog post.

   - If `volume` is provided and known (1 or 2), shows a
     volume-specific CTA pointing to the matching Payhip page.
   - Otherwise (`type: lesson` cross-volume, or no volume set),
     shows a generic CTA listing both volumes side-by-side.
   ============================================================ */

interface Props {
  volume?: number;
}

const VOLUMES = {
  1: {
    title: "From Zero to Grid",
    sessions: "23 sessions",
    url: "https://payhip.com/b/a4yMc",
  },
  2: {
    title: "From Grid to Brain",
    sessions: "29 sessions",
    url: "https://payhip.com/b/NHw53",
  },
} as const;

const { volume } = Astro.props;
const v = volume === 1 || volume === 2 ? VOLUMES[volume] : null;
---

{v ? (
  <div class="mt-10 rounded-lg border border-pos/30 bg-pos/5 px-5 py-5 sm:px-6">
    <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-pos mb-2">
      From the diary
    </div>
    <div class="text-[15.5px] text-text font-medium">
      This story is from Volume {volume} — {v.title}.
    </div>
    <p class="mt-2 text-[14px] leading-[1.6] text-text-dim">
      The full diary with all {v.sessions} is available on Payhip for €4.99.
    </p>
    <a href={v.url}
       class="mt-3 inline-flex items-center gap-2 rounded-md border border-pos/40
              bg-pos/10 px-3 py-1.5 font-mono text-[12px] text-pos
              hover:bg-pos/20 hover:border-pos/60 transition-colors">
      → Read Volume {volume} on Payhip
    </a>
  </div>
) : (
  <div class="mt-10 rounded-lg border border-border bg-surface px-5 py-5 sm:px-6">
    <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-text-muted mb-2">
      If this resonated
    </div>
    <div class="text-[15.5px] text-text font-medium">
      The full diary lives in two volumes on Payhip.
    </div>
    <div class="mt-3 flex flex-col gap-2 sm:flex-row sm:gap-3">
      <a href="https://payhip.com/b/a4yMc"
         class="inline-flex items-center gap-2 rounded-md border border-border-soft
                bg-bg/40 px-3 py-1.5 font-mono text-[12px] text-text-dim
                hover:text-text hover:border-text-muted transition-colors">
        V1 · From Zero to Grid · €4.99
      </a>
      <a href="https://payhip.com/b/NHw53"
         class="inline-flex items-center gap-2 rounded-md border border-border-soft
                bg-bg/40 px-3 py-1.5 font-mono text-[12px] text-text-dim
                hover:text-text hover:border-text-muted transition-colors">
        V2 · From Grid to Brain · €4.99
      </a>
    </div>
  </div>
)}
