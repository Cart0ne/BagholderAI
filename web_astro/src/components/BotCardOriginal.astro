---
/* 1:1 port of the original bot-card from web/index.html.
   CSS and HTML structure preserved verbatim — only the surrounding
   context (Layout, palette of NON-bot elements) is from the new site.
   This file is intentionally NOT refactored to "Astro idiomatic" —
   keeping it identical to the legacy markup is the whole point. */

import BotMascot from "./BotMascot.astro";
import MixerSVG  from "./MixerSVG.astro";
import MugSVG    from "./MugSVG.astro";
import RadarSVG  from "./RadarSVG.astro";

type Mode = "live" | "testmode" | "paused";

interface Props {
  variant: "grid" | "tf" | "sentinel" | "sherpa";
  mode?: Mode;
  patience: number;
  speed: number;
  capital: number;
  wins: number;
  losses: number;
  maxStat?: number;
  description: string;
  recoveryHref?: string;
}

const {
  variant,
  mode = (variant === "sentinel" || variant === "sherpa") ? "testmode" : "live",
  patience, speed, capital, wins, losses,
  maxStat = 200,
  description,
  recoveryHref,
} = Astro.props;

const meta = {
  grid:     { name: "GRID BOT",       sub: "Methodical Trader", color: "#22c55e", build: "stocky" as const, expression: "focused" as const,  uid: "gridmain",     tilt: "tilt-l" as const, frameKind: "grid"     },
  tf:       { name: "TREND FOLLOWER", sub: "Market Scanner",    color: "#f59e0b", build: "lanky"  as const, expression: "scanning" as const, uid: "tfmain",       tilt: "tilt-r" as const, frameKind: "tf"       },
  sentinel: { name: "SENTINEL",       sub: "Risk Watcher",      color: "#3b82f6", build: "stocky" as const, expression: "focused" as const,  uid: "sentinelmain", tilt: "tilt-l" as const, frameKind: "sentinel" },
  sherpa:   { name: "SHERPA",         sub: "Bot Coordinator",   color: "#ef4444", build: "lanky"  as const, expression: "curious" as const,  uid: "sherpamain",   tilt: "tilt-r" as const, frameKind: "sherpa"   },
}[variant];

const labels: Record<Mode, { pill: string; rarity: string }> = {
  live:     { pill: "LIVE",      rarity: "ACTIVE · v3"  },
  testmode: { pill: "TEST MODE", rarity: "DRY_RUN · v3" },
  paused:   { pill: "ON HOLD",   rarity: "PAUSED · v3"  },
};
const modeLabel = labels[mode];

/* Visual state:
   - dim   = silhouette + "?" (Sentinel/Sherpa, mode=testmode)
   - paused = full frame but stats panel replaced by recovery link (TF) */
const dim    = mode === "testmode";
const paused = mode === "paused";

const pct = (val: number, max: number) =>
  max ? Math.min(100, (val / max) * 100) : 0;

const RED = "#ef4444";

const stats = [
  { label: "PATIENCE", value: patience, color: meta.color, max: 100 },
  { label: "SPEED",    value: speed,    color: meta.color, max: 100 },
  { label: "CAPITAL",  value: capital,  color: meta.color, max: 500, format: "capital" as const },
  { label: "WINS",     value: wins,     color: meta.color, max: maxStat },
  { label: "LOSSES",   value: losses,   color: RED,        max: maxStat },
];

/* Class composition — brief 70c §7: pill + cornice colorate per-bot anche
   in testmode/paused (prima erano grey "LOCKED"). Mantengo `dim` per
   Sentinel/Sherpa (silhouette + ?) ma con cornice colorata sopra. */
const cardClass = [
  "bot-card",
  mode === "live"     && meta.frameKind === "grid" ? "grid-active"        :
  mode === "live"     && meta.frameKind === "tf"   ? "tf-active"          :
  mode === "testmode" && variant === "sentinel"    ? "sentinel-active dim":
  mode === "testmode" && variant === "sherpa"      ? "sherpa-active dim"  :
  mode === "paused"   && variant === "tf"          ? "tf-active"          :
                                                      "dim",
  meta.tilt,
].join(" ");

const pillClass = [
  "bot-pill",
  mode === "live"     && meta.frameKind === "grid" ? "live-grid"         :
  mode === "live"     && meta.frameKind === "tf"   ? "live-tf"           :
  mode === "testmode" && variant === "sentinel"    ? "testmode-sentinel" :
  mode === "testmode" && variant === "sherpa"      ? "testmode-sherpa"   :
  mode === "paused"   && variant === "tf"          ? "paused-tf"         :
                                                      "soon",
].join(" ");
---

<article class={cardClass}>
  <span class={pillClass}>{modeLabel.pill}</span>

  <div class="bot-head">
    <span class={`bot-name ${meta.frameKind}`}>{meta.name}</span>
    <span class="bot-rarity">{modeLabel.rarity}</span>
  </div>
  <div class="bot-subtitle">{meta.sub}</div>

  <div class={`bot-frame ${meta.frameKind}`}>
    <div class="bot-scanlines"></div>

    {/* Grid: mixer (BTC/ETH/SOL faders) at top + mascot bottom-left + mug bottom-right */}
    {variant === "grid" && (
      <>
        <MixerSVG color={meta.color} />
        <div class="bot-mascot-grid">
          <BotMascot color={meta.color} accent={meta.color}
                     build={meta.build} expression={meta.expression}
                     size={108} uid={meta.uid}/>
        </div>
        <div class="bot-mug-wrap"><MugSVG /></div>
      </>
    )}

    {/* TF: radar background + mascot centered with binoculars */}
    {variant === "tf" && (
      <>
        <RadarSVG color={meta.color} />
        <div class="bot-mascot-wrap">
          <BotMascot color={meta.color} accent={meta.color}
                     build={meta.build} expression={meta.expression}
                     carrying="binoculars"
                     size={130} uid={meta.uid}/>
        </div>
      </>
    )}

    {/* Sentinel/Sherpa: question mark + dim silhouette */}
    {dim && (
      <>
        <div class={`bot-question ${meta.frameKind}`}>?</div>
        <div class:list={["bot-mascot-wrap", "bot-silhouette-glow", meta.frameKind]}>
          <BotMascot color="#0a0e17" accent={meta.color}
                     build={meta.build} expression={meta.expression}
                     size={130} uid={meta.uid}/>
        </div>
        <div class={`bot-silhouette-tint ${meta.frameKind}`}></div>
      </>
    )}
  </div>

  {paused ? (
    <div class="bot-paused-body">
      <div class="bot-paused-icon">🩺</div>
      <p class="bot-paused-text">{description}</p>
      {recoveryHref && (
        <a href={recoveryHref} class={`bot-paused-link ${meta.frameKind}`}>
          → see the doctor
        </a>
      )}
    </div>
  ) : (
    <div>
      {stats.map(s => {
        const display = dim ? "0" : (s.format === "capital" ? `$${s.value}` : `${s.value}`);
        const fillW = pct(s.value, s.max);
        /* IDs only on live bots' wins/losses — those get hot-swapped from
           Supabase by /scripts/live-stats.ts. */
        const liveKey =
          mode === "live" &&
          (variant === "grid" || variant === "tf") &&
          (s.label === "WINS" || s.label === "LOSSES")
            ? `bot-${variant}-${s.label.toLowerCase()}`
            : null;
        return (
          <div class:list={["bot-stat-row", dim && "dim"]}>
            <span class="bot-stat-label">{s.label}</span>
            <div class="bot-stat-bar-track">
              <div
                id={liveKey ? `${liveKey}-bar` : undefined}
                class="bot-stat-bar-fill"
                style={`width:${fillW}%; background:${dim ? 'rgba(255,255,255,0.15)' : s.color};`}
              ></div>
            </div>
            <span
              id={liveKey || undefined}
              class="bot-stat-value"
              style={`color:${dim ? 'rgba(255,255,255,0.35)' : s.color};`}
            >{display}</span>
          </div>
        );
      })}
    </div>
  )}

  {!paused && (
    <div class="bot-footer"><span class={`arrow ${meta.frameKind}`}>▸ </span>{description}</div>
  )}
</article>

<style>
  /* TF paused-mode body — replaces the stats grid + footer with a
     compact recovery link. Coherent with the dashboard's TfDoctor SVG. */
  .bot-paused-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.55rem;
    padding: 0.5rem 0.75rem 0.25rem;
    text-align: center;
  }
  .bot-paused-icon { font-size: 1.4rem; line-height: 1; }
  .bot-paused-text {
    font-size: 12px;
    line-height: 1.5;
    color: rgba(245, 245, 245, 0.7);
    max-width: 90%;
  }
  .bot-paused-link {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #f59e0b;
    text-decoration: none;
    border-bottom: 1px dashed rgba(245, 158, 11, 0.4);
    padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s;
  }
  .bot-paused-link:hover {
    color: #fcd34d;
    border-color: #fcd34d;
  }
</style>
