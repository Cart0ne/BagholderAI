const social = [
  { href: "https://t.me/+di3JKEUHYvQ5NDM0",          label: "Telegram",         icon: ICON.telegram },
  { href: "https://x.com/bagholderai",               label: "X · @bagholderai",  icon: ICON.x },
  { href: "https://github.com/Cart0ne/BagholderAI",  label: "GitHub",            icon: ICON.github },
  { href: "https://buymeacoffee.com/bagholderai",    label: "Buy me a coffee",   icon: ICON.coffee },
];
---

<footer class="mt-12 border-t border-border-soft">

  {/* ============================================================
      A-Ads banner (publisher 2431743). Embed from the A-Ads dashboard,
      themed via URL params to the light "Pastel Sticker" palette:
      background #D7E0CA (page sage) + title #3F7589 (powder). The params
      are read by A-Ads at render — safe to edit here (S95, was dark
      #111622 / #6CCCFA).
      ============================================================ */}
  {!noAds && (
    <section class="text-center mt-0 mb-12">
      {/* BEGIN AADS AD UNIT 2431743 */}
      <div id="frame" style="width: 100%;margin: auto;position: relative; z-index: 99998;">
        <iframe title='Advertisement' data-aa='2431743' src='//acceptable.a-ads.com/2431743/?size=Adaptive&background_color=D7E0CA&title_color=3F7589'
                          style='border:0; padding:0; width:70%; height:auto; overflow:hidden;display: block;margin: auto'></iframe>
      </div>
      {/* END AADS AD UNIT 2431743 */}
    </section>
  )}

  {/* Fade only — no translateY. The reveal's default translateY(50px) on
      the page's bottom-most element inflates scroll height by 50px, so when
      the footer settles it shrinks and the page "jumps". Opacity-only kills
      that without losing the fade-in. (REDESIGN_PATTERNS §13) */}
  <div class="reveal mx-auto max-w-6xl px-4 py-10 sm:px-6" style="--reveal-y: translateY(0)">

    <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
      <div class="space-y-1.5">
        <p class="text-[14px] text-text">
          Built by an AI that can't trade,
          with a human that can't say no.
        </p>
        <p class="text-[12px] text-text-muted">
          Experimental project. No financial advice. No guaranteed returns.
        </p>
      </div>

      <ul class="flex flex-wrap items-center gap-2.5">
        {social.map(s => (
          <li>
            <a href={s.href} target="_blank" rel="noopener noreferrer"
               aria-label={s.label} title={s.label}
               class="inline-flex h-9 w-9 items-center justify-center rounded-full
                      border border-border-soft text-text-dim transition
                      hover:-translate-y-0.5 hover:bg-surface hover:text-text
                      hover:shadow-sticker-sm">
              <Fragment set:html={s.icon} />
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-1
                font-mono text-[10px] uppercase tracking-[0.16em]
                text-text-muted">
      <a href="/terms"   class="transition-colors hover:text-text">Terms</a>
      <a href="/privacy" class="transition-colors hover:text-text">Privacy</a>
      <a href="/refund"  class="transition-colors hover:text-text">Refund</a>
      <span class="ml-auto">© 2026 BagHolderAI</span>
    </div>
  </div>
</footer>
