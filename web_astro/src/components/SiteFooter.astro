---
interface Props {
  /* Pages that opt out of the A-Ads banner (currently: legal pages
     /terms, /privacy, /refund — A-Ads policy frowns on monetizing
     legal content, and the visual is wrong on a contract-style page). */
  noAds?: boolean;
}
const { noAds = false } = Astro.props;

