---
/* NewsKeeper mascot — locked/dim variant.
   Paths extracted verbatim from `team-cards-locked-2.svg` (Claude Design,
   2026-05-23). Palette: full-color scene values (S107 unification):
       #5c2f88 (dark) · #a855f7 (mid) · #c288f9 (light).
   Original full-color rendering lives in `bots-newskeeper.jsx`
   (kept as reference for future variants: read/flash/brief/stack).
   ViewBox 200×260 (same family as TF/Sherpa, "lanky" build). */
interface Props { size?: number; }
const { size = 120 } = Astro.props;
---

<svg width={size} height={size * (260 / 200)} viewBox="0 0 200 260">
  <defs>
    <linearGradient id="newskeeper-body" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#c288f9"></stop>
      <stop offset="0.45" stop-color="#a855f7"></stop>
      <stop offset="1" stop-color="#5c2f88"></stop>
    </linearGradient>
    <linearGradient id="newskeeper-flap" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#cb9afa"></stop>
      <stop offset="1" stop-color="#af63f8"></stop>
    </linearGradient>
    <linearGradient id="newskeeper-pock" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="rgba(0,0,0,0.5)"></stop>
      <stop offset="1" stop-color="rgba(0,0,0,0.18)"></stop>
    </linearGradient>
  </defs>

  {/* Body shell (legs, feet, shoulder loops, gradient body, flap) */}
  <g>
    <ellipse cx="100" cy="228" rx="46" ry="4" fill="rgba(0,0,0,0.45)"></ellipse>
    <rect x="68" y="182" width="14" height="38" rx="3" fill="#5c2f88"></rect>
    <rect x="118" y="182" width="14" height="38" rx="3" fill="#5c2f88"></rect>
    <rect x="69" y="184" width="3" height="32" rx="1.5" fill="#c288f9" opacity="0.4"></rect>
    <rect x="119" y="184" width="3" height="32" rx="1.5" fill="#c288f9" opacity="0.4"></rect>
    <g>
      <ellipse cx="75" cy="224" rx="14" ry="5" fill="#0a0e17"></ellipse>
      <ellipse cx="75" cy="223" rx="14" ry="3" fill="#1a2030"></ellipse>
      <ellipse cx="72" cy="222" rx="6" ry="1.5" fill="rgba(255,255,255,0.25)"></ellipse>
      <line x1="67" y1="221" x2="83" y2="221" stroke="#a855f7" stroke-width="1.5"></line>
    </g>
    <g>
      <ellipse cx="125" cy="224" rx="14" ry="5" fill="#0a0e17"></ellipse>
      <ellipse cx="125" cy="223" rx="14" ry="3" fill="#1a2030"></ellipse>
      <ellipse cx="122" cy="222" rx="6" ry="1.5" fill="rgba(255,255,255,0.25)"></ellipse>
      <line x1="117" y1="221" x2="133" y2="221" stroke="#a855f7" stroke-width="1.5"></line>
    </g>
    <ellipse cx="76" cy="52" rx="9" ry="12" fill="none" stroke="#5c2f88" stroke-width="6" stroke-linecap="round"></ellipse>
    <ellipse cx="124" cy="52" rx="9" ry="12" fill="none" stroke="#5c2f88" stroke-width="6" stroke-linecap="round"></ellipse>
    <ellipse cx="74" cy="50" rx="10" ry="13" fill="none" stroke="#c288f9" stroke-width="1.5" stroke-linecap="round" opacity="0.5" stroke-dasharray="3 30"></ellipse>
    <ellipse cx="122" cy="50" rx="10" ry="13" fill="none" stroke="#c288f9" stroke-width="1.5" stroke-linecap="round" opacity="0.5" stroke-dasharray="3 30"></ellipse>
    <path d="M 56 62 Q 56 47 72 47 L 128 47 Q 144 47 144 62 L 144 182 Q 144 196 130 196 L 70 196 Q 56 196 56 182 Z" fill="url(#newskeeper-body)"></path>
    <path d="M 144 67 L 144 177" stroke="rgba(255,255,255,0.18)" stroke-width="1.5"></path>
    <line x1="68" y1="102" x2="68" y2="182" stroke="#5c2f88" stroke-width="2" opacity="0.45"></line>
    <line x1="132" y1="102" x2="132" y2="182" stroke="#5c2f88" stroke-width="2" opacity="0.45"></line>
    <path d="M 56 62 Q 56 47 72 47 L 128 47 Q 144 47 144 62 L 144 92 Q 144 100 134 100 L 66 100 Q 56 100 56 92 Z" fill="url(#newskeeper-flap)"></path>
    <ellipse cx="82" cy="57" rx="22" ry="6" fill="rgba(255,255,255,0.25)"></ellipse>
  </g>

  {/* Buckle on flap */}
  <g>
    <rect x="92" y="84" width="16" height="10" rx="2" fill="#5c2f88"></rect>
    <rect x="92" y="84" width="16" height="3" rx="1" fill="rgba(255,255,255,0.3)"></rect>
    <rect x="95" y="87" width="10" height="4" rx="1" fill="#af63f8" opacity="0.5"></rect>
  </g>

  {/* Eyes — open behind the glasses */}
  <g>
    <ellipse cx="83" cy="116" rx="6.5" ry="6.5" fill="#fff" stroke="#06090f" stroke-width="2"></ellipse>
    <ellipse cx="117" cy="116" rx="6.5" ry="6.5" fill="#fff" stroke="#06090f" stroke-width="2"></ellipse>
    <circle cx="86" cy="117" r="3" fill="#06090f"></circle>
    <circle cx="120" cy="117" r="3" fill="#06090f"></circle>
  </g>

  {/* Reader glasses + temple tips + highlight */}
  <g>
    <circle cx="83" cy="116" r="9.5" fill="none" stroke="#06090f" stroke-width="1.7"></circle>
    <circle cx="117" cy="116" r="9.5" fill="none" stroke="#06090f" stroke-width="1.7"></circle>
    <line x1="92.5" y1="116" x2="107.5" y2="116" stroke="#06090f" stroke-width="1.7"></line>
    <path d="M 73.5 116 Q 70 113 71 110" stroke="#06090f" stroke-width="1.4" fill="none" stroke-linecap="round"></path>
    <path d="M 126.5 116 Q 130 113 129 110" stroke="#06090f" stroke-width="1.4" fill="none" stroke-linecap="round"></path>
    <path d="M 78 111 Q 75 113 76 115" stroke="rgba(255,255,255,0.55)" stroke-width="1.1" fill="none" stroke-linecap="round"></path>
    <path d="M 112 111 Q 109 113 110 115" stroke="rgba(255,255,255,0.55)" stroke-width="1.1" fill="none" stroke-linecap="round"></path>
  </g>

  {/* Open newspaper "THE TAPE" held in front (signature prop) */}
  <g>
    <rect x="18" y="132" width="164" height="78" fill="#f4ede0" stroke="#0a0e17" stroke-width="1.5" rx="1"></rect>
    <path d="M 18 136 Q 28 129 40 134" stroke="#0a0e17" stroke-width="0.8" fill="none" opacity="0.5"></path>
    <path d="M 160 134 Q 172 129 182 136" stroke="#0a0e17" stroke-width="0.8" fill="none" opacity="0.5"></path>
    <line x1="100" y1="134" x2="100" y2="208" stroke="#0a0e17" stroke-width="0.8" opacity="0.4"></line>
    <text x="100" y="146" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-size="12" font-weight="900" fill="#0a0e17" letter-spacing="0.5">THE TAPE</text>
    <line x1="24" y1="149" x2="176" y2="149" stroke="#0a0e17" stroke-width="0.7"></line>
    <text x="26" y="155" font-family="ui-monospace, monospace" font-size="3.5" fill="#0a0e17" opacity="0.7">DAILY · WIRE · DISPATCH</text>
    <text x="174" y="155" text-anchor="end" font-family="ui-monospace, monospace" font-size="3.5" fill="#0a0e17" opacity="0.7">VOL.XXIV · NO.1138</text>
    <text x="24" y="167" font-family="Georgia, serif" font-size="6" font-weight="700" fill="#0a0e17">BTC RIPS ON FED PIVOT</text>
    <text x="24" y="174" font-family="Georgia, serif" font-size="4" font-style="italic" fill="#0a0e17" opacity="0.7">algos divided, volume spikes</text>
    <line x1="24" y1="181" x2="96" y2="181" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <line x1="24" y1="184" x2="96" y2="184" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <line x1="24" y1="187" x2="96" y2="187" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <line x1="24" y1="190" x2="96" y2="190" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <line x1="24" y1="193" x2="96" y2="193" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <line x1="24" y1="196" x2="96" y2="196" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <line x1="24" y1="199" x2="96" y2="199" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <line x1="24" y1="202" x2="96" y2="202" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <line x1="24" y1="205" x2="96" y2="205" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <line x1="24" y1="208" x2="96" y2="208" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <text x="106" y="167" font-family="Georgia, serif" font-size="6" font-weight="700" fill="#0a0e17">ETH FORK · WHALES MOVE</text>
    <text x="106" y="174" font-family="Georgia, serif" font-size="4" font-style="italic" fill="#0a0e17" opacity="0.7">on-chain quiet, social loud</text>
    <line x1="106" y1="181" x2="176" y2="181" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <line x1="106" y1="184" x2="176" y2="184" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <line x1="106" y1="187" x2="176" y2="187" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <line x1="106" y1="190" x2="176" y2="190" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <line x1="106" y1="193" x2="176" y2="193" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <line x1="106" y1="196" x2="176" y2="196" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <line x1="106" y1="199" x2="176" y2="199" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <line x1="106" y1="202" x2="176" y2="202" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <line x1="106" y1="205" x2="176" y2="205" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <line x1="106" y1="208" x2="176" y2="208" stroke="#0a0e17" stroke-width="0.45" opacity="0.45"></line>
    <circle cx="19" cy="154" r="6" fill="#5c2f88"></circle>
    <circle cx="181" cy="154" r="6" fill="#5c2f88"></circle>
  </g>
</svg>
