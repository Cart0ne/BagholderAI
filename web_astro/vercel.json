{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/buy",
      "destination": "https://payhip.com/BagHolderAI",
      "permanent": false
    },
    {
      "source": "/guide",
      "destination": "/library",
      "permanent": true
    },
    {
      "source": "/guide.html",
      "destination": "/library",
      "permanent": true
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap-index.xml",
      "permanent": false
    }
  ]
}
